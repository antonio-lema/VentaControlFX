<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.Rectangle?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #525659;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.controller.PrintPreviewController">
   <children>
      <!-- PREVIEW AREA (Left/Center) -->
      <StackPane HBox.hgrow="ALWAYS" style="-fx-background-color: #525659;">
         <children>
            <ScrollPane fitToHeight="false" fitToWidth="false" style="-fx-background: #525659; -fx-border-color: transparent;" hbarPolicy="AS_NEEDED" vbarPolicy="AS_NEEDED">
               <content>
                  <StackPane style="-fx-padding: 30; -fx-background-color: #525659;">
                     <children>
                        <!-- A4 PAPER SIMULATION -->
                        <VBox fx:id="paperSheet" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="650.0" minWidth="460.0" prefWidth="460.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 10, 0, 0, 0); -fx-padding: 40 40 40 40; -fx-font-family: 'Arial'; -fx-text-fill: black;" spacing="0">
                           <children>
                                <!-- Header -->
                                <VBox alignment="TOP_CENTER" spacing="5.0">
                                   <!-- Logo/Brand -->
                                    <HBox alignment="CENTER" spacing="5">
                                        <Label text="☁" style="-fx-text-fill: #2196F3; -fx-font-size: 24;" />
                                        <Label text="GestionTPV" style="-fx-font-weight: bold; -fx-font-size: 22; -fx-text-fill: #2196F3;" />
                                    </HBox>
                                    
                                   <Label text="Gestion TPV Demo," style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: black;" />
                                   <Label text="c/ demo 10, 28020 Madrid" style="-fx-font-size: 10; -fx-text-fill: black;" />
                                   <Label text="Teléfono: 915555555" style="-fx-font-size: 10; -fx-text-fill: black;" />
                                   <Label text="CIF: B-55555555" style="-fx-font-size: 10; -fx-text-fill: black;" />
                                </VBox>
                                
                                <Region prefHeight="20.0" />
                                
                                <!-- Ticket Info -->
                                <VBox alignment="CENTER_LEFT" spacing="2.0">
                                    <Label fx:id="lblGiftIndicator" managed="false" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #1a73e8; -fx-padding: 0 0 5 0;" text="TICKET REGALO" visible="false" />
                                    <Label fx:id="lblTicketTitle" style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: black;" text="Factura simplificada Nº: 01/4246" />
                                    <Label fx:id="lblDate" style="-fx-font-size: 10; -fx-text-fill: black;" text="Fecha: 18 Feb, 2026 Hora: 12:20:38 Caja: 01" />
                                </VBox>
                                
                                <Region prefHeight="15.0" />

                                <!-- Items Header -->
                                <HBox spacing="10.0" style="-fx-border-color: transparent transparent black transparent; -fx-border-width: 0.5; -fx-padding: 0 0 2 0;">
                                   <children>
                                      <Label text="Descripción" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: black;" />
                                      <Label text="Cant." prefWidth="30.0" alignment="CENTER_RIGHT" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: black;" />
                                      <Label text="PVP" prefWidth="55.0" fx:id="lblPVPHeader" alignment="CENTER_RIGHT" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: black;" />
                                      <Label text="Total" prefWidth="55.0" fx:id="lblTotalHeader" alignment="CENTER_RIGHT" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: black;" />
                                   </children>
                                </HBox>
                                
                                <!-- Items Container -->
                                <VBox fx:id="itemsContainer" spacing="0.0" minHeight="50.0" style="-fx-padding: 5 0 5 0;" />
                                
                                <Separator style="-fx-opacity: 1;" />
                                <Region prefHeight="10.0" />
                                
                                <!-- Totals -->
                                <VBox fx:id="totalsContainer" spacing="3.0">
                                    <HBox>
                                       <Label text="Subtotal" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-size: 10; -fx-text-fill: black;" />
                                       <Label fx:id="lblSubtotal" text="0,00 €" style="-fx-font-size: 10; -fx-alignment: CENTER_RIGHT; -fx-text-fill: black;" />
                                    </HBox>
                                    <HBox>
                                       <Label text="IVA 21%" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-size: 10; -fx-text-fill: black;" />
                                       <Label fx:id="lblVat" text="0,00 €" style="-fx-font-size: 10; -fx-text-fill: black;" />
                                    </HBox>
                                    <HBox style="-fx-padding: 5 0 0 0;">
                                       <Label text="TOTAL" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: black;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                                       <Label fx:id="lblTotal" text="0,00 €" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: black;" />
                                    </HBox>
                                </VBox>
                                <Region prefHeight="15.0" />
                                
                                <!-- Payment Info -->
                                <VBox fx:id="paymentInfoContainer" spacing="2.0">
                                    <HBox>
                                        <Label text="Forma de pago" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-size: 10; -fx-text-fill: black;" />
                                        <Label fx:id="lblPaymentMethod" text="Efectivo" style="-fx-font-size: 10; -fx-text-fill: black;" />
                                    </HBox>
                                     <HBox>
                                        <Label text="Entregado" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-size: 10; -fx-text-fill: black;" />
                                        <Label fx:id="lblPaid" text="0,00 €" style="-fx-font-size: 10; -fx-text-fill: black;" />
                                    </HBox>
                                </VBox>
                                
                                <Region VBox.vgrow="ALWAYS" />
                                
                                <!-- Footer -->
                                <!-- Spacer to push footer down -->
                                <Region VBox.vgrow="ALWAYS" />
                                
                                <!-- Footer -->
                                <VBox alignment="CENTER" spacing="5.0" style="-fx-padding: 10 0 0 0;">
                                    <Label text="Le ha atendido Admin" style="-fx-text-fill: grey; -fx-font-size: 9;" />
                                    <Label text="GRACIAS POR SU VISITA" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: black;" />
                                    
                                    <Region prefHeight="10.0" />
                                    <Separator style="-fx-opacity: 0.5;" />
                                    <Label text="www.gestiontpv.com" style="-fx-font-size: 8; -fx-text-fill: grey;" />
                                </VBox>
                                
                                <!-- Barcode (Gift Ticket) -->
                                <VBox fx:id="barcodeSection" alignment="CENTER" spacing="5" managed="false" visible="false">
                                    <HBox fx:id="barcodeContainer" alignment="CENTER" spacing="1" style="-fx-padding: 10 0;" />
                                    <Label fx:id="lblBarcodeValue" style="-fx-font-size: 8; -fx-text-fill: black;" text="0123456789" />
                                </VBox>

                           </children>
                        </VBox>
                     </children>
                  </StackPane>
               </content>
            </ScrollPane>
         </children>
      </StackPane>

      <!-- SETTINGS SIDEBAR (Right) -->
      <VBox prefWidth="350.0" style="-fx-background-color: white; -fx-padding: 25 30 25 30;" spacing="20">
         <children>
            <HBox alignment="CENTER_LEFT">
                <Label text="Imprimir" style="-fx-font-size: 18; -fx-font-weight: normal; -fx-text-fill: #333;" />
                <Region HBox.hgrow="ALWAYS" />
                <Label text="1 hoja de papel" style="-fx-text-fill: #666; -fx-font-size: 12;" />
            </HBox>
            
            <Region prefHeight="10.0" />
            
            <VBox spacing="20">
                <!-- Destino -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label text="Destino" style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 12;" prefWidth="60" />
                    <ComboBox fx:id="cmbPrinters" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 4;" />
                </HBox>
                
                <!-- Paginas -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label text="Páginas" style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 12;" prefWidth="60" />
                    <ComboBox maxWidth="Infinity" promptText="Todas" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 4;" />
                </HBox>
                
                <!-- Copias -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label text="Copias" style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 12;" prefWidth="60" />
                    <TextField text="1" maxWidth="100" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 4;" />
                </HBox>
                
                 <!-- Diseño -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <Label text="Diseño" style="-fx-font-weight: bold; -fx-text-fill: #555; -fx-font-size: 12;" prefWidth="60" />
                    <ComboBox maxWidth="Infinity" promptText="Vertical" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #ddd; -fx-border-radius: 4;" />
                </HBox>
                
                <!-- More Settings -->
                <HBox alignment="CENTER_LEFT">
                    <Label text="Más ajustes" style="-fx-text-fill: #1a73e8; -fx-font-weight: bold; -fx-cursor: hand;" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="▼" style="-fx-text-fill: #1a73e8; -fx-font-size: 10;" />
                </HBox>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <HBox spacing="10" alignment="CENTER">
                <Button text="Imprimir" onAction="#confirmPrint" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 25; -fx-cursor: hand;" graphicTextGap="10">
                    <graphic>
                        <Label text="⎙" style="-fx-text-fill: white; -fx-font-size: 16;" />
                    </graphic>
                </Button>
                <Button fx:id="btnGiftTicket" style="-fx-background-color: white; -fx-text-fill: #1a73e8; -fx-border-color: #1a73e8; -fx-border-radius: 25; -fx-border-width: 1; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 25; -fx-cursor: hand;" text="Ticket regalo">
                    <graphic>
                        <Label fx:id="lblGiftIcon" style="-fx-font-size: 16; -fx-text-fill: #1a73e8;" text="🎁" />
                    </graphic>
                </Button>
            </HBox>
            
            <Separator style="-fx-padding: 10 0;" />
            
            <HBox spacing="10" alignment="CENTER">
                <Button text="Volver" onAction="#cancel" style="-fx-background-color: #ea4335; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 25; -fx-background-radius: 25; -fx-cursor: hand;" />
                <Button text="Nueva Venta" onAction="#cancel" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 25; -fx-background-radius: 25; -fx-cursor: hand;" />
            </HBox>
         </children>
      </VBox>
   </children>
</HBox>
