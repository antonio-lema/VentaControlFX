<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="20" styleClass="modal-container"
      xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.PriceListContentController"
      prefWidth="750" prefHeight="550">
      
    <padding>
        <Insets top="25" right="30" bottom="25" left="30"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <VBox HBox.hgrow="ALWAYS">
            <Label fx:id="lblTitle" text="Precios de la tarifa..." styleClass="view-header"/>
            <Label text="Consulta rápida de precios para la tarifa seleccionada" styleClass="view-subtitle"/>
        </VBox>
        <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand;">
            <graphic>
                <FontAwesomeIconView glyphName="TIMES" size="20" fill="#9ca3af"/>
            </graphic>
        </Button>
    </HBox>

    <!-- Barra de Búsqueda -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <HBox styleClass="modern-input-container" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
            <FontAwesomeIconView glyphName="SEARCH" size="16" styleClass="sidebar-icon"/>
            <TextField fx:id="txtSearch" promptText="Buscar por producto o categoría..." styleClass="modern-input-field" HBox.hgrow="ALWAYS">
                <HBox.margin>
                    <Insets left="10"/>
                </HBox.margin>
            </TextField>
        </HBox>
    </HBox>

    <!-- Content -->
    <TableView fx:id="tablePrices" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <placeholder>
            <Label text="No hay precios registrados en esta tarifa" style="-fx-text-fill: #9ca3af; -fx-font-size: 14px;"/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50" style="-fx-alignment: CENTER;" />
            <TableColumn fx:id="colCategory" text="Categoría" prefWidth="120" />
            <TableColumn fx:id="colProduct" text="Producto" prefWidth="200" />
            <TableColumn fx:id="colBasePrice" text="P. Base" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" />
            <TableColumn fx:id="colListPrice" text="P. Lista" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;" />
            <TableColumn fx:id="colListPvp" text="PVP Final" prefWidth="100" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold; -fx-text-fill: #1e40af;" />
            <TableColumn fx:id="colDiff" text="Δ %" prefWidth="70" style="-fx-alignment: CENTER-RIGHT;" />
        </columns>
    </TableView>

    <!-- Pagination -->
    <HBox alignment="CENTER_RIGHT" spacing="15">
        <javafx.scene.control.Pagination fx:id="pagination" maxPageIndicatorCount="5" styleClass="server-pagination" />
        <Label fx:id="lblCount" text="0 productos" style="-fx-text-fill: #6b7280; -fx-font-weight: bold;"/>
    </HBox>

    <!-- Actions -->
    <HBox alignment="CENTER_RIGHT">
        <Button text="Cerrar" onAction="#handleClose" styleClass="btn-secondary"/>
    </HBox>

</VBox>
