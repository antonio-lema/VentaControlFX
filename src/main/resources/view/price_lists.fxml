<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.geometry.Insets?>

<VBox spacing="0" styleClass="main-content-area" style="-fx-padding: 0;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.PriceListController">
    <!-- Header Section -->
    <VBox styleClass="view-header" spacing="0">
        <HBox alignment="CENTER_LEFT" spacing="16">
            <StackPane styleClass="view-header-icon-wrap">
                <FontAwesomeIconView glyphName="MONEY" size="24" fill="white"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="Gesti\u00f3n de Tarifas" styleClass="view-title"/>
                <Label text="Administra las listas de precios aplicables a ventas y clientes" styleClass="view-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Nueva Tarifa" onAction="#openNewPriceListForm" styleClass="btn-primary">
                <graphic>
                    <FontAwesomeIconView glyphName="PLUS" size="14" fill="WHITE"/>
                </graphic>
            </Button>
        </HBox>
    </VBox>

    <VBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 25 35;">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="lblCount" text="0 tarifas registradas" styleClass="metric-value-small, text-muted"/>
        </HBox>

        <!-- Content area -->
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="edge-to-edge">
            <FlowPane fx:id="priceListsContainer" hgap="20" vgap="20" prefWrapLength="800">
                <padding>
                    <Insets top="5" right="5" bottom="5" left="5"/>
                </padding>
                <!-- Las tarjetas de tarifas se generar\u00e1n aqu\u00ed din\u00e1micamente -->
            </FlowPane>
        </ScrollPane>
    </VBox>
</VBox>
