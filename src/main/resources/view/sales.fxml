<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<AnchorPane id="AnchorPane" prefHeight="750.0" prefWidth="1100.0" styleClass="main-content-area"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.ventacontrolfx.presentation.controller.HistoryController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="10.0" left="25.0" right="25.0" top="25.0" />
         </padding>
         <children>
            <!-- Header Section -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <VBox>
                     <children>
                        <Label text="📜 Historial de Ventas" styleClass="section-title"/>
                        <Label text="Consulta y filtra las ventas por rango de fechas 🔍" styleClass="section-subtitle"/>
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />

                  <!-- Advanced Range Filter -->
                  <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="filter-card">
                     <children>
                        <VBox spacing="2">
                           <children>
                              <Label text="DESDE" styleClass="filter-label-cap" />
                              <DatePicker fx:id="datePickerStart" onAction="#loadSales" prefWidth="130.0" styleClass="filter-datepicker" />
                           </children>
                        </VBox>
                        <Separator orientation="VERTICAL" prefHeight="30" />
                        <VBox spacing="2">
                           <children>
                              <Label text="HASTA" styleClass="filter-label-cap" />
                              <DatePicker fx:id="datePickerEnd" onAction="#loadSales" prefWidth="130.0" styleClass="filter-datepicker" />
                           </children>
                        </VBox>
                        <Separator orientation="VERTICAL" prefHeight="30" />
                        <VBox spacing="2">
                           <children>
                              <Label text="BUSCAR TICKET" styleClass="filter-label-cap" />
                              <TextField fx:id="txtSearchId" promptText="Nº Ticket..." onAction="#handleSearch" prefWidth="100.0" styleClass="filter-search-field" />
                           </children>
                        </VBox>
                        <Button onAction="#loadSales" styleClass="btn-primary" text="Filtrar">
                           <graphic><FontAwesomeIconView glyphName="SEARCH" fill="WHITE" /></graphic>
                        </Button>
                        <Button onAction="#handleClearFilters" styleClass="btn-secondary" text="Limpiar">
                           <graphic><FontAwesomeIconView glyphName="ERASER" styleClass="sidebar-icon" /></graphic>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </HBox>

            <!-- Quick Filters Toolbar -->
            <HBox spacing="10.0" alignment="CENTER_LEFT">
               <children>
                  <Label text="Accesos rápidos:" styleClass="label-muted" style="-fx-font-weight: bold;" />
                  <Button fx:id="btnQuickToday" onAction="#filterToday" styleClass="quick-filter-btn" text="Hoy" />
                  <Button fx:id="btnQuickWeek" onAction="#filterLast7Days" styleClass="quick-filter-btn" text="Últimos 7 días" />
                  <Button fx:id="btnQuickMonth" onAction="#filterThisMonth" styleClass="quick-filter-btn" text="Este mes" />
               </children>
            </HBox>

            <!-- Summary Cards -->
            <HBox spacing="20.0">
               <children>
                  <VBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <StackPane styleClass="stat-icon-bg stat-icon-bg-blue">
                                 <children><FontAwesomeIconView glyphName="SHOPPING_CART" size="22" fill="white" /></children>
                              </StackPane>
                              <Label text="🎫 Tickets" styleClass="stat-label" />
                           </children>
                        </HBox>
                        <Label fx:id="lblTotalSalesCount" text="0" styleClass="stat-value, text-info" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <StackPane styleClass="stat-icon-bg stat-icon-bg-green">
                                 <children><FontAwesomeIconView glyphName="EURO" size="22" fill="white" /></children>
                              </StackPane>
                              <Label text="💰 Total Recaudado" styleClass="stat-label" />
                           </children>
                        </HBox>
                        <Label fx:id="lblTotalAmount" text="0,00 €" styleClass="stat-value, text-total" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <StackPane styleClass="stat-icon-bg stat-icon-bg-orange">
                                 <children><FontAwesomeIconView glyphName="MONEY" size="22" fill="white" /></children>
                              </StackPane>
                              <Label text="💵 Efectivo" styleClass="stat-label" />
                           </children>
                        </HBox>
                        <Label fx:id="lblTotalCash" text="0,00 €" styleClass="stat-value, text-cash" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <StackPane styleClass="stat-icon-bg stat-icon-bg-purple">
                                 <children><FontAwesomeIconView glyphName="CREDIT_CARD" size="22" fill="white" /></children>
                              </StackPane>
                              <Label text="💳 Tarjeta" styleClass="stat-label" />
                           </children>
                        </HBox>
                        <Label fx:id="lblTotalCard" text="0,00 €" styleClass="stat-value, text-card" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Sales Table -->
                  <VBox spacing="0" styleClass="table-card" HBox.hgrow="ALWAYS">
                     <children>
                        <TableView fx:id="salesTable" styleClass="modern-table-view" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colId" prefWidth="100.0" text="Nº TICKET" />
                            <TableColumn fx:id="colUser" prefWidth="180.0" text="ATENDIDO POR" />
                            <TableColumn fx:id="colDate" prefWidth="150.0" text="FECHA Y HORA" />
                            <TableColumn fx:id="colTotal" prefWidth="120.0" text="IMPORTE TOTAL" />
                            <TableColumn fx:id="colMethod" prefWidth="150.0" text="MÉTODO DE PAGO" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT" prefHeight="30.0" spacing="10.0">
                           <children>
                              <Label fx:id="lblCount" text="0 tickets encontrados" styleClass="label-muted" style="-fx-font-weight: bold;" />
                           </children>
                           <padding>
                              <Insets right="10.0" />
                           </padding>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- Receipt Side Panel -->
                  <VBox fx:id="detailsPanel" prefWidth="380.0" visible="false" managed="false" styleClass="detail-panel">
                     <children>
                        <HBox prefHeight="6.0" styleClass="detail-panel-accent" />
                        <VBox spacing="15.0" styleClass="detail-panel-body" VBox.vgrow="ALWAYS">
                           <children>
                              <VBox alignment="CENTER" spacing="5">
                                 <children>
                                    <Label text="📦 DETALLE DE TRANSACCIÓN" styleClass="filter-label-cap" />
                                    <HBox spacing="10" alignment="CENTER">
                                        <children>
                                            <Label fx:id="lblSaleId" text="Ticket #0000" styleClass="detail-sale-id" />
                                            <Label fx:id="lblReturnBadge" text="DEVUELTO" visible="false" styleClass="badge-danger" />
                                        </children>
                                     </HBox>
                                    <Label fx:id="lblSaleFullDate" text="18/02/2026 15:30" styleClass="label-muted" />
                                 </children>
                              </VBox>

                              <Separator />

                              <Label text="PRODUCTOS" styleClass="filter-label-cap" />
                              <ScrollPane fitToWidth="true" styleClass="detail-scroll" prefHeight="300.0">
                                 <content>
                                    <VBox fx:id="detailsItemsContainer" spacing="12.0" styleClass="detail-items-container" />
                                 </content>
                              </ScrollPane>

                              <Separator />

                              <VBox spacing="8.0">
                                 <children>
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label text="Método de pago" styleClass="label-muted" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Label fx:id="lblPaymentMethod" text="Efectivo" styleClass="detail-info-value" />
                                       </children>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                                       <children>
                                          <Label text="TOTAL TICKET" styleClass="detail-total-label" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Label fx:id="lblTotalAmountDetail" text="0,00 €" styleClass="detail-total-value, text-total" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>

                               <HBox spacing="10">
                                  <children>
                                      <Button fx:id="btnPrint" onAction="#handlePrintTicket" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="btn-primary btn-lg">
                                         <graphic>
                                            <FontAwesomeIconView glyphName="PRINT" fill="white" size="18" />
                                         </graphic>
                                         <text> IMPRIMIR </text>
                                      </Button>
                                      <Button fx:id="btnReturn" onAction="#handleRegisterReturn" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="btn-warning btn-lg">
                                         <graphic>
                                            <FontAwesomeIconView glyphName="REPLY" fill="white" size="18" />
                                         </graphic>
                                         <text> DEVOLVER </text>
                                      </Button>
                                  </children>
                               </HBox>

                               <Region VBox.vgrow="ALWAYS" />
                               <Button onAction="#handleCloseDetails" maxWidth="Infinity" styleClass="btn-secondary btn-lg" text="CERRAR DETALLES" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
