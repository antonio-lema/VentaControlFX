<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import de.jensd.fx.glyphs.fontawesome.*?>

<VBox spacing="0" styleClass="main-content-area" style="-fx-padding: 0;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.closure.CashClosureController"
      maxWidth="Infinity" maxHeight="Infinity">

    <!-- Header Area Modernizado -->
    <VBox styleClass="view-header" spacing="0">
        <HBox alignment="CENTER_LEFT" spacing="20">
            <StackPane styleClass="view-header-icon-wrap">
                <FontAwesomeIconView glyphName="CALCULATOR" size="24" fill="white"/>
            </StackPane>
            <VBox spacing="2">
                <Label text="%closure.main_title" styleClass="view-title"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="lblDate" text="20 Feb, 2026" styleClass="view-subtitle"/>
                    <Label text="&#x2022;" styleClass="view-subtitle"/>
                    <Label fx:id="lblCurrentUser" text="Admin" styleClass="view-subtitle" style="-fx-font-weight: bold;"/>
                </HBox>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button onAction="#handleClose" styleClass="btn-icon" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 50;">
                <graphic>
                    <FontAwesomeIconView glyphName="CLOSE" size="18" fill="white"/>
                </graphic>
            </Button>
        </HBox>
    </VBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS" style="-fx-padding: 25;">
        <!-- Left Column: Scrollable stats and actions -->
        <ScrollPane prefWidth="420" fitToWidth="true" hbarPolicy="NEVER" styleClass="estetica-scroll" 
                   style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="14">
                <!-- TPP TARJETA: EFECTIVO EN CAJA PPW -->
                <VBox fx:id="cardCash" spacing="12" styleClass="estetica-card">
                    <HBox styleClass="estetica-card-header" alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="estetica-card-icon-wrap, estetica-icon-green">
                            <FontAwesomeIconView glyphName="MONEY" size="18" fill="#22c55e"/>
                        </StackPane>
                        <VBox>
                            <Label text="%closure.card.cash_in_drawer" styleClass="estetica-card-title"/>
                            <Label text="%closure.card.cash_desc" styleClass="estetica-card-desc"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnRefreshCash" onAction="#handleRefreshCash"
                                styleClass="btn-icon" style="-fx-min-width: 28; -fx-min-height: 28;">
                            <graphic>
                                <FontAwesomeIconView glyphName="REFRESH" size="13" styleClass="sidebar-icon"/>
                            </graphic>
                            <tooltip><Tooltip text="Actualizar saldo"/></tooltip>
                        </Button>
                    </HBox>

                    <!-- Saldo actual prominente -->
                    <VBox alignment="CENTER" spacing="4" style="-fx-padding: 10 0 6 0;">
                        <Label fx:id="lblCashInDrawer" text="%closure.cash.no_session"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: -text-muted;"/>
                        <Label fx:id="lblActiveFund" text="%closure.cash.no_fund"
                               style="-fx-font-size: 12px; -fx-text-fill: -color-warning; -fx-font-weight: bold;"/>
                    </VBox>

                    <!-- Botones de gesti&#x00f3;n de caja -->
                    <VBox styleClass="estetica-card-body" spacing="8">
                        <Button fx:id="btnOpenFund" onAction="#handleOpenFund"
                                maxWidth="Infinity" text="%closure.btn.open_fund"
                                styleClass="btn-success"/>
                        <Button fx:id="btnWithdrawCash" onAction="#handleWithdrawCash"
                                maxWidth="Infinity" text="%closure.btn.withdraw"
                                styleClass="btn-danger" disable="true"/>
                        <Button fx:id="btnRegisterCashEntry" onAction="#handleRegisterCashEntry"
                                maxWidth="Infinity" text="%closure.btn.deposit"
                                styleClass="btn-primary" disable="true"/>
                    </VBox>
                </VBox>

                <!-- TPP TARJETA: CONTABILIDAD PPW -->
                <VBox fx:id="cardAccounting" spacing="15" styleClass="estetica-card">
                    <HBox styleClass="estetica-card-header" alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="estetica-card-icon-wrap, estetica-icon-blue">
                            <FontAwesomeIconView glyphName="BALANCE_SCALE" size="16" fill="#1e88e5"/>
                        </StackPane>
                        <VBox>
                            <Label text="%closure.card.accounting" styleClass="estetica-card-title"/>
                            <Label text="%closure.card.accounting_desc" styleClass="estetica-card-desc"/>
                        </VBox>
                    </HBox>
                    <VBox styleClass="estetica-card-body" spacing="18">
                        <VBox spacing="5" styleClass="closure-amount-row">
                            <Label text="%closure.cash_sold" styleClass="label-muted"/>
                            <Label fx:id="lblTotalCash" text="0,00 &#x20ac;" styleClass="closure-amount-cash" style="-fx-font-size: 20px;"/>
                        </VBox>

                        <VBox spacing="5" styleClass="closure-amount-row">
                            <Label text="%closure.card_sold" styleClass="label-muted"/>
                            <Label fx:id="lblTotalCard" text="0,00 &#x20ac;" styleClass="closure-amount-card" style="-fx-font-size: 20px;"/>
                        </VBox>

                        <VBox fx:id="containerReturns" spacing="5" styleClass="closure-amount-row" visible="false" managed="false">
                            <Label text="%closure.returns" styleClass="label-muted"/>
                            <Label fx:id="lblTotalReturns" text="0,00 &#x20ac;"
                                   style="-fx-text-fill: -color-danger; -fx-font-weight: bold; -fx-font-size: 20px;"/>
                        </VBox>

                        <!-- Descuentos Aplicados -->
                        <VBox fx:id="containerDiscounts" spacing="5" styleClass="closure-amount-row" visible="false" managed="false">
                            <Label text="%closure.discounts" styleClass="label-muted"/>
                            <Label fx:id="lblTotalDiscounts" text="0,00 &#x20ac;"
                                   style="-fx-text-fill: #16a34a; -fx-font-weight: bold; -fx-font-size: 20px;"/>
                        </VBox>

                        <!-- Highlighted total -->
                        <VBox spacing="8" styleClass="estetica-preview-wrapper" style="-fx-alignment: center;">
                            <Label text="%closure.net_total" styleClass="estetica-preview-title"/>
                            <Label fx:id="lblTotalAll" text="0,00 &#x20ac;" styleClass="closure-grand-total" style="-fx-font-size: 32px; -fx-text-fill: -color-primary;"/>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Stats Section -->
                <VBox spacing="15" styleClass="estetica-card">
                    <HBox styleClass="estetica-card-header" alignment="CENTER_LEFT" spacing="12">
                        <StackPane styleClass="estetica-card-icon-wrap, estetica-icon-purple">
                            <FontAwesomeIconView glyphName="BAR_CHART" size="16" fill="#8b5cf6"/>
                        </StackPane>
                        <VBox>
                            <Label text="%closure.stats.title" styleClass="estetica-card-title"/>
                            <Label text="%closure.stats.desc" styleClass="estetica-card-desc"/>
                        </VBox>
                    </HBox>
                    <VBox styleClass="estetica-card-body">
                        <GridPane vgap="14" hgap="10">
                            <Label text="%closure.stats.transactions" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Label fx:id="lblSalesCount" text="0" styleClass="estetica-card-title" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                            <Label text="%closure.stats.status" styleClass="label-muted" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <Label fx:id="lblStatus" text="%cash.status.pending" styleClass="badge-primary" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        </GridPane>
                    </VBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" minHeight="10"/>


            </VBox>
        </ScrollPane>

        <!-- Right Column: Product Breakdown -->
        <VBox fx:id="cardProductSummary" spacing="20" HBox.hgrow="ALWAYS" styleClass="estetica-card" style="-fx-padding: 0;">
            <HBox styleClass="estetica-card-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane styleClass="estetica-card-icon-wrap, estetica-icon-blue">
                    <FontAwesomeIconView glyphName="LIST" size="16" fill="#1e88e5"/>
                </StackPane>
                <VBox>
                    <Label text="%closure.product_breakdown" styleClass="estetica-card-title"/>
                    <Label text="%closure.product_breakdown_desc" styleClass="estetica-card-desc"/>
                </VBox>
            </HBox>

            <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 20;" spacing="15">
                <TableView fx:id="tableProductSummary" VBox.vgrow="ALWAYS" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="colProdName" text="%closure.table.product" prefWidth="350" />
                        <TableColumn fx:id="colProdQty" text="%closure.table.quantity" prefWidth="120" />
                        <TableColumn fx:id="colProdTotal" text="%closure.table.total" prefWidth="180" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <Label text="%closure.info.pending" styleClass="estetica-card-desc"/>
                </HBox>
            </VBox>
        </VBox>
    </HBox>

    <!-- Fixed Footer Action Bar -->
    <HBox styleClass="estetica-action-bar" spacing="20" alignment="CENTER_LEFT">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <FontAwesomeIconView glyphName="INFO_CIRCLE" size="14" fill="#64748b"/>
            <Label text="%closure.footer.ensure" styleClass="estetica-card-desc"/>
        </HBox>
        
        <Region HBox.hgrow="ALWAYS"/>

        <Button onAction="#handleRefreshCash" styleClass="estetica-btn-secondary" text="%closure.btn.sync">
            <graphic>
                <FontAwesomeIconView glyphName="REFRESH" size="13"/>
            </graphic>
        </Button>
        <Button fx:id="btnPerformClosure" onAction="#handlePerformClosure"
                text="%closure.btn.confirm"
                styleClass="estetica-btn-save" prefWidth="320">
            <graphic>
                <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="16"/>
            </graphic>
        </Button>
    </HBox>
</VBox>
