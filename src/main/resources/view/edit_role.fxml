<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.ventacontrolfx.presentation.controller.EditRoleController"
           styleClass="register-popup-background" fx:id="rootStackPane"
           onMousePressed="#handleMousePressed" onMouseDragged="#handleMouseDragged">

    <!-- Modern Role Card -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent;" maxHeight="700">
        <content>
            <VBox alignment="CENTER" spacing="0" maxWidth="480" minWidth="480" styleClass="modern-register-card">
                <padding>
                    <Insets top="35" right="40" bottom="35" left="40"/>
                </padding>

                <!-- Header -->
                <VBox styleClass="modern-register-header" alignment="CENTER_LEFT">
                    <Label fx:id="lblTitle" text="Crear Nuevo Rol" styleClass="modern-register-title"/>
                    <Label text="Define el conjunto de permisos para este rol" styleClass="modern-register-subtitle"/>
                </VBox>

                <!--  DATOS DEL ROL  -->
                <VBox spacing="12">
                    
                    <VBox styleClass="modern-input-group">
                        <HBox styleClass="modern-input-container">
                            <FontAwesomeIconView glyphName="TAG" size="18" styleClass="sidebar-icon"/>
                            <TextField fx:id="txtRoleName" promptText="Nombre del Rol (ej. Vendedor)" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                        </HBox>
                    </VBox>

                    <VBox styleClass="modern-input-group">
                        <HBox styleClass="modern-input-container" style="-fx-alignment: top-left; -fx-padding: 8;">
                            <FontAwesomeIconView glyphName="INFO_CIRCLE" size="16" styleClass="sidebar-icon" style="-fx-translate-y: 5;"/>
                            <TextArea fx:id="txtDescription" promptText="Descripci&#x00f3;n" wrapText="true" prefRowCount="3" HBox.hgrow="ALWAYS" styleClass="modern-input-field" style="-fx-background-color: transparent; -fx-border-width: 0;"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!--  SECCI&#x00d3;N DE PERMISOS  -->
                <VBox spacing="10" style="-fx-padding: 16 0 0 0;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontAwesomeIconView glyphName="SHIELD" size="16" styleClass="sidebar-icon"/>
                        <Label text="Permisos del Rol" styleClass="permission-section-title"/>
                    </HBox>
                    <Label text="Selecciona qu&#x00e9; acciones estar&#x00e1;n permitidas para los usuarios con este rol"
                           styleClass="permission-section-subtitle" wrapText="true"/>

                    <VBox fx:id="permissionsContainer" spacing="8" styleClass="permissions-box">
                        <padding>
                            <Insets top="10" right="15" bottom="10" left="15"/>
                        </padding>
                        <!-- Los CheckBox se inyectan din&#x00e1;micamente desde el controlador -->
                    </VBox>
                </VBox>

                <!-- Error label -->
                <Label fx:id="lblError" text="" styleClass="modern-error-label" wrapText="true"
                       visible="false" managed="false" style="-fx-padding: 8 0 0 0;"/>

                <!-- Spacer -->
                <VBox minHeight="16"/>

                <!-- Actions -->
                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button fx:id="btnCancel" text="Cancelar" onAction="#handleCancel"
                            styleClass="modern-btn-secondary" cancelButton="true"/>
                    <Button fx:id="btnSave" text="Guardar Rol" onAction="#handleSave"
                            styleClass="modern-btn-primary" defaultButton="true"/>
                </HBox>

            </VBox>
        </content>
    </ScrollPane>
</StackPane>
