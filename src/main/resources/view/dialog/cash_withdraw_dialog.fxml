<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="15" styleClass="modal-container" prefWidth="450" stylesheets="@/styles/variables.css" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.closure.CashWithdrawController">
    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <StackPane styleClass="icon-container-blue" maxWidth="45" maxHeight="45" style="-fx-background-color: rgba(239, 68, 68, 0.1);">
            <FontAwesomeIconView glyphName="MINUS_CIRCLE" size="20" fill="#ef4444"/>
        </StackPane>
        <VBox spacing="2">
            <Label text="Retirar Efectivo" styleClass="modal-title"/>
            <Label text="Registra una salida de dinero de caja" styleClass="modal-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleCancel" styleClass="button-ghost" text="&#x2715;" style="-fx-font-size: 16px;"/>
    </HBox>

    <Separator/>

    <VBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Saldo disponible -->
        <HBox fx:id="bannerAvailable" spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: #fef2f2; -fx-padding: 12; -fx-background-radius: 12; -fx-border-color: #fecaca; -fx-border-width: 1;">
            <FontAwesomeIconView glyphName="WARNING" size="16" fill="#dc2626" />
            <VBox spacing="2">
                <Label text="Efectivo disponible en caja" styleClass="text-xs, text-gray-500" />
                <Label fx:id="lblAvailable" text="0,00 &#x20ac;" style="-fx-font-weight: 800; -fx-text-fill: #dc2626; -fx-font-size: 15px;" />
            </VBox>
        </HBox>

        <!-- Importe -->
        <VBox spacing="8">
            <Label text="Importe a Retirar (&#x20ac;)" styleClass="text-sm, font-medium, text-gray-700" />
            <TextField fx:id="txtAmount" promptText="0,00" styleClass="form-control"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #ef4444;" />
            <!-- Aviso de saldo insuficiente -->
            <Label fx:id="lblWarning" text="" style="-fx-text-fill: #ef4444; -fx-font-size: 12px; -fx-padding: 0 0 0 5;" visible="false" managed="false" />
        </VBox>

        <!-- Motivo -->
        <VBox spacing="8">
            <Label text="Motivo de la Retirada" styleClass="text-sm, font-medium, text-gray-700" />
            <TextField fx:id="txtReason" promptText="Ej: Cambio, gastos menores..." styleClass="form-control" />
        </VBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS" minHeight="10"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button fx:id="btnConfirm" text="Confirmar Retirada" onAction="#handleConfirm" styleClass="btn-danger">
            <graphic>
                <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="14" fill="white" />
            </graphic>
        </Button>
    </HBox>
</VBox>

