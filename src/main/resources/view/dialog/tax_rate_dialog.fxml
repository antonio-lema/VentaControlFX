<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="15" styleClass="modal-container" prefWidth="480" stylesheets="@/styles/variables.css" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.TaxRateDialogController">
    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <StackPane styleClass="icon-container-blue" maxWidth="45" maxHeight="45" style="-fx-background-color: rgba(16, 185, 129, 0.1);">
            <FontAwesomeIconView glyphName="PERCENT" size="20" fill="#10b981"/>
        </StackPane>
        <VBox spacing="2">
            <Label text="Tasa Impositiva" styleClass="modal-title"/>
            <Label text="Configura el porcentaje para este tributo" styleClass="modal-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleCancel" styleClass="button-ghost" text="&#x2715;" style="-fx-font-size: 16px;"/>
    </HBox>

    <Separator/>

    <VBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Nombre -->
        <VBox spacing="8">
            <Label text="Nombre" styleClass="text-sm, font-medium, text-gray-700" />
            <TextField fx:id="txtName" promptText="Ej: IVA 21%, RE 5.2%..." styleClass="form-control" />
        </VBox>

        <!-- Valor -->
        <VBox spacing="8">
            <Label text="Porcentaje (%)" styleClass="text-sm, font-medium, text-gray-700" />
            <TextField fx:id="txtRate" promptText="Ej: 21.00" styleClass="form-control" />
        </VBox>

        <!-- País -->
        <VBox spacing="8">
            <Label text="País (ISO)" styleClass="text-sm, font-medium, text-gray-700" />
            <TextField fx:id="txtCountry" promptText="Completa si aplica, Ej: ES" styleClass="form-control" />
        </VBox>

        <!-- Fecha Inicio -->
        <VBox spacing="8">
            <Label text="Fecha de Inicio / Vigor" styleClass="text-sm, font-medium, text-gray-700" />
            <DatePicker fx:id="dpStartDate" promptText="Seleccionar fecha" maxWidth="Infinity" styleClass="form-control" />
        </VBox>

        <!-- Activo -->
        <CheckBox fx:id="chkActive" text="Tasa activa para nuevos cálculos" styleClass="text-sm, font-medium, text-gray-800" />
    </VBox>

    <Region VBox.vgrow="ALWAYS" minHeight="10"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="Guardar Tasa" onAction="#handleSave" styleClass="btn-primary">
            <graphic>
                <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="14" fill="white" />
            </graphic>
        </Button>
    </HBox>
</VBox>

