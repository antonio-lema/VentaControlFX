<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:id="root" spacing="20" styleClass="modern-register-card" 
      prefWidth="480" alignment="TOP_CENTER"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.TaxRateDialogController">
    
    <stylesheets>
        <URL value="@/styles/variables.css" />
        <URL value="@/styles/components/botones.css" />
        <URL value="@/styles/components/formularios.css" />
    </stylesheets>

    <!-- Header -->
    <VBox spacing="5" alignment="CENTER" style="-fx-padding: 30 0 10 0;">
        <StackPane styleClass="estetica-card-icon-wrap, estetica-icon-green" maxWidth="50" maxHeight="50">
            <FontAwesomeIconView glyphName="PERCENT" size="24" fill="#10b981"/>
        </StackPane>
        <Label text="Tasa Impositiva" styleClass="modern-register-title" />
        <Label text="Configura el porcentaje para este tributo" styleClass="modern-register-subtitle" />
    </VBox>

    <!-- Body -->
    <VBox spacing="18" style="-fx-padding: 0 40 30 40;">
        
        <!-- Nombre -->
        <VBox spacing="8">
            <Label text="Nombre:" styleClass="label" />
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="modern-input-container">
                <FontAwesomeIconView glyphName="TAG" size="16" fill="#64748b" />
                <TextField fx:id="txtName" promptText="Ej: IVA 21%, RE 5.2%..." HBox.hgrow="ALWAYS" styleClass="modern-input-field" />
            </HBox>
        </VBox>

        <!-- Valor -->
        <VBox spacing="8">
            <Label text="Porcentaje (%):" styleClass="label" />
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="modern-input-container">
                <FontAwesomeIconView glyphName="CALCULATOR" size="16" fill="#64748b" />
                <TextField fx:id="txtRate" promptText="Ej: 21.00" HBox.hgrow="ALWAYS" styleClass="modern-input-field" />
            </HBox>
        </VBox>

        <!-- Pa\u00eds -->
        <VBox spacing="8">
            <Label text="Pa\u00eds (ISO):" styleClass="label" />
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="modern-input-container">
                <FontAwesomeIconView glyphName="GLOBE" size="16" fill="#64748b" />
                <TextField fx:id="txtCountry" promptText="Completa si aplica, Ej: ES" HBox.hgrow="ALWAYS" styleClass="modern-input-field" />
            </HBox>
        </VBox>

        <!-- Fecha Inicio -->
        <VBox spacing="8">
            <Label text="Fecha de Inicio / Vigor:" styleClass="label" />
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="modern-input-container">
                <FontAwesomeIconView glyphName="CALENDAR" size="16" fill="#64748b" />
                <DatePicker fx:id="dpStartDate" promptText="Seleccionar fecha" HBox.hgrow="ALWAYS" styleClass="modern-input-field" style="-fx-background-color: transparent;" />
            </HBox>
        </VBox>

        <!-- Activo -->
        <CheckBox fx:id="chkActive" text="Tasa activa para nuevos c\u00e1lculos" styleClass="permission-checkbox" />

        <!-- Barra de acciones -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 10 0;">
            <Button text="CANCELAR" onAction="#handleCancel" styleClass="btn-secondary" prefHeight="45" prefWidth="120" />
            <Button text="GUARDAR" onAction="#handleSave" styleClass="btn-primary" prefHeight="45" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <graphic>
                    <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="18" fill="white" />
                </graphic>
            </Button>
        </HBox>
    </VBox>
</VBox>
