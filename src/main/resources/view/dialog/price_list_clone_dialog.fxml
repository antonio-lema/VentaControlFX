<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="15" styleClass="modal-container" prefWidth="480" stylesheets="@/styles/variables.css" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.PriceListCloneController">
    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <StackPane styleClass="icon-container-blue" maxWidth="45" maxHeight="45" style="-fx-background-color: rgba(16, 185, 129, 0.1);">
            <FontAwesomeIconView glyphName="COPY" size="18" fill="#10b981"/>
        </StackPane>
        <VBox spacing="2">
            <Label fx:id="lblTitle" text="Clonar Tarifa de Precios" styleClass="modal-title"/>
            <Label text="Crea una copia ajustando porcentajes" styleClass="modal-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleCancel" styleClass="button-ghost" text="&#x2715;" style="-fx-font-size: 16px;"/>
    </HBox>

    <Separator/>

    <VBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox spacing="8">
            <Label text="Nombre de la Nueva Tarifa" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="txtName" promptText="Ej: Tarifa Mayoristas - CLON" styleClass="form-control" />
        </VBox>

        <VBox spacing="8">
            <Label text="Ajuste de Precios (%)" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="txtPercentage" promptText="Ej: 10 para +10%, -5 para -5%" styleClass="form-control" text="0"/>
            <Label text="Se recalcularán los precios de venta de la copia aplicando este porcentaje." wrapText="true" styleClass="text-xs, text-gray-500"/>
        </VBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS" minHeight="15"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="Clonar Tarifa" onAction="#handleConfirm" styleClass="btn-primary">
            <graphic>
                <FontAwesomeIconView glyphName="MAGIC" size="14" fill="white" />
            </graphic>
        </Button>
    </HBox>
</VBox>

