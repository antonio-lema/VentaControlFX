<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:id="root" spacing="15" styleClass="modern-register-card" 
      prefWidth="450" alignment="TOP_CENTER"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.CashOpeningController">
    
    <stylesheets>
        <URL value="@/styles/variables.css" />
        <URL value="@/styles/components/botones.css" />
        <URL value="@/styles/components/formularios.css" />
    </stylesheets>

    <VBox spacing="5" alignment="CENTER" style="-fx-padding: 20 0 5 0;">
        <StackPane styleClass="estetica-card-icon-wrap, estetica-icon-blue" maxWidth="45" maxHeight="45">
            <FontAwesomeIconView glyphName="KEY" size="22" fill="#3b82f6"/>
        </StackPane>
        <Label text="Apertura de Jornada" styleClass="modern-register-title" style="-fx-font-size: 22px;" />
        <Label text="Introduce el fondo de caja para iniciar" styleClass="modern-register-subtitle" />
    </VBox>

    <VBox spacing="12" style="-fx-padding: 0 35 25 35;">
        <!-- Informaci&#x00f3;n informativa -->
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="info-banner" style="-fx-background-color: #f0f7ff; -fx-padding: 10; -fx-background-radius: 8;">
            <FontAwesomeIconView glyphName="INFO_CIRCLE" size="14" fill="#3b82f6" />
            <VBox>
                <Label text="Saldo del &#x00fa;ltimo cierre:" styleClass="label-muted" />
                <Label fx:id="lblLastClosure" text="0,00 &#x20ac;" style="-fx-font-weight: bold; -fx-text-fill: #1e40af;" />
            </VBox>
        </HBox>

        <!-- Input Fondo Inicial -->
        <VBox spacing="6">
            <Label text="Fondo Inicial (&#x20ac;):" styleClass="label" />
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="modern-input-container">
                <FontAwesomeIconView glyphName="MONEY" size="16" fill="#94a3b8" />
                <TextField fx:id="txtInitialAmount" promptText="0,00" HBox.hgrow="ALWAYS" styleClass="modern-input-field" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            </HBox>
        </VBox>

        <!-- Observaciones -->
        <VBox spacing="6">
            <Label text="Notas de Apertura:" styleClass="label" />
            <TextArea fx:id="txtNotes" promptText="Opcional. Ej: Monedas de 1&#x20ac; extra..." prefRowCount="2" wrapText="true" styleClass="text-field" />
        </VBox>

        <!-- Botones de Acci&#x00f3;n -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
            <Button text="CANCELAR" onAction="#handleCancel" styleClass="btn-secondary" prefHeight="40" prefWidth="110" />
            <Button text="ABRIR CAJA" onAction="#handleOpen" styleClass="btn-success" prefHeight="40" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <graphic>
                    <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="16" fill="white" />
                </graphic>
            </Button>
        </HBox>
    </VBox>
</VBox>
