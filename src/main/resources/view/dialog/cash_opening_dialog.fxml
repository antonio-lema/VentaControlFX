<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:id="root" spacing="20" styleClass="modern-register-card" 
      prefWidth="450" alignment="TOP_CENTER"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.CashOpeningController">
    
    <stylesheets>
        <URL value="@/styles/variables.css" />
        <URL value="@/styles/components/botones.css" />
        <URL value="@/styles/components/formularios.css" />
    </stylesheets>

    <VBox spacing="5" alignment="CENTER" style="-fx-padding: 30 0 10 0;">
        <StackPane styleClass="estetica-card-icon-wrap, estetica-icon-blue" maxWidth="50" maxHeight="50">
            <FontAwesomeIconView glyphName="KEY" size="24" fill="#3b82f6"/>
        </StackPane>
        <Label text="Apertura de Jornada" styleClass="modern-register-title" />
        <Label text="Introduce el fondo de caja para iniciar" styleClass="modern-register-subtitle" />
    </VBox>

    <VBox spacing="15" style="-fx-padding: 0 40 30 40;">
        <!-- Información informativa -->
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="info-banner" style="-fx-background-color: #f0f7ff; -fx-padding: 10; -fx-background-radius: 8;">
            <FontAwesomeIconView glyphName="INFO_CIRCLE" size="14" fill="#3b82f6" />
            <VBox>
                <Label text="Saldo del último cierre:" styleClass="label-muted" />
                <Label fx:id="lblLastClosure" text="0,00 €" style="-fx-font-weight: bold; -fx-text-fill: #1e40af;" />
            </VBox>
        </HBox>

        <!-- Input Fondo Inicial -->
        <VBox spacing="8">
            <Label text="Fondo Inicial (€):" styleClass="label" />
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="modern-input-container">
                <FontAwesomeIconView glyphName="MONEY" size="16" fill="#94a3b8" />
                <TextField fx:id="txtInitialAmount" promptText="0,00" HBox.hgrow="ALWAYS" styleClass="modern-input-field" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            </HBox>
        </VBox>

        <!-- Observaciones -->
        <VBox spacing="8">
            <Label text="Notas de Apertura:" styleClass="label" />
            <TextArea fx:id="txtNotes" promptText="Opcional. Ej: Monedas de 1€ extra..." prefRowCount="2" wrapText="true" styleClass="text-field" />
        </VBox>

        <!-- Botones de Acción -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <Button text="CANCELAR" onAction="#handleCancel" styleClass="btn-secondary" prefHeight="45" prefWidth="120" />
            <Button text="ABRIR CAJA" onAction="#handleOpen" styleClass="btn-success" prefHeight="45" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <graphic>
                    <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="16" fill="white" />
                </graphic>
            </Button>
        </HBox>
    </VBox>
</VBox>
