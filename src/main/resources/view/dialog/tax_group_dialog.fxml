<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="15" styleClass="modal-container" prefWidth="500" stylesheets="@/styles/variables.css" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.TaxGroupDialogController">
    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <StackPane styleClass="icon-container-blue" maxWidth="45" maxHeight="45">
            <FontAwesomeIconView glyphName="PERCENT" size="20" fill="#1e88e5"/>
        </StackPane>
        <VBox spacing="2">
            <Label text="Grupo de Impuestos" styleClass="modal-title"/>
            <Label text="Crea o edita agrupaciones de tasas" styleClass="modal-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleCancel" styleClass="button-ghost" text="&#x2715;" style="-fx-font-size: 16px;"/>
    </HBox>

    <Separator/>

    <VBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Nombre Grupo -->
        <VBox spacing="8">
            <Label text="Nombre del Grupo" styleClass="text-sm, font-medium, text-gray-700" />
            <TextField fx:id="txtName" promptText="Ej: IVA General, Exento..." styleClass="form-control" />
        </VBox>

        <!-- Por Defecto -->
        <CheckBox fx:id="chkDefault" text="Establecer como grupo por defecto" styleClass="text-sm, font-medium, text-gray-800" />

        <!-- Lista de Tasas -->
        <VBox spacing="8" VBox.vgrow="ALWAYS">
            <Label text="Tasas impositivas incluidas" styleClass="text-sm, font-medium, text-gray-700" />
            <ScrollPane fitToWidth="true" minHeight="200" maxHeight="300" styleClass="form-control" style="-fx-padding: 0;">
                <VBox fx:id="ratesListContainer" spacing="10" style="-fx-padding: 15; -fx-background-color: transparent;">
                    <!-- Los items de CheckBox se generarán dinámicamente -->
                </VBox>
            </ScrollPane>
        </VBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS" minHeight="10"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#handleCancel" styleClass="btn-secondary"/>
        <Button text="Guardar Cambios" onAction="#handleSave" styleClass="btn-primary">
            <graphic>
                <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="14" fill="white" />
            </graphic>
        </Button>
    </HBox>
</VBox>

