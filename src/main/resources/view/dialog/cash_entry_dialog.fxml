<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:id="root" spacing="15" styleClass="modern-register-card"
      prefWidth="450" alignment="TOP_CENTER"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.CashEntryController">

    <stylesheets>
        <URL value="@/styles/variables.css" />
        <URL value="@/styles/components/botones.css" />
        <URL value="@/styles/components/formularios.css" />
    </stylesheets>

    <VBox spacing="5" alignment="CENTER" style="-fx-padding: 20 0 5 0;">
        <StackPane styleClass="estetica-card-icon-wrap, estetica-icon-blue" maxWidth="45" maxHeight="45">
            <FontAwesomeIconView glyphName="PLUS_CIRCLE" size="22" fill="#3b82f6"/>
        </StackPane>
        <Label text="Ingresar Efectivo" styleClass="modern-register-title" style="-fx-font-size: 22px;" />
        <Label text="Registra una entrada manual en el libro de caja" styleClass="modern-register-subtitle" />
    </VBox>

    <VBox spacing="12" style="-fx-padding: 0 35 25 35;">

        <!-- Saldo actual informativo -->
        <HBox fx:id="bannerCurrentCash" spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color: #f0fdf4; -fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #bbf7d0; -fx-border-radius: 8;">
            <FontAwesomeIconView glyphName="INFO_CIRCLE" size="14" fill="#16a34a" />
            <VBox>
                <Label text="Efectivo actual en caja:" styleClass="label-muted" />
                <Label fx:id="lblCurrentCash" text="0,00 &#x20ac;" style="-fx-font-weight: bold; -fx-text-fill: #15803d;" />
            </VBox>
        </HBox>

        <!-- Importe -->
        <VBox spacing="6">
            <Label text="Importe a Ingresar (&#x20ac;):" styleClass="label" />
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="modern-input-container">
                <FontAwesomeIconView glyphName="MONEY" size="20" fill="#22c55e" />
                <TextField fx:id="txtAmount" promptText="0,00" HBox.hgrow="ALWAYS" styleClass="modern-input-field"
                           style="-fx-font-size: 20px; -fx-font-weight: 900;" />
            </HBox>
        </VBox>

        <!-- Tipo de ingreso -->
        <VBox spacing="6">
            <Label text="Tipo de Ingreso:" styleClass="label" />
            <ComboBox fx:id="comboType" maxWidth="Infinity" styleClass="modern-combo-box" />
        </VBox>

        <!-- Motivo -->
        <VBox spacing="6">
            <Label text="Motivo / Justificaci&#x00f3;n:" styleClass="label" />
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="modern-input-container">
                <FontAwesomeIconView glyphName="PENCIL" size="14" fill="#94a3b8" />
                <TextField fx:id="txtReason" promptText="Escribe la justificaci&#x00f3;n..." HBox.hgrow="ALWAYS" styleClass="modern-input-field" />
            </HBox>
        </VBox>

        <!-- Botones de Acci&#x00f3;n -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 5 0 0 0;">
            <Button text="CANCELAR" onAction="#handleCancel" styleClass="btn-secondary" prefHeight="40" prefWidth="110" />
            <Button text="CONFIRMAR INGRESO" onAction="#handleConfirm" styleClass="btn-primary" prefHeight="40" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <graphic>
                    <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="16" fill="white" />
                </graphic>
            </Button>
        </HBox>
    </VBox>
</VBox>
