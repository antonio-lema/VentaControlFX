<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:id="root" spacing="20" styleClass="modern-register-card" 
      prefWidth="500" alignment="TOP_CENTER"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.CashClosingController">
    
    <stylesheets>
        <URL value="@/styles/variables.css" />
        <URL value="@/styles/components/botones.css" />
        <URL value="@/styles/components/formularios.css" />
    </stylesheets>

    <VBox spacing="5" alignment="CENTER" style="-fx-padding: 30 0 10 0;">
        <StackPane styleClass="estetica-card-icon-wrap, estetica-icon-purple" maxWidth="50" maxHeight="50">
            <FontAwesomeIconView glyphName="CALCULATOR" size="24" fill="#8b5cf6"/>
        </StackPane>
        <Label text="Arqueo y Cierre de Caja" styleClass="modern-register-title" />
        <Label text="Finaliza la jornada comparando el efectivo real" styleClass="modern-register-subtitle" />
    </VBox>

    <VBox spacing="20" style="-fx-padding: 0 40 30 40;">
        
        <!-- Grid de Comparativa -->
        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="100" prefWidth="150" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="100" />
            </columnConstraints>

            <!-- Esperado (Solo Lectura) -->
            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="Efectivo Esperado:" styleClass="label-muted" />
                <Label fx:id="lblExpected" text="0,00 €" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -text-main;" />
            </VBox>

            <!-- Real (Input destacado) -->
            <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Efectivo Real Contado (€):" styleClass="label" />
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="modern-input-container">
                    <FontAwesomeIconView glyphName="MONEY" size="20" fill="#22c55e" />
                    <TextField fx:id="txtActualAmount" promptText="0,00" HBox.hgrow="ALWAYS" styleClass="modern-input-field" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: -fx-text-custom-main;" />
                </HBox>
            </VBox>

            <!-- Diferencia -->
            <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2" 
                  alignment="CENTER" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 12;">
                <Label text="Descuadre / Diferencia" styleClass="label-muted" />
                <Label fx:id="lblDifference" text="0,00 €" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: #10b981;" />
                <Label fx:id="lblDiffReason" text="✅ Caja cuadrada perfectamente" styleClass="trend-text" style="-fx-text-fill: #16a34a; -fx-font-weight: bold;" />
            </VBox>
        </GridPane>

        <!-- Observaciones / Notas -->
        <VBox spacing="8">
            <Label text="Observaciones / Justificación:" styleClass="label" />
            <TextArea fx:id="txtNotes" promptText="Motivo del descuadre, incidencias..." prefRowCount="3" wrapText="true" styleClass="text-field" />
        </VBox>

        <!-- Botones de Acción -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <Button text="CANCELAR" onAction="#handleCancel" styleClass="btn-secondary" prefHeight="50" prefWidth="140" />
            <Button text="CONFIRMAR CIERRE" onAction="#handleClose" styleClass="btn-primary" prefHeight="50" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <graphic>
                    <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="18" fill="white" />
                </graphic>
            </Button>
        </HBox>
    </VBox>
</VBox>
