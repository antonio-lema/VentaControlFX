<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="15" styleClass="modal-container" prefWidth="480" stylesheets="@/styles/variables.css" 
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.EditClosureDialogController">
    <padding>
        <Insets top="24" right="32" bottom="24" left="32"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <StackPane styleClass="icon-container-blue" maxWidth="45" maxHeight="45">
            <FontAwesomeIconView glyphName="PENCIL_SQUARE" size="20" fill="#3b82f6"/>
        </StackPane>
        <VBox spacing="2">
            <Label text="Modificar Arqueo" styleClass="modal-title" />
            <Label text="Ajusta el total contado y registra el motivo" styleClass="modal-subtitle" />
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleCancel" styleClass="button-ghost" text="&#x2715;" style="-fx-font-size: 16px;"/>
    </HBox>

    <Separator/>

    <VBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Info Anterior -->
        <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-background-color: #f0f9ff; -fx-padding: 12; -fx-background-radius: 12; -fx-border-color: #bae6fd; -fx-border-width: 1;">
            <FontAwesomeIconView glyphName="INFO_CIRCLE" size="16" fill="#0284c7" />
            <VBox spacing="2">
                <Label text="Efectivo contado anterior" styleClass="text-xs, text-gray-500" />
                <Label fx:id="lblPreviousCash" text="0,00 &#x20ac;" style="-fx-font-weight: 800; -fx-text-fill: #0369a1; -fx-font-size: 15px;" />
            </VBox>
        </HBox>

        <!-- Importe Nuevo -->
        <VBox spacing="8">
            <Label text="Nuevo Total Contado (&#x20ac;)" styleClass="text-sm, font-medium, text-gray-700" />
            <TextField fx:id="txtAmount" promptText="0,00" styleClass="form-control" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        </VBox>

        <!-- Motivo -->
        <VBox spacing="8">
            <Label text="Motivo de la Modificación" styleClass="text-sm, font-medium, text-gray-700" />
            <TextField fx:id="txtReason" promptText="Ej: Error de digitación, billete traspapelado..." styleClass="form-control" />
        </VBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS" minHeight="10"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#handleCancel" styleClass="btn-secondary" />
        <Button fx:id="btnConfirm" text="Modificar Arqueo" onAction="#handleConfirm" styleClass="btn-primary">
            <graphic>
                <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="14" fill="white" />
            </graphic>
        </Button>
    </HBox>
</VBox>

