<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.ImageView?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.HeaderController"
      spacing="0" alignment="CENTER_LEFT" styleClass="top-bar">

    <!-- ====== LOGO / MARCA ====== -->
    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="logo-container">
        <StackPane styleClass="top-bar-action-btn">
            <ImageView fx:id="imgLogo" fitHeight="28" preserveRatio="true" managed="false" visible="false"/>
            <FontAwesomeIconView glyphName="SHOPPING_BAG" size="20" fill="#1e88e5" />
        </StackPane>
        <HBox spacing="4" alignment="CENTER_LEFT">
            <Label fx:id="lblAppPrefix" text="Venta" styleClass="logo-text"/>
            <Label fx:id="lblAppName"   text="Control" styleClass="brand-text"/>
        </HBox>
    </HBox>

    <!-- Separador flexible izquierdo -->
    <Region HBox.hgrow="ALWAYS"/>

    <!-- ====== BARRA DE BÚSQUEDA ====== -->
    <HBox fx:id="searchBarContainer" alignment="CENTER_LEFT" spacing="10" styleClass="search-bar">
        <FontAwesomeIconView glyphName="SEARCH" size="16" fill="#adb5bd"/>
        <TextField fx:id="searchField"
                   promptText="Buscar productos, clientes o códigos..."
                   styleClass="search-field"
                   HBox.hgrow="ALWAYS"/>
        <StackPane styleClass="search-shortcut">
            <Label text="⌘K" styleClass="search-shortcut"/>
        </StackPane>
    </HBox>

    <!-- Separador flexible derecho -->
    <Region HBox.hgrow="ALWAYS"/>

    <!-- ====== ZONA DERECHA: NOTIFICACIÓN + USUARIO ====== -->
    <HBox spacing="12" alignment="CENTER_LEFT">

        <!-- Menú de usuario -->
        <MenuButton fx:id="userMenuButton" styleClass="user-menu-button">
            <graphic>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <VBox alignment="CENTER_RIGHT" spacing="1">
                        <Label fx:id="lblHeaderUsername" text="Administrador" styleClass="label"/>
                        <Label text="En línea" styleClass="label-muted user-status-online"/>
                    </VBox>
                    <StackPane>
                        <Circle radius="18" styleClass="user-avatar-circle"/>
                        <FontAwesomeIconView glyphName="USER" size="14" fill="white"/>
                    </StackPane>
                </HBox>
            </graphic>
            <items>
                <MenuItem text="Cerrar caja" onAction="#handleCashClosure">
                    <graphic><FontAwesomeIconView glyphName="MONEY" size="14"/></graphic>
                </MenuItem>
                <SeparatorMenuItem />
                <MenuItem fx:id="menuItemLogout" text="Cerrar sesión" onAction="#handleLogout">
                    <graphic><FontAwesomeIconView glyphName="SIGN_OUT" size="14" fill="#e53935"/></graphic>
                </MenuItem>
            </items>
        </MenuButton>

    </HBox>
</HBox>
