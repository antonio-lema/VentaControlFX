<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="20" styleClass="main-content-area" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ManageUsersController">
    <padding>
        <Insets top="30" right="30" bottom="20" left="30"/>
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="15.0">
       <children>
          <VBox spacing="5">
             <children>
                <Label text="Gestión de Usuarios" styleClass="section-title" />
                <Label text="Administra los accesos y roles del sistema" styleClass="section-subtitle" />
             </children>
          </VBox>
          <Region HBox.hgrow="ALWAYS" />
          <Button onAction="#handleNewUser" styleClass="btn-primary">
             <graphic><FontAwesomeIconView glyphName="PLUS" size="14" fill="white" /></graphic>
             <text> Nuevo Usuario</text>
          </Button>
       </children>
    </HBox>

    <!-- Filter Section -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="modern-filter-bar">
        <children>
            <HBox alignment="CENTER_LEFT" styleClass="search-bar" maxWidth="500" HBox.hgrow="ALWAYS">
                <children>
                    <FontAwesomeIconView glyphName="SEARCH" size="16" fill="#adb5bd" />
                    <TextField fx:id="txtSearch" promptText="Nombre, usuario o email..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                </children>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
        </children>
    </HBox>

    <!-- Cards Section -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS" hbarPolicy="NEVER">
        <content>
            <FlowPane fx:id="userCardsPane" hgap="25" vgap="25">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <!-- Cards will be populated here -->
            </FlowPane>
        </content>
    </ScrollPane>
    
    <!-- Count Section -->
    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10;">
        <children>
            <Label fx:id="lblCount" text="0 usuarios encontrados" styleClass="label-muted" style="-fx-font-weight: bold;"/>
        </children>
    </HBox>

</VBox>
