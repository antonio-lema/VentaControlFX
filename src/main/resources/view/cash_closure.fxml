<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import de.jensd.fx.glyphs.fontawesome.*?>

<VBox prefWidth="950" prefHeight="700" spacing="0" style="-fx-background-color: #f4f7fa;" 
      stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.controller.CashClosureController">
    <!-- Header Area -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
        <VBox style="-fx-background-color: #e3f2fd; -fx-background-radius: 12; -fx-padding: 10;">
            <FontAwesomeIconView glyphName="CALCULATOR" size="24" fill="#1e88e5"/>
        </VBox>
        <VBox spacing="2">
            <Label text="Resumen de Turno" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label fx:id="lblDate" text="20 Feb, 2026" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;"/>
                <Label text="•" style="-fx-text-fill: #bdc3c7;"/>
                <Label fx:id="lblCurrentUser" text="Admin" style="-fx-text-fill: #1a73e8; -fx-font-weight: bold; -fx-font-size: 14px;"/>
            </HBox>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleClose" style="-fx-background-color: #f5f6f7; -fx-background-radius: 30; -fx-padding: 8; -fx-cursor: hand;">
            <graphic>
                <FontAwesomeIconView glyphName="CLOSE" size="18" fill="#95a5a6"/>
            </graphic>
        </Button>
    </HBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS" style="-fx-padding: 25;">
        <!-- Left Column: Details and Totals -->
        <VBox spacing="20" prefWidth="350">
            <!-- Totals Section -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 22; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 15, 0, 0, 5);">
                <Label text="CONTABILIDAD" style="-fx-font-weight: bold; -fx-text-fill: #95a5a6; -fx-font-size: 12px;"/>
                
                <VBox spacing="5" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 12; -fx-border-color: #edf2f7; -fx-border-width: 1; -fx-border-radius: 12;">
                    <Label text="Efectivo" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    <Label fx:id="lblTotalCash" text="0,00 €" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>

                <VBox spacing="5" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 12; -fx-border-color: #edf2f7; -fx-border-width: 1; -fx-border-radius: 12;">
                    <Label text="Tarjeta" style="-fx-text-fill: #64748b; -fx-font-size: 13px;"/>
                    <Label fx:id="lblTotalCard" text="0,00 €" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                </VBox>

                <VBox spacing="5" style="-fx-background-color: #1a73e8; -fx-padding: 20; -fx-background-radius: 12;">
                    <Label text="Total a Cerrar" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 13px;"/>
                    <Label fx:id="lblTotalAll" text="0,00 €" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                </VBox>
            </VBox>

            <!-- Stats Section -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 18; -fx-padding: 22; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 15, 0, 0, 5);">
                <Label text="ESTADÍSTICAS" style="-fx-font-weight: bold; -fx-text-fill: #95a5a6; -fx-font-size: 12px;"/>
                <GridPane vgap="14" hgap="10">
                    <Label text="Transacciones:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="lblSalesCount" text="0" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50; -fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="Estado:" style="-fx-text-fill: #7f8c8d; -fx-font-size: 14px;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lblStatus" text="Pendiente" style="-fx-font-weight: bold; -fx-text-fill: #f39c12; -fx-font-size: 14px;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Action Button -->
            <Button fx:id="btnPerformClosure" onAction="#handlePerformClosure" maxWidth="Infinity" text="REALIZAR CIERRE DE CAJA"
                    style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 18; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(26,115,232,0.3), 10, 0, 0, 5);"/>
        </VBox>

        <!-- Right Column: Product Breakdown -->
        <VBox spacing="15" HBox.hgrow="ALWAYS" styleClass="table-card" style="-fx-padding: 25;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <FontAwesomeIconView glyphName="LIST" size="18" fill="#1a73e8"/>
                <Label text="Desglose de Ventas por Producto" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            </HBox>
            
            <TableView fx:id="tableProductSummary" VBox.vgrow="ALWAYS" styleClass="modern-table-view">
                <columns>
                    <TableColumn fx:id="colProdName" text="PRODUCTO" prefWidth="350" />
                    <TableColumn fx:id="colProdQty" text="CANT." prefWidth="100" style="-fx-alignment: CENTER-RIGHT;" />
                    <TableColumn fx:id="colProdTotal" text="VENTA TOTAL" prefWidth="150" style="-fx-alignment: CENTER-RIGHT;" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
            
            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                <Label text="Ventas pendientes de vincular al cierre" style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
