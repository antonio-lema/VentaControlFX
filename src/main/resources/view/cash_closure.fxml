<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import de.jensd.fx.glyphs.fontawesome.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.controller.CashClosureController"
      spacing="20" style="-fx-background-color: #f8f9fa; -fx-padding: 30;">
    
    <HBox alignment="CENTER_LEFT" spacing="15">
        <FontAwesomeIconView glyphName="CALCULATOR" size="30" fill="#1a73e8"/>
        <VBox>
            <Label text="Cierre de Caja" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #202124;"/>
            <Label fx:id="lblDate" text="18 Feb, 2026" style="-fx-font-size: 14px; -fx-text-fill: #5f6368;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-cursor: hand;">
            <graphic>
                <FontAwesomeIconView glyphName="CLOSE" size="20" fill="#5f6368"/>
            </graphic>
        </Button>
    </HBox>

    <Separator/>

    <HBox spacing="20" alignment="CENTER">
        <!-- Cash Card -->
        <VBox spacing="10" alignment="CENTER" HBox.hgrow="ALWAYS" 
              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <FontAwesomeIconView glyphName="MONEY" size="40" fill="#34a853"/>
            <Label text="Efectivo" style="-fx-font-size: 16px; -fx-text-fill: #5f6368;"/>
            <Label fx:id="lblTotalCash" text="0,00 €" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #202124;"/>
        </VBox>

        <!-- Card Card -->
        <VBox spacing="10" alignment="CENTER" HBox.hgrow="ALWAYS" 
              style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <FontAwesomeIconView glyphName="CREDIT_CARD" size="40" fill="#4285f4"/>
            <Label text="Tarjeta" style="-fx-font-size: 16px; -fx-text-fill: #5f6368;"/>
            <Label fx:id="lblTotalCard" text="0,00 €" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #202124;"/>
        </VBox>

        <!-- Total Card -->
        <VBox spacing="10" alignment="CENTER" HBox.hgrow="ALWAYS" 
              style="-fx-background-color: #1a73e8; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(26,115,232,0.3), 10, 0, 0, 5);">
            <FontAwesomeIconView glyphName="BAR_CHART" size="40" fill="white"/>
            <Label text="Total del Día" style="-fx-font-size: 16px; -fx-text-fill: #e8f0fe;"/>
            <Label fx:id="lblTotalAll" text="0,00 €" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
    </HBox>

    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: #e8eaed; -fx-border-radius: 15;">
        <Label text="Estadísticas de Hoy" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #202124;"/>
        
        <GridPane hgap="40" vgap="10">
            <Label text="Nº de Ventas:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #5f6368;"/>
            <Label fx:id="lblSalesCount" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
            
            <Label text="Usuario Actual:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-text-fill: #5f6368;"/>
            <Label fx:id="lblCurrentUser" text="Admin" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
            
            <Label text="Estado Cierre:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-text-fill: #5f6368;"/>
            <Label fx:id="lblStatus" text="Pendiente" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #f29900;"/>
        </GridPane>
    </VBox>

    <HBox alignment="CENTER" VBox.vgrow="ALWAYS">
        <Button fx:id="btnPerformClosure" text="REALIZAR CIERRE DE CAJA" onAction="#handlePerformClosure"
                style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-padding: 15 40; -fx-background-radius: 30; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);"/>
    </HBox>

</VBox>
