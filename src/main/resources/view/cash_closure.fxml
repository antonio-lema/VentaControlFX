<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import de.jensd.fx.glyphs.fontawesome.*?>

<VBox prefWidth="950" prefHeight="700" spacing="0" styleClass="main-content-area"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.CashClosureController">

    <!-- Header Area -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="detail-panel-header">
        <StackPane styleClass="stat-icon-bg stat-icon-bg-blue">
            <FontAwesomeIconView glyphName="CALCULATOR" size="22" fill="white"/>
        </StackPane>
        <VBox spacing="2">
            <Label text="📊 Resumen de Turno" styleClass="section-title"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label fx:id="lblDate" text="20 Feb, 2026" styleClass="label-muted"/>
                <Label text="•" styleClass="label-muted"/>
                <Label fx:id="lblCurrentUser" text="Admin" styleClass="closure-user-label"/>
            </HBox>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleClose" styleClass="btn-icon" cancelButton="true">
            <graphic>
                <FontAwesomeIconView glyphName="CLOSE" size="18" styleClass="sidebar-icon"/>
            </graphic>
        </Button>
    </HBox>

    <HBox spacing="25" VBox.vgrow="ALWAYS" style="-fx-padding: 25;">
        <!-- Left Column: Details and Totals -->
        <VBox spacing="20" prefWidth="350">
            <!-- Totals Section -->
            <VBox spacing="15" styleClass="stat-card">
                <Label text="CONTABILIDAD" styleClass="filter-label-cap"/>

                <VBox spacing="5" styleClass="closure-amount-row">
                    <Label text="💵 Efectivo" styleClass="label-muted"/>
                    <Label fx:id="lblTotalCash" text="0,00 €" styleClass="closure-amount-cash"/>
                </VBox>

                <VBox spacing="5" styleClass="closure-amount-row">
                    <Label text="💳 Tarjeta" styleClass="label-muted"/>
                    <Label fx:id="lblTotalCard" text="0,00 €" styleClass="closure-amount-card"/>
                </VBox>

                <!-- Highlighted total -->
                <VBox spacing="5" styleClass="closure-total-highlight">
                    <Label text="💰 Total a Cerrar" styleClass="stat-label-light"/>
                    <Label fx:id="lblTotalAll" text="0,00 €" styleClass="closure-grand-total"/>
                </VBox>
            </VBox>

            <!-- Stats Section -->
            <VBox spacing="15" styleClass="stat-card">
                <Label text="ESTADÍSTICAS" styleClass="filter-label-cap"/>
                <GridPane vgap="14" hgap="10">
                    <Label text="Transacciones:" styleClass="label-muted"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="lblSalesCount" text="0" styleClass="closure-stat-value"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Estado:" styleClass="label-muted"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="lblStatus" text="Pendiente" styleClass="closure-status-pending"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Action Button -->
            <Button fx:id="btnPerformClosure" onAction="#handlePerformClosure"
                    maxWidth="Infinity" text="REALIZAR CIERRE DE CAJA"
                    styleClass="btn-primary btn-lg" defaultButton="true"/>
        </VBox>

        <!-- Right Column: Product Breakdown -->
        <VBox spacing="15" HBox.hgrow="ALWAYS" styleClass="table-card" style="-fx-padding: 25;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane styleClass="stat-icon-bg stat-icon-bg-blue">
                    <FontAwesomeIconView glyphName="LIST" size="16" fill="white"/>
                </StackPane>
                <Label text="Desglose de Ventas por Producto" styleClass="section-title" style="-fx-font-size: 18px;"/>
            </HBox>

            <TableView fx:id="tableProductSummary" VBox.vgrow="ALWAYS" styleClass="modern-table-view">
                <columns>
                    <TableColumn fx:id="colProdName" text="PRODUCTO" prefWidth="350" />
                    <TableColumn fx:id="colProdQty" text="CANT." prefWidth="100" />
                    <TableColumn fx:id="colProdTotal" text="VENTA TOTAL" prefWidth="150" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_RIGHT">
                <Label text="Ventas pendientes de vincular al cierre" styleClass="label-muted" style="-fx-font-size: 11px;"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
