<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="500.0" style="-fx-background-color: white;" stylesheets="@../styles/main.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.MassivePriceUpdateController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label styleClass="text-h2" text="Actualización Masiva de Precios" />
            <Label style="-fx-text-fill: #7f8c8d;" text="Aplica incrementos o descuentos a todo el inventario o a una categoría en específico." wrapText="true" />
            <VBox spacing="10.0">
               <children>
                  <Label styleClass="label-bold" text="Filtro de Categoría" />
                  <ComboBox fx:id="cmbCategory" maxWidth="1.7976931348623157E308" promptText="Todas las categorías (Inventario completo)" styleClass="modern-combo-box" />
               </children>
            </VBox>
            <VBox spacing="10.0">
               <children>
                  <Label styleClass="label-bold" text="Porcentaje a Aplicar (%)" />
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <TextField fx:id="txtPercentage" prefWidth="100.0" promptText="Ej: 10 o -5" styleClass="modern-text-field" />
                        <Label style="-fx-text-fill: #7f8c8d;" text="\% (Valores positivos suben el precio, negativos lo bajan)" wrapText="true" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <VBox spacing="10.0">
               <children>
                  <Label styleClass="label-bold" text="Motivo del cambio (Registro)" />
                  <TextField fx:id="txtReason" promptText="Ej: Inflación, Promoción Fin de Mes..." styleClass="modern-text-field" />
               </children>
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button cancelButton="true" mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-secondary" text="Cancelar" />
                  <Button fx:id="btnApply" defaultButton="true" mnemonicParsing="false" onAction="#handleApply" style="-fx-base: #f39c12; -fx-text-fill: white;" styleClass="btn-primary" text="Aplicar Cambios" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
