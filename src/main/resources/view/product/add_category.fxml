<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ComboBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<StackPane fx:id="rootStackPane" styleClass="register-popup-background" onMousePressed="#handleMousePressed" onMouseDragged="#handleMouseDragged" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.product.AddCategoryController">
    <VBox maxWidth="450" spacing="0" alignment="CENTER" styleClass="modern-register-card">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        <!-- Header -->
        <VBox styleClass="modern-register-header" alignment="CENTER_LEFT">
            <Label fx:id="lblTitle" text="%category.form.title" styleClass="modern-register-title"/>
            <Label fx:id="lblSubtitle" text="%category.form.subtitle" styleClass="modern-register-subtitle" style="-fx-text-fill: #64748b;"/>
        </VBox>
        
        <VBox spacing="15">
            <!-- Name -->
            <VBox styleClass="modern-input-group">
                <Label text="%category.form.name" styleClass="modern-label" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;"/>
                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                    <FontAwesomeIconView glyphName="FOLDER" size="18" fill="#64748b">
                        <HBox.margin>
                            <Insets right="10"/>
                        </HBox.margin>
                    </FontAwesomeIconView> 
                    <TextField fx:id="txtName" promptText="%category.form.name.prompt" styleClass="modern-input-field" HBox.hgrow="ALWAYS" style="-fx-text-fill: #1e293b;"/>
                </HBox>
            </VBox>

            <!-- Default Tax Group (V2) -->
            <VBox styleClass="modern-input-group">
                <Label text="%category.form.tax_group" styleClass="modern-label" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;"/>
                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                    <FontAwesomeIconView glyphName="BALANCE_SCALE" size="18" fill="#64748b">
                        <HBox.margin>
                            <Insets right="10"/>
                        </HBox.margin>
                    </FontAwesomeIconView> 
                    <ComboBox fx:id="cmbTaxGroup" promptText="%category.form.tax_group.prompt" styleClass="modern-input-field" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" style="-fx-background-color: transparent; -fx-text-fill: #1e293b;"/>
                </HBox>
            </VBox>

            <!-- Default IVA -->
            <VBox styleClass="modern-input-group">
                <Label text="%category.form.iva" styleClass="modern-label" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;"/>
                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                    <FontAwesomeIconView glyphName="PERCENT" size="18" fill="#64748b">
                        <HBox.margin>
                            <Insets right="10"/>
                        </HBox.margin>
                    </FontAwesomeIconView> 
                    <TextField fx:id="txtIva" promptText="%category.form.iva.prompt" styleClass="modern-input-field" HBox.hgrow="ALWAYS" style="-fx-text-fill: #1e293b;"/>
                </HBox>
            </VBox>
        </VBox>
        
        <!-- Actions -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 30 0 0 0;">
            <Button text="%btn.cancel" onAction="#handleCancel" styleClass="modern-btn-secondary" cancelButton="true"/>
            <Button text="%category.form.btn_save" onAction="#handleSave" styleClass="modern-btn-primary" defaultButton="true"/>
        </HBox>
    </VBox>
</StackPane>
