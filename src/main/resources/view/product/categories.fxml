<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.layout.StackPane?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" styleClass="main-content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.product.CategoryController">
   <children>
      <VBox spacing="0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- Header Section -->
            <VBox styleClass="view-header" spacing="0">
                <children>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <children>
                            <StackPane styleClass="view-header-icon-wrap">
                                <children><FontAwesomeIconView glyphName="TAG" size="22" fill="white"/></children>
                            </StackPane>
                            <VBox spacing="2">
                                <children>
                                    <Label text="%categories.title" styleClass="view-title"/>
                                    <Label text="%categories.subtitle" styleClass="view-subtitle"/>
                                </children>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                <children>
                                    <Button fx:id="btnAdd" onAction="#handleAddCategory" styleClass="btn-primary" text="%categories.btn.new">
                                        <graphic><FontAwesomeIconView glyphName="PLUS" size="14" fill="WHITE"/></graphic>
                                    </Button>
                                </children>
                            </HBox>
                        </children>
                    </HBox>
                </children>
            </VBox>
            
            <VBox spacing="20.0" VBox.vgrow="ALWAYS" style="-fx-padding: 25;">
                <children>

            <!-- Table Card -->
            <VBox spacing="0" styleClass="table-card" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Filter Section -->
                  <HBox alignment="CENTER_LEFT" styleClass="modern-filter-bar">
                     <children>
                        <Label text="%categories.filter.label" styleClass="label-muted" />
                        <HBox alignment="CENTER_LEFT" styleClass="search-bar" HBox.hgrow="ALWAYS" maxWidth="400">
                           <children>
                              <FontAwesomeIconView glyphName="SEARCH" size="14" styleClass="sidebar-icon" />
                              <TextField fx:id="searchField" promptText="%categories.filter.prompt" styleClass="search-field" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                           <children>
                              <Label text="%categories.show_label" textFill="#7f8c8d" />
                              <TextField fx:id="rowsPerPageField" prefWidth="45.0" text="10" styleClass="row-count-field" />
                              <Label text="%categories.rows_label" textFill="#7f8c8d" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>

                  <!-- Table View -->
                  <TableView fx:id="categoriesTable" styleClass="modern-table-view" VBox.vgrow="ALWAYS">
                    <columns>
                       <TableColumn fx:id="colName" prefWidth="300.0" text="%categories.table.name" />
                       <TableColumn fx:id="colTaxGroup" prefWidth="150.0" text="%categories.table.tax_group" />
                <TableColumn fx:id="colIva" prefWidth="80.0" text="%categories.table.iva" />
                       <TableColumn fx:id="colVisible" prefWidth="100.0" text="%categories.table.status" />
                       <TableColumn fx:id="colFavorite" prefWidth="100.0" text="%categories.table.favorite" />
                       <TableColumn fx:id="colActions" prefWidth="180.0" text="%categories.table.actions" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <!-- Count Section -->
                  <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10;">
                      <children>
                          <Label fx:id="lblCount" text="%categories.found_count" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold;"/>
                      </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
