<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<StackPane fx:id="rootStackPane" styleClass="register-popup-background" onMousePressed="#handleMousePressed" onMouseDragged="#handleMouseDragged" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.AddCategoryController">
    <VBox maxWidth="450" spacing="0" alignment="CENTER" styleClass="modern-register-card">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        <!-- Header -->
        <VBox styleClass="modern-register-header" alignment="CENTER_LEFT">
            <Label fx:id="lblTitle" text="Nueva Categoría" styleClass="modern-register-title"/>
            <Label fx:id="lblSubtitle" text="Introduce el nombre de la categoría" styleClass="modern-register-subtitle"/>
        </VBox>
        
        <VBox spacing="15">
            <!-- Name -->
            <VBox styleClass="modern-input-group">
                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                    <FontAwesomeIconView glyphName="FOLDER" size="18" styleClass="sidebar-icon">
                        <HBox.margin>
                            <Insets right="10"/>
                        </HBox.margin>
                    </FontAwesomeIconView> 
                    <TextField fx:id="txtName" promptText="Nombre de la categoría" styleClass="modern-input-field" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>

            <!-- Default Tax Group (V2) -->
            <VBox styleClass="modern-input-group">
                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                    <FontAwesomeIconView glyphName="BALANCE_SCALE" size="18" styleClass="sidebar-icon">
                        <HBox.margin>
                            <Insets right="10"/>
                        </HBox.margin>
                    </FontAwesomeIconView> 
                    <ComboBox fx:id="cmbTaxGroup" promptText="Grupo de Impuestos (V2)" styleClass="modern-combo-box" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
            </VBox>

            <!-- Default IVA -->
            <VBox styleClass="modern-input-group">
                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                    <FontAwesomeIconView glyphName="PERCENT" size="18" styleClass="sidebar-icon">
                        <HBox.margin>
                            <Insets right="10"/>
                        </HBox.margin>
                    </FontAwesomeIconView> 
                    <TextField fx:id="txtIva" promptText="IVA por defecto (%)" styleClass="modern-input-field" HBox.hgrow="ALWAYS" text="21.0"/>
                </HBox>
            </VBox>
        </VBox>
        
        <!-- Actions -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 30 0 0 0;">
            <Button text="Cancelar" onAction="#handleCancel" styleClass="modern-btn-secondary" cancelButton="true"/>
            <Button text="Guardar" onAction="#handleSave" styleClass="modern-btn-primary" defaultButton="true"/>
        </HBox>
    </VBox>
</StackPane>
