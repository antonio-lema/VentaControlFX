<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.SidebarController"
      spacing="2" styleClass="sidebar">
    <padding>
        <Insets top="24" right="10" bottom="20" left="10"/>
    </padding>

    <!-- ─── BRANDING SECCIÓN — Dinámico desde configuración ─── -->
    <VBox alignment="CENTER" spacing="8" styleClass="sidebar-branding">
        <padding>
            <Insets bottom="24" />
        </padding>
        <!-- Logo de empresa (se muestra si hay imagen configurada) -->
        <StackPane fx:id="brandIconWrap" styleClass="brand-icon-wrap" alignment="CENTER">
            <!-- Icono de fallback, visible cuando no hay logo configurado -->
            <FontAwesomeIconView fx:id="brandFallbackIcon" glyphName="SHOPPING_CART" size="26" styleClass="brand-fallback-icon"/>
            <!-- Logo real, visible cuando hay imagen -->
            <ImageView fx:id="brandLogoImage" fitWidth="40" fitHeight="40" preserveRatio="true" visible="false" managed="false"/>
        </StackPane>
        <!-- Nombre de la aplicación de la configuración -->
        <Label fx:id="lblAppName" styleClass="brand-name" alignment="CENTER" maxWidth="Infinity"/>
    </VBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="sidebar-scroll-pane">
        <VBox spacing="4" style="-fx-background-color: transparent;" alignment="TOP_CENTER">
            
            <Button fx:id="btnSell" styleClass="sidebar-button" onAction="#showSellView" contentDisplay="TOP" maxWidth="Infinity" text="Vender">
                <graphic>
                    <FontAwesomeIconView glyphName="SHOPPING_CART" size="22" styleClass="sidebar-icon"/>
                </graphic>
            </Button>

            <Button fx:id="btnHistory" styleClass="sidebar-button" onAction="#showHistoryView" contentDisplay="TOP" maxWidth="Infinity" text="Historial">
                <graphic>
                    <FontAwesomeIconView glyphName="HISTORY" size="22" styleClass="sidebar-icon"/>
                </graphic>
            </Button>

            <Button fx:id="btnReturns" styleClass="sidebar-button" onAction="#handleShowReturns" contentDisplay="TOP" maxWidth="Infinity" text="Devoluciones">
                <graphic>
                    <FontAwesomeIconView glyphName="REPLY" size="22" styleClass="sidebar-icon"/>
                </graphic>
            </Button>

            <Button fx:id="btnProducts" styleClass="sidebar-button" onAction="#showProductsView" contentDisplay="TOP" maxWidth="Infinity" text="Productos">
                <graphic>
                    <FontAwesomeIconView glyphName="TAGS" size="22" styleClass="sidebar-icon"/>
                </graphic>
            </Button>

            <Button fx:id="btnClients" styleClass="sidebar-button" onAction="#handleShowClients" contentDisplay="TOP" maxWidth="Infinity" text="Directorio">
                <graphic>
                    <FontAwesomeIconView glyphName="ADDRESS_BOOK" size="22" styleClass="sidebar-icon"/>
                </graphic>
            </Button>

            <Button fx:id="btnReports" styleClass="sidebar-button" onAction="#handleShowReports" contentDisplay="TOP" maxWidth="Infinity" text="Informes">
                <graphic>
                    <FontAwesomeIconView glyphName="BAR_CHART" size="22" styleClass="sidebar-icon"/>
                </graphic>
            </Button>

            <Button fx:id="btnClosures" styleClass="sidebar-button" onAction="#handleShowClosures" contentDisplay="TOP" maxWidth="Infinity" text="Arqueos">
                <graphic>
                    <FontAwesomeIconView glyphName="CALCULATOR" size="22" styleClass="sidebar-icon"/>
                </graphic>
            </Button>

            <Button fx:id="btnBilling" styleClass="sidebar-button" onAction="#handleShowBilling" contentDisplay="TOP" maxWidth="Infinity" text="Facturación">
                <graphic>
                    <FontAwesomeIconView glyphName="FILE_TEXT_ALT" size="22" styleClass="sidebar-icon"/>
                </graphic>
            </Button>

            <Button fx:id="btnConfig" styleClass="sidebar-button" onAction="#handleShowConfig" contentDisplay="TOP" maxWidth="Infinity" text="Configuración">
                <graphic>
                    <FontAwesomeIconView glyphName="COG" size="22" styleClass="sidebar-icon"/>
                </graphic>
            </Button>

            <Button fx:id="btnThemeSettings" styleClass="sidebar-button" contentDisplay="TOP" maxWidth="Infinity" onAction="#handleShowCustomization" text="Estética">
                <graphic>
                    <FontAwesomeIconView glyphName="PAINT_BRUSH" size="22" styleClass="sidebar-icon"/>
                </graphic>
            </Button>

            <Region VBox.vgrow="ALWAYS" />
            
            <Separator styleClass="sidebar-divider">
                <VBox.margin>
                    <Insets top="10" bottom="10" />
                </VBox.margin>
            </Separator>
        </VBox>
    </ScrollPane>

    <Button fx:id="btnLock" styleClass="sidebar-button" contentDisplay="TOP" maxWidth="Infinity" onAction="#handleLockApp" text="Cerrar">
        <graphic>
            <FontAwesomeIconView glyphName="LOCK" size="22" styleClass="sidebar-icon"/>
        </graphic>
    </Button>


</VBox>
