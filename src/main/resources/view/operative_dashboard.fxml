<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import java.net.URL?>

<VBox spacing="0" styleClass="dashboard-container" xmlns="http://javafx.com/javafx/21" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.OperativeDashboardController">
    
    <!-- ─── HEADER ─── -->
    <HBox alignment="CENTER_LEFT" spacing="20" styleClass="dashboard-header">
        <padding><Insets top="25" right="30" bottom="25" left="30"/></padding>
        <children>
            <StackPane styleClass="header-icon-container">
                <children>
                    <Circle radius="22" fill="#3b82f615" />
                    <FontAwesomeIconView glyphName="DASHBOARD" size="24" fill="#3b82f6" />
                </children>
            </StackPane>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="MONITOR OPERATIVO REAL-TIME" styleClass="header-title" />
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <children>
                            <Label text="Supervisión en vivo de personal, cajas y cumplimiento horario" styleClass="header-subtitle" />
                            <Separator orientation="VERTICAL" prefHeight="12" />
                            <Label fx:id="lblServerTime" text="13:30:00" styleClass="header-clock" />
                        </children>
                    </HBox>
                </children>
            </VBox>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <children>
                    <Button onAction="#refreshData" styleClass="btn-icon-refresh">
                        <graphic><FontAwesomeIconView glyphName="REFRESH" size="16" /></graphic>
                    </Button>
                    <Label fx:id="lblBusinessStatus" text="CARGANDO..." styleClass="status-badge" />
                </children>
            </HBox>
        </children>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS" styleClass="dashboard-scroll">
        <content>
            <VBox spacing="30" style="-fx-padding: 30;">
                <children>
                    
                    <!-- ─── KPI CARDS ROW ─── -->
                    <HBox spacing="25" alignment="CENTER">
                        <children>
                            <!-- Card: Personal -->
                            <VBox styleClass="kpi-card, kpi-blue" HBox.hgrow="ALWAYS">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <StackPane styleClass="kpi-icon-wrap"><FontAwesomeIconView glyphName="USERS" size="18" /></StackPane>
                                        <Label text="PERSONAL ACTIVO" styleClass="kpi-label" />
                                    </HBox>
                                    <Label fx:id="lblActiveStaffCount" text="0" styleClass="kpi-value" />
                                    <Label text="Empleados con jornada iniciada" styleClass="kpi-hint" />
                                </children>
                            </VBox>
                            
                            <!-- Card: Caja Actual -->
                            <VBox styleClass="kpi-card, kpi-green" HBox.hgrow="ALWAYS">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <StackPane styleClass="kpi-icon-wrap"><FontAwesomeIconView glyphName="MONEY" size="18" /></StackPane>
                                        <Label text="ESTADO DE CAJA" styleClass="kpi-label" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblCashStatus" text="ABIERTA" style="-fx-font-weight: bold; -fx-font-size: 10px;" />
                                    </HBox>
                                    <Label fx:id="lblCashAmount" text="0.00 €" styleClass="kpi-value" />
                                    <Label text="Efectivo total en el cajón" styleClass="kpi-hint" />
                                </children>
                            </VBox>

                            <!-- Card: Apertura -->
                            <VBox styleClass="kpi-card, kpi-indigo" HBox.hgrow="ALWAYS">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <StackPane styleClass="kpi-icon-wrap"><FontAwesomeIconView glyphName="CLOCK_ALT" size="18" /></StackPane>
                                        <Label text="APERTURA HOY" styleClass="kpi-label" />
                                    </HBox>
                                    <Label fx:id="lblDailyOpenTime" text="--:--" styleClass="kpi-value" />
                                    <Label text="Primer marcaje del día" styleClass="kpi-hint" />
                                </children>
                            </VBox>

                            <!-- Card: Cumplimiento -->
                            <VBox styleClass="kpi-card, kpi-amber" HBox.hgrow="ALWAYS">
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <StackPane styleClass="kpi-icon-wrap"><FontAwesomeIconView glyphName="CALENDAR_CHECK_O" size="18" /></StackPane>
                                        <Label text="PLANIFICACIÓN" styleClass="kpi-label" />
                                    </HBox>
                                    <Label fx:id="lblScheduleCompliance" text="100%" styleClass="kpi-value" />
                                    <Label text="Puntualidad operativa" styleClass="kpi-hint" />
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <!-- ─── CONTENT AREA (Grid) ─── -->
                    <GridPane hgap="30" vgap="30">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="600" />
                            <ColumnConstraints hgrow="NEVER" prefWidth="350" />
                        </columnConstraints>
                        
                        <children>
                            <!-- TABLA DE PERSONAL -->
                            <VBox spacing="15" styleClass="data-card" GridPane.columnIndex="0">
                                <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
                                <children>
                                    <HBox alignment="CENTER_LEFT" spacing="15">
                                        <Label text="PERSONAL EN TURNO" styleClass="card-title" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button text="Ver Historial" styleClass="btn-link" />
                                    </HBox>
                                    <TableView fx:id="tableActiveStaff" prefHeight="400" styleClass="modern-table">
                                        <columns>
                                            <TableColumn fx:id="colStaffStatus" text="ESTADO" prefWidth="100" />
                                            <TableColumn fx:id="colStaffName" text="COLABORADOR" prefWidth="200" />
                                            <TableColumn fx:id="colStaffRole" text="ROL" prefWidth="120" />
                                            <TableColumn fx:id="colStaffShift" text="TURNO ASIG." prefWidth="130" />
                                            <TableColumn fx:id="colStaffStart" text="INICIO SES." prefWidth="100" />
                                            <TableColumn fx:id="colStaffDuration" text="TIEMPO" prefWidth="100" />
                                            <TableColumn fx:id="colStaffProgress" text="PROGRESO" prefWidth="150" />
                                        </columns>
                                        <placeholder><Label text="No hay personal activo en este momento."/></placeholder>
                                    </TableView>
                                </children>
                            </VBox>

                            <!-- PANEL LATERAL: HORARIOS -->
                            <VBox spacing="20" GridPane.columnIndex="1">
                                <children>
                                    <!-- Tarjeta Horarios Hoy -->
                                    <VBox spacing="15" styleClass="data-card">
                                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <FontAwesomeIconView glyphName="CALENDAR" size="16" fill="#3b82f6" />
                                                <Label text="HORARIO DE HOY" styleClass="card-subtitle" />
                                            </HBox>
                                            <VBox fx:id="vboxTodaySchedule" spacing="10" styleClass="today-schedule-list">
                                                <!-- Dynamic turns added here -->
                                            </VBox>
                                        </children>
                                    </VBox>

                                    <!-- Tarjeta Alertas/Eventos -->
                                    <VBox spacing="15" styleClass="data-card" VBox.vgrow="ALWAYS">
                                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <FontAwesomeIconView glyphName="BELL" size="16" fill="#ef4444" />
                                                <Label text="ALERTAS RECIENTES" styleClass="card-subtitle" />
                                            </HBox>
                                            <VBox fx:id="vboxAlerts" spacing="8">
                                                <children>
                                                    <!-- Alert placeholders -->
                                                    <HBox spacing="8" styleClass="alert-row, alert-info">
                                                        <FontAwesomeIconView glyphName="INFO_CIRCLE" />
                                                        <Label text="Sistema operando con normalidad." />
                                                    </HBox>
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                        </children>
                    </GridPane>
                </children>
            </VBox>
        </content>
    </ScrollPane>

    <stylesheets>
        <URL value="@../styles/components/informes.css" />
        <URL value="@../styles/components/operative_monitor.css" />
    </stylesheets>
</VBox>
