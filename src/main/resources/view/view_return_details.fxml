<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ViewReturnDetailsController"
      spacing="20" style="-fx-background-color: -fx-bg-surface;" prefWidth="600" prefHeight="450">
    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <FontAwesomeIconView glyphName="INFO_CIRCLE" size="24" fill="#6366f1"/>
        <VBox>
            <Label fx:id="lblTitle" text="Detalles de la Devoluci&#x00f3;n" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: -fx-text-custom-main;"/>
            <Label fx:id="lblSubtitle" text="Desglose de productos reintegrados" style="-fx-font-size: 13; -fx-text-fill: #64748b;"/>
        </VBox>
    </HBox>

    <TableView fx:id="detailsTable" VBox.vgrow="ALWAYS" styleClass="modern-table-view">
        <columns>
            <TableColumn fx:id="colProduct" text="Producto" prefWidth="300"/>
            <TableColumn fx:id="colQuantity" text="Cant." prefWidth="80" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colPrice" text="Precio Unit." prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <VBox spacing="10" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: -fx-radius-md;">
        <Label text="MOTIVO REGISTRADO:" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
        <Label fx:id="lblReason" wrapText="true" style="-fx-font-size: 13; -fx-text-fill: -fx-text-custom-main;"/>
    </VBox>

    <HBox alignment="CENTER_RIGHT">
        <Button text="CERRAR" onAction="#handleClose" styleClass="btn-secondary" prefWidth="100"/>
    </HBox>
</VBox>
