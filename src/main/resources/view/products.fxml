<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" styleClass="main-content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ProductController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="10.0" left="25.0" right="25.0" top="25.0" />
         </padding>
         <children>
            <!-- Header Section -->
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <VBox>
                     <children>
                        <Label text="Gestión de Productos" styleClass="section-title"/>
                        <Label text="Administra el inventario de tu negocio" styleClass="section-subtitle"/>
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <HBox spacing="10.0" alignment="CENTER_RIGHT">
                     <children>
                        <Button fx:id="btnAdd" onAction="#handleAddProduct" styleClass="btn-primary">
                           <graphic><FontAwesomeIconView glyphName="PLUS" size="14" fill="WHITE"/></graphic>
                           <text> Nuevo Producto</text>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </HBox>

            <!-- Table Card -->
            <VBox spacing="0" styleClass="table-card" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Filter Section -->
                  <HBox alignment="CENTER_LEFT" styleClass="modern-filter-bar">
                     <children>
                        <Label text="Filtrar por nombre o código:" styleClass="label-muted" />
                        <HBox alignment="CENTER_LEFT" styleClass="search-bar" HBox.hgrow="ALWAYS" maxWidth="400">
                           <children>
                              <FontAwesomeIconView glyphName="SEARCH" size="14" styleClass="sidebar-icon" />
                              <TextField fx:id="searchField" promptText="Buscar producto..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                           </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                           <children>
                              <Label text="Ver" textFill="#7f8c8d" />
                              <TextField fx:id="rowsPerPageField" prefWidth="45.0" text="10" styleClass="row-count-field" />
                              <Label text="filas" textFill="#7f8c8d" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>

                  <!-- Table View -->
                  <TableView fx:id="productsTable" styleClass="modern-table-view" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colImage" prefWidth="100.0" text="IMAGEN" />
                      <TableColumn fx:id="colName" prefWidth="280.0" text="PRODUCTO" />
                      <TableColumn fx:id="colCategoryName" prefWidth="180.0" text="CATEGORÍA" />
                      <TableColumn fx:id="colPrice" prefWidth="120.0" text="PRECIO" />
                      <TableColumn fx:id="colFavorite" prefWidth="100.0" text="FAVORITO" />
                      <TableColumn fx:id="colVisible" prefWidth="100.0" text="ESTADO" />
                      <TableColumn fx:id="colActions" prefWidth="180.0" text="ACCIONES" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <!-- Count Section -->
                  <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10;">
                      <children>
                          <Label fx:id="lblCount" text="0 productos encontrados" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold;"/>
                      </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
