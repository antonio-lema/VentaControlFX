<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.layout.StackPane?>

<AnchorPane id="AnchorPane" prefHeight="600.0" prefWidth="900.0" styleClass="main-content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ProductController">
   <children>
      <VBox spacing="0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- Header Section -->
            <VBox styleClass="view-header" spacing="0">
                <children>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <children>
                            <StackPane styleClass="view-header-icon-wrap">
                                <children><FontAwesomeIconView glyphName="CUBES" size="24" fill="white"/></children>
                            </StackPane>
                            <VBox spacing="2">
                                <children>
                                    <Label text="Gestión de Productos" styleClass="view-title"/>
                                    <Label text="Administra el inventario de tu negocio" styleClass="view-subtitle"/>
                                </children>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnAdd" onAction="#handleAddProduct" styleClass="modern-btn-primary" text=" Nuevo Producto">
                                <graphic><FontAwesomeIconView glyphName="PLUS" size="14" fill="WHITE"/></graphic>
                            </Button>
                            <Button text="Importar" onAction="#handleImportExcel" styleClass="modern-btn-secondary">
                                <graphic><FontAwesomeIconView glyphName="UPLOAD" size="14" fill="#334155"/></graphic>
                            </Button>
                        </children>
                    </HBox>
                </children>
            </VBox>
            
            <VBox spacing="20.0" VBox.vgrow="ALWAYS" style="-fx-padding: 25;">
                <children>

            <!-- Table Card -->
            <VBox spacing="0" styleClass="table-card" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Filter Section -->
                  <HBox alignment="CENTER_LEFT" styleClass="modern-filter-bar">
                     <children>
                        <Label text="Filtrar por nombre o código:" styleClass="label-muted" />
                        <HBox alignment="CENTER_LEFT" styleClass="search-bar" HBox.hgrow="ALWAYS" maxWidth="400">
                           <children>
                              <FontAwesomeIconView glyphName="SEARCH" size="14" styleClass="sidebar-icon" />
                               <TextField fx:id="searchField" promptText="Buscar producto..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                            </children>
                         </HBox>
                         <HBox spacing="8" alignment="CENTER_LEFT" styleClass="filter-buttons-container" style="-fx-padding: 0 0 0 15;">
                             <ToggleButton fx:id="btnFilterAll" text="Todos" styleClass="date-filter-chip" />
                             <ToggleButton fx:id="btnFilterVisible" text="Visibles" styleClass="date-filter-chip" selected="true" />
                             <ToggleButton fx:id="btnFilterDisabled" text="Deshabilitados" styleClass="date-filter-chip" />
                         </HBox>
                         <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row-limit-container">
                           <children>
                              <Label text="Mostrar:" styleClass="label-limit" />
                              <ComboBox fx:id="cmbRowLimit" prefWidth="90" styleClass="combo-limit" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>

                  <!-- Table View -->
                  <TableView fx:id="productsTable" styleClass="modern-table-view" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colImage" prefWidth="80.0" text="IMAGEN" />
                      <TableColumn fx:id="colName" prefWidth="240.0" text="PRODUCTO" />
                      <TableColumn fx:id="colSku" prefWidth="120.0" text="SKU" />
                      <TableColumn fx:id="colCategoryName" prefWidth="150.0" text="CATEGORÍA" />
                      <TableColumn fx:id="colStock" prefWidth="100.0" text="STOCK" />
                      <TableColumn fx:id="colPrice" text="Precio" prefWidth="100" />
                      <TableColumn fx:id="colIva" text="IVA" prefWidth="65" style="-fx-alignment: CENTER;" />
                      <TableColumn fx:id="colFavorite" text="Fav" prefWidth="60" style="-fx-alignment: CENTER;" />
                      <TableColumn fx:id="colVisible" prefWidth="80.0" text="ESTADO" />
                      <TableColumn fx:id="colActions" prefWidth="150.0" text="ACCIONES" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  <!-- Count Section -->
                  <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10; -fx-alignment: CENTER_RIGHT;">
                      <children>
                          
                          <Region HBox.hgrow="ALWAYS" />

                          <!-- Jump Buttons and Pagination -->
                          <HBox alignment="CENTER" spacing="0">
                              <children>
                                  <Button onAction="#handleJumpBack10" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                                      <graphic><FontAwesomeIconView glyphName="ANGLE_DOUBLE_LEFT" size="20" fill="#3498db"/></graphic>
                                  </Button>
                                  
                                  <javafx.scene.control.Pagination fx:id="pagination" maxPageIndicatorCount="7" styleClass="server-pagination" />
                                  
                                  <Button onAction="#handleJumpForward10" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 4;">
                                      <graphic><FontAwesomeIconView glyphName="ANGLE_DOUBLE_RIGHT" size="20" fill="#3498db"/></graphic>
                                  </Button>
                              </children>
                          </HBox>

                          <Label fx:id="lblCount" text="0 productos encontrados" style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold; -fx-min-width: 200; -fx-alignment: CENTER_RIGHT;"/>
                      </children>
                  </HBox>
               </children>
            </VBox>
         </children>
      </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
