<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<StackPane fx:id="rootStackPane" styleClass="register-popup-background"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ReturnDialogController">
   <VBox maxWidth="850.0" spacing="0.0" styleClass="modern-register-card" StackPane.alignment="CENTER">
      <!-- Header -->
      <VBox styleClass="modern-register-header" alignment="CENTER_LEFT">
         <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <Label text="Devoluci&#x00f3;n de Productos" styleClass="modern-register-title" />
         <Label fx:id="lblTicketInfo" text="Seleccione los productos a devolver del ticket #"
                styleClass="modern-register-subtitle" />
      </VBox>

      <!-- Content -->
      <VBox spacing="15.0">
         <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="10.0" />
         </padding>

         <!-- Table Header Row -->
         <HBox spacing="10.0" styleClass="return-table-header">
            <Label prefWidth="40.0" text="Sel." styleClass="table-col-header" />
            <Label HBox.hgrow="ALWAYS" maxWidth="Infinity" text="PRODUCTO" styleClass="table-col-header" />
            <Region HBox.hgrow="ALWAYS" />
            <Label prefWidth="70.0" text="VEND." styleClass="table-col-header" alignment="CENTER" />
            <Label prefWidth="70.0" text="DEV." styleClass="table-col-header" alignment="CENTER" />
            <Label prefWidth="90.0" text="CANT." styleClass="table-col-header" alignment="CENTER" />
         </HBox>

         <ScrollPane fitToWidth="true" minHeight="200.0" maxHeight="350.0" styleClass="detail-scroll">
            <content>
               <VBox fx:id="itemsContainer" spacing="2.0" style="-fx-background-color: transparent;" />
            </content>
         </ScrollPane>

         <!-- Reason TextArea -->
         <VBox spacing="8.0" styleClass="modern-input-group">
            <Label text="Motivo de la devolución" styleClass="config-field-label" />
            <TextArea fx:id="txtReason" prefHeight="70.0"
                      promptText="Motivo detallado..."
                      styleClass="modern-input-field return-reason-area"
                      wrapText="true" />
         </VBox>

         <!-- Refund Summary -->
         <VBox spacing="5.0" styleClass="return-summary-box" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e9ecef; -fx-border-width: 1;">
             <HBox alignment="CENTER_LEFT" spacing="10">
                 <Label text="Total a devolver:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                 <Region HBox.hgrow="ALWAYS" />
                 <Label fx:id="lblTotalRefund" text="0,00 €" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #212529;"/>
             </HBox>
             <HBox fx:id="boxBrokenDownRefund" alignment="CENTER_LEFT" spacing="10" visible="false">
                 <VBox spacing="2">
                     <HBox spacing="10">
                         <Label text="📤 En Efectivo:" style="-fx-text-fill: #6c757d; -fx-font-size: 12px;"/>
                         <Label fx:id="lblCashRefund" text="0,00 €" style="-fx-font-weight: bold; -fx-text-fill: #198754; -fx-font-size: 12px;"/>
                     </HBox>
                     <HBox spacing="10">
                         <Label text="💳 En Tarjeta:" style="-fx-text-fill: #6c757d; -fx-font-size: 12px;"/>
                         <Label fx:id="lblCardRefund" text="0,00 €" style="-fx-font-weight: bold; -fx-text-fill: #0d6efd; -fx-font-size: 12px;"/>
                     </HBox>
                 </VBox>
             </HBox>
         </VBox>
      </VBox>

      <!-- Footer -->
      <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 20 30 30 30;">
         <Button onAction="#handleCancel" styleClass="modern-btn-secondary"
                 text="Cancelar" cancelButton="true"/>
         <Button onAction="#handleConfirm" styleClass="modern-btn-primary"
                 text="Confirmar Devoluci&#x00f3;n" defaultButton="true">
            <graphic>
               <FontAwesomeIconView glyphName="CHECK" size="14" fill="WHITE" />
            </graphic>
         </Button>
      </HBox>
   </VBox>
</StackPane>
