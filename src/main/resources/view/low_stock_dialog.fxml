<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.LowStockDialogController"
      spacing="15" prefWidth="500" prefHeight="400" styleClass="low-stock-dialog">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <FontAwesomeIconView glyphName="EXCLAMATION_TRIANGLE" size="24" fill="#e53935"/>
        <VBox>
            <Label text="Productos con Stock Bajo" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="Estos productos han alcanzado o superado el límite mínimo." styleClass="label-muted"/>
        </VBox>
    </HBox>

    <TableView fx:id="tableLowStock" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columns>
            <TableColumn fx:id="colName" text="Producto" prefWidth="200"/>
            <TableColumn fx:id="colCurrentStock" text="Actual" prefWidth="100" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colMinStock" text="Mínimo" prefWidth="100" style="-fx-alignment: CENTER;"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button text="Cerrar" onAction="#handleClose" styleClass="modern-btn-primary"/>
    </HBox>
</VBox>
