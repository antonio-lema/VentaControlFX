<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.PromotionFormController"
      spacing="20" style="-fx-padding: 25; -fx-background-color: white;" prefWidth="500">
    
    <children>
        <HBox spacing="15" alignment="CENTER_LEFT">
            <children>
                <StackPane styleClass="view-header-icon-wrap" style="-fx-background-color: -color-primary; -fx-min-width: 40; -fx-min-height: 40;">
                    <children><FontAwesomeIconView glyphName="TAG" size="18" fill="white"/></children>
                </StackPane>
                <VBox spacing="2">
                    <children>
                        <Label fx:id="lblTitle" text="Nueva Promoción" styleClass="view-title" style="-fx-font-size: 18;"/>
                        <Label text="Configura los detalles de la oferta" styleClass="view-subtitle"/>
                    </children>
                </VBox>
            </children>
        </HBox>

        <Separator />

        <GridPane hgap="20" vgap="15">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            </columnConstraints>
            <children>
                <VBox spacing="5" GridPane.columnSpan="2">
                    <children>
                        <Label text="Nombre de la Promoción" styleClass="label-bold"/>
                        <TextField fx:id="txtName" promptText="Ej: Rebajas de Verano" styleClass="modern-text-field"/>
                    </children>
                </VBox>

                <VBox spacing="5" GridPane.rowIndex="1">
                    <children>
                        <Label text="Tipo" styleClass="label-bold"/>
                        <ComboBox fx:id="cmbType" maxWidth="Infinity" styleClass="modern-combo-box"/>
                    </children>
                </VBox>

                <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
                    <children>
                        <Label text="Valor" styleClass="label-bold"/>
                        <TextField fx:id="txtValue" promptText="0.00" styleClass="modern-text-field"/>
                    </children>
                </VBox>

                <VBox spacing="5" GridPane.rowIndex="2">
                    <children>
                        <Label text="Ámbito" styleClass="label-bold"/>
                        <ComboBox fx:id="cmbScope" maxWidth="Infinity" styleClass="modern-combo-box"/>
                    </children>
                </VBox>

                <VBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1" alignment="BOTTOM_LEFT">
                    <children>
                        <CheckBox fx:id="chkActive" text="Activar promoción" selected="true" style="-fx-font-weight: bold;"/>
                    </children>
                </VBox>

                <VBox fx:id="panelAffected" spacing="5" GridPane.rowIndex="3" GridPane.columnSpan="2">
                    <children>
                        <Label fx:id="lblAffected" text="Afectados" styleClass="label-bold"/>
                        <HBox spacing="10">
                            <children>
                                <TextField fx:id="txtAffectedSearch" promptText="Buscar ID o nombre..." HBox.hgrow="ALWAYS" styleClass="modern-text-field"/>
                                <Button onAction="#handleAddAffected" styleClass="btn-secondary" text="Añadir" />
                            </children>
                        </HBox>
                        <ListView fx:id="listAffected" prefHeight="100" styleClass="modern-list-view"/>
                    </children>
                </VBox>

                <VBox fx:id="panelVolume" spacing="5" GridPane.rowIndex="4" GridPane.columnSpan="2">
                    <children>
                        <HBox spacing="20">
                            <children>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Cant. Compra (Paga)" styleClass="label-bold"/>
                                        <TextField fx:id="txtBuyQty" promptText="Ej: 2" styleClass="modern-text-field"/>
                                    </children>
                                </VBox>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="Cant. Gratis (Regalo)" styleClass="label-bold"/>
                                        <TextField fx:id="txtFreeQty" promptText="Ej: 1" styleClass="modern-text-field"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="5" GridPane.rowIndex="5">
                    <children>
                        <Label text="Fecha Inicio" styleClass="label-bold"/>
                        <DatePicker fx:id="dpStartDate" maxWidth="Infinity" styleClass="modern-date-picker"/>
                    </children>
                </VBox>

                <VBox spacing="5" GridPane.rowIndex="5" GridPane.columnIndex="1">
                    <children>
                        <Label text="Fecha Fin" styleClass="label-bold"/>
                        <DatePicker fx:id="dpEndDate" maxWidth="Infinity" styleClass="modern-date-picker"/>
                    </children>
                </VBox>
            </children>
        </GridPane>

        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <children>
                <Button onAction="#handleCancel" text="Cancelar" styleClass="btn-outline"/>
                <Button onAction="#handleSave" text="Guardar Promoción" styleClass="btn-primary">
                    <graphic><FontAwesomeIconView glyphName="SAVE" fill="WHITE"/></graphic>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>
