<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.PromotionFormController"
      spacing="20" prefWidth="550" prefHeight="650"
      style="-fx-padding: 30; -fx-background-color: -fx-bg-surface; -fx-background-radius: 24px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 30, 0, 0, 15); -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 24px; -fx-border-width: 1.5px;">
    
    <children>
        <HBox spacing="20" alignment="CENTER_LEFT">
            <children>
                <StackPane style="-fx-background-color: linear-gradient(to bottom right, #6366f1, #4f46e5); -fx-background-radius: 14px; -fx-min-width: 50; -fx-min-height: 50; -fx-effect: dropshadow(three-pass-box, rgba(79, 70, 229, 0.4), 10, 0, 0, 4);">
                    <children><FontAwesomeIconView glyphName="TAG" size="22" fill="white"/></children>
                </StackPane>
                <VBox spacing="2">
                    <children>
                        <Label fx:id="lblTitle" text="%promotion.btn.new" style="-fx-font-size: 22; -fx-font-weight: 800; -fx-text-fill: -fx-text-custom-main;"/>
                        <Label text="%promotion.form.subtitle" style="-fx-font-size: 13; -fx-text-fill: -fx-text-custom-muted;"/>
                    </children>
                </VBox>
            </children>
        </HBox>

        <Separator style="-fx-opacity: 0.3;" />

        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0;" styleClass="edge-to-edge" VBox.vgrow="ALWAYS">
            <content>
                <GridPane hgap="20" vgap="15">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>
                    <children>
                        <VBox spacing="5" GridPane.columnSpan="2">
                            <children>
                                <Label text="%promotion.form.name" styleClass="label-bold"/>
                                <TextField fx:id="txtName" promptText="Ej: Rebajas de Verano" styleClass="modern-text-field"/>
                            </children>
                        </VBox>
                        
                        <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnSpan="2">
                            <children>
                                <Label text="%promotion.form.code" styleClass="label-bold"/>
                                <HBox spacing="10">
                                    <children>
                                        <TextField fx:id="txtCode" promptText="Código (Ej: VERANO2024)" HBox.hgrow="ALWAYS" styleClass="modern-text-field"/>
                                        <Button onAction="#handleGenerateCode" styleClass="btn-secondary" text="Generar">
                                            <graphic><de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView glyphName="MAGIC" fill="WHITE"/></graphic>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="5" GridPane.rowIndex="2">
                            <children>
                                <Label text="Límite de Usos Totales (0 = Sin Límite)" styleClass="label-bold"/>
                                <TextField fx:id="txtMaxUses" promptText="0" styleClass="modern-text-field"/>
                            </children>
                        </VBox>

                        <VBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                            <children>
                                <Label text="ID Cliente Específico (Opcional)" styleClass="label-bold"/>
                                <TextField fx:id="txtBoundClientId" promptText="Dejar vacío para todos" styleClass="modern-text-field"/>
                            </children>
                        </VBox>

                        <VBox spacing="5" GridPane.rowIndex="3" GridPane.columnSpan="2">
                            <children>
                                <Label text="Compra Mínima Requerida (Subtotal > X)" styleClass="label-bold"/>
                                <TextField fx:id="txtMinOrderValue" promptText="0,00" styleClass="modern-text-field"/>
                            </children>
                        </VBox>

                        <VBox spacing="5" GridPane.rowIndex="4">
                            <children>
                                <Label text="%promotion.form.type" styleClass="label-bold"/>
                                <ComboBox fx:id="cmbType" maxWidth="Infinity" styleClass="modern-combo-box"/>
                            </children>
                        </VBox>

                        <VBox fx:id="panelValue" spacing="5" GridPane.rowIndex="4" GridPane.columnIndex="1">
                            <children>
                                <Label text="%promotion.form.value" styleClass="label-bold"/>
                                <TextField fx:id="txtValue" promptText="0,00" styleClass="modern-text-field"/>
                            </children>
                        </VBox>

                        <VBox spacing="5" GridPane.rowIndex="5">
                            <children>
                                <Label text="%promotion.form.scope" styleClass="label-bold"/>
                                <ComboBox fx:id="cmbScope" maxWidth="Infinity" styleClass="modern-combo-box"/>
                            </children>
                        </VBox>

                        <VBox spacing="5" GridPane.rowIndex="5" GridPane.columnIndex="1" alignment="BOTTOM_LEFT">
                            <children>
                                <CheckBox fx:id="chkActive" text="%promotion.form.active" selected="true" style="-fx-font-weight: bold;"/>
                            </children>
                        </VBox>

                        <VBox fx:id="panelAffected" spacing="5" GridPane.rowIndex="6" GridPane.columnSpan="2">
                            <children>
                                <Label fx:id="lblAffected" text="%promotion.form.affected" styleClass="label-bold"/>
                                <HBox spacing="10">
                                    <children>
                                        <TextField fx:id="txtAffectedSearch" promptText="Buscar ID o nombre..." HBox.hgrow="ALWAYS" styleClass="modern-text-field"/>
                                        <Button onAction="#handleAddAffected" styleClass="btn-secondary" text="%promotion.form.btn.add" />
                                    </children>
                                </HBox>
                                <ListView fx:id="listAffected" prefHeight="100" styleClass="modern-list-view"/>
                            </children>
                        </VBox>

                        <VBox fx:id="panelVolume" spacing="5" GridPane.rowIndex="7" GridPane.columnSpan="2">
                            <children>
                                <HBox spacing="20">
                                    <children>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="%promotion.form.buy_qty" styleClass="label-bold"/>
                                                <TextField fx:id="txtBuyQty" promptText="Ej: 2" styleClass="modern-text-field"/>
                                            </children>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="%promotion.form.free_qty" styleClass="label-bold"/>
                                                <TextField fx:id="txtFreeQty" promptText="Ej: 1" styleClass="modern-text-field"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="5" GridPane.rowIndex="8">
                            <children>
                                <Label text="%promotion.form.start_date" styleClass="label-bold"/>
                                <DatePicker fx:id="dpStartDate" maxWidth="Infinity" styleClass="modern-datepicker"/>
                            </children>
                        </VBox>

                        <VBox spacing="5" GridPane.rowIndex="8" GridPane.columnIndex="1">
                            <children>
                                <Label text="%promotion.form.end_date" styleClass="label-bold"/>
                                <DatePicker fx:id="dpEndDate" maxWidth="Infinity" styleClass="modern-datepicker"/>
                            </children>
                        </VBox>
                    </children>
                </GridPane>
            </content>
        </ScrollPane>

        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 20 0 0 0;">
            <children>
                <Button onAction="#handleCancel" text="%btn.cancel" 
                        style="-fx-background-color: transparent; -fx-text-fill: -fx-text-custom-muted; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 20; -fx-border-color: rgba(0,0,0,0.1); -fx-border-radius: 10px;"/>
                <Button onAction="#handleSave" text="%promotion.form.btn.save" 
                        style="-fx-background-color: linear-gradient(to right, #6366f1, #4f46e5); -fx-text-fill: white; -fx-font-weight: 800; -fx-cursor: hand; -fx-background-radius: 12px; -fx-padding: 12 30; -fx-effect: dropshadow(three-pass-box, rgba(79, 70, 229, 0.3), 10, 0, 0, 4);">
                    <graphic><FontAwesomeIconView glyphName="SAVE" fill="WHITE" size="14"/></graphic>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>
