<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
           fx:controller="com.mycompany.ventacontrolfx.presentation.controller.FiscalDocumentsController"
           styleClass="main-content-area">
    <stylesheets>
        <java.net.URL value="@../styles/components/informes.css"/>
    </stylesheets>

    <VBox spacing="0">
        <!-- ─── HEADER ─── -->
        <VBox styleClass="view-header" spacing="0">
            <children>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <children>
                        <StackPane styleClass="view-header-icon-wrap">
                            <children>
                                <FontAwesomeIconView glyphName="FILE_TEXT" size="22" fill="white"/>
                            </children>
                        </StackPane>
                        <VBox spacing="2">
                            <children>
                                <Label text="Gestión de Facturación" styleClass="view-title"/>
                                <Label text="Consulta, reimpresión y anulación de documentos fiscales" styleClass="view-subtitle"/>
                            </children>
                        </VBox>
                        
                        <Region HBox.hgrow="ALWAYS" />

                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button styleClass="btn-secondary" onAction="#handleOpenArchiveDir">
                                <graphic><FontAwesomeIconView glyphName="FOLDER_OPEN" size="14"/></graphic>
                                <text>Abrir Carpeta PDF</text>
                            </Button>
                            <Button styleClass="btn-secondary" onAction="#refresh">
                                <graphic><FontAwesomeIconView glyphName="REFRESH" size="14"/></graphic>
                                <text>Actualizar</text>
                            </Button>
                            <Button styleClass="btn-primary" onAction="#handleExportData">
                                <graphic><FontAwesomeIconView glyphName="FILE_EXCEL_ALT" size="14" fill="#ffffff"/></graphic>
                                <text>Exportar Listado (Excel)</text>
                            </Button>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 30;">

        <!-- ─── KPI CARDS ─── -->
        <HBox spacing="20">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <StackPane styleClass="icon-bg-blue">
                        <FontAwesomeIconView glyphName="TICKET" size="24" fill="#3b82f6"/>
                    </StackPane>
                    <VBox>
                        <Label text="Tickets Emitidos" styleClass="stat-label"/>
                        <Label fx:id="lblTotalTickets" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <StackPane styleClass="icon-bg-green">
                        <FontAwesomeIconView glyphName="BUILDING_ALT" size="24" fill="#10b981"/>
                    </StackPane>
                    <VBox>
                        <Label text="Facturas Emitidas" styleClass="stat-label"/>
                        <Label fx:id="lblTotalInvoices" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <StackPane styleClass="icon-bg-red">
                        <FontAwesomeIconView glyphName="BAN" size="24" fill="#ef4444"/>
                    </StackPane>
                    <VBox>
                        <Label text="Documentos Anulados" styleClass="stat-label"/>
                        <Label fx:id="lblTotalCancelled" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>
            
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <StackPane styleClass="icon-bg-blue">
                        <FontAwesomeIconView glyphName="CALCULATOR" size="24" fill="#3b82f6"/>
                    </StackPane>
                    <VBox>
                        <Label text="Total Facturado (Base)" styleClass="stat-label"/>
                        <Label fx:id="lblTotalAmount" text="0.00 €" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <!-- ─── FILTROS ─── -->
        <HBox styleClass="filter-card" alignment="CENTER_LEFT" spacing="15">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            
            <VBox spacing="5">
                <Label text="Rango de Fechas" styleClass="filter-label"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <DatePicker fx:id="dpFrom" prefWidth="150" promptText="Desde" onAction="#applyFilters" styleClass="modern-datepicker"/>
                    <Label text="a" style="-fx-text-fill: #94a3b8;"/>
                    <DatePicker fx:id="dpTo" prefWidth="150" promptText="Hasta" onAction="#applyFilters" styleClass="modern-datepicker"/>
                </HBox>
            </VBox>

            <Separator orientation="VERTICAL" prefHeight="40" style="-fx-opacity: 0.1;"/>

            <VBox spacing="5">
                <Label text="Tipo de Documento" styleClass="filter-label"/>
                <ComboBox fx:id="cbType" prefWidth="180" promptText="Todos los tipos" onAction="#applyFilters"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Estado" styleClass="filter-label"/>
                <ComboBox fx:id="cbStatus" prefWidth="150" promptText="Todos los estados" onAction="#applyFilters"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox spacing="5" alignment="CENTER_RIGHT">
                <Label text="Buscar por Número/Ref" styleClass="filter-label"/>
                <HBox alignment="CENTER_RIGHT" spacing="5" styleClass="search-box">
                    <FontAwesomeIconView glyphName="SEARCH" size="14" fill="#94a3b8"/>
                    <TextField fx:id="txtSearch" promptText="Ej: 2026-T-001" prefWidth="200" styleClass="search-input"/>
                </HBox>
            </VBox>
        </HBox>

        <!-- ─── TABLA ─── -->
        <TableView fx:id="fiscalTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colDate" text="Fecha Emisión" prefWidth="150"/>
                <TableColumn fx:id="colRef" text="Referencia" prefWidth="180"/>
                <TableColumn fx:id="colType" text="Tipo" prefWidth="120"/>
                <TableColumn fx:id="colClient" text="Cliente / Receptor" prefWidth="250"/>
                <TableColumn fx:id="colTotal" text="Importe Total" prefWidth="130" styleClass="column-right"/>
                <TableColumn fx:id="colStatus" text="Estado" prefWidth="120" styleClass="column-center"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <!-- Conteo y Paginación -->
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row-limit-container">
            <children>
                <Label text="Mostrar:" styleClass="label-limit" />
                <ComboBox fx:id="cmbRowLimit" prefWidth="90" styleClass="combo-limit" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblCount" text="0 registros encontrados" styleClass="label-muted" style="-fx-font-weight: bold;" />
            </children>
        </HBox>

    </VBox>
    </VBox>

    <!-- ─── PANEL DE DETALLE DESLIZANTE (OPCIONAL) ─── -->
    <HBox fx:id="detailsOverlay" visible="false" managed="false" alignment="CENTER_RIGHT" style="-fx-background-color: rgba(0,0,0,0.3);">
        <VBox fx:id="detailsPanel" prefWidth="450" styleClass="detail-panel">
             <!-- Contenido dinámico del detalle aquí -->
        </VBox>
    </HBox>

</StackPane>
