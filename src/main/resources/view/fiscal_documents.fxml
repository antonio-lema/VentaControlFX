<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<StackPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
           fx:controller="com.mycompany.ventacontrolfx.presentation.controller.FiscalDocumentsController"
           styleClass="main-content-area">
    <stylesheets>
        <java.net.URL value="@../styles/components/informes.css"/>
        <java.net.URL value="@../styles/components/filters.css" />
    </stylesheets>

    <VBox spacing="0">
        <!--  HEADER  -->
        <VBox styleClass="view-header" spacing="0">
            <children>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <children>
                        <StackPane styleClass="view-header-icon-wrap">
                            <children>
                                <FontAwesomeIconView glyphName="FILE_TEXT" size="22" fill="white"/>
                            </children>
                        </StackPane>
                        <VBox spacing="2">
                            <children>
                                <Label text="%fiscal.title" styleClass="view-title"/>
                                <Label text="%fiscal.subtitle" styleClass="view-subtitle"/>
                            </children>
                        </VBox>
                        
                        <Region HBox.hgrow="ALWAYS" />

                        <HBox spacing="10" alignment="CENTER_RIGHT">
                            <Button styleClass="btn-secondary" onAction="#handleOpenArchiveDir" text="%fiscal.btn.open_folder">
                                <graphic><FontAwesomeIconView glyphName="FOLDER_OPEN" size="14"/></graphic>
                            </Button>
                            <Button styleClass="btn-secondary" onAction="#refresh" text="%fiscal.btn.refresh">
                                <graphic><FontAwesomeIconView glyphName="REFRESH" size="14"/></graphic>
                            </Button>
                            <Button styleClass="btn-primary" onAction="#handleExportData" text="%fiscal.btn.export">
                                <graphic><FontAwesomeIconView glyphName="FILE_EXCEL_ALT" size="14" fill="#ffffff"/></graphic>
                            </Button>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 30;">

        <!--  KPI CARDS  -->
        <HBox spacing="15">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <StackPane styleClass="icon-bg-blue">
                        <FontAwesomeIconView glyphName="TICKET" size="24" fill="#3b82f6"/>
                    </StackPane>
                    <VBox>
                        <Label text="%fiscal.kpi.tickets" styleClass="stat-label"/>
                        <Label fx:id="lblTotalTickets" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <StackPane styleClass="icon-bg-green">
                        <FontAwesomeIconView glyphName="BUILDING_ALT" size="24" fill="#10b981"/>
                    </StackPane>
                    <VBox>
                        <Label text="%fiscal.kpi.invoices" styleClass="stat-label"/>
                        <Label fx:id="lblTotalInvoices" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <StackPane styleClass="icon-bg-orange" style="-fx-background-color: #ffedd5;">
                        <FontAwesomeIconView glyphName="REPLY" size="24" fill="#f97316"/>
                    </StackPane>
                    <VBox>
                        <Label text="%fiscal.kpi.returns" styleClass="stat-label"/>
                        <Label fx:id="lblTotalReturns" text="0" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>

            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <StackPane styleClass="icon-bg-blue">
                        <FontAwesomeIconView glyphName="CALCULATOR" size="24" fill="#3b82f6"/>
                    </StackPane>
                    <VBox>
                        <Label text="%fiscal.kpi.total_facturado" styleClass="stat-label"/>
                        <Label fx:id="lblTotalAmount" text="0.00 €" styleClass="stat-value"/>
                    </VBox>
                </HBox>
            </VBox>
        </HBox>

        <!--  FILTROS  -->
        <HBox styleClass="filter-card" alignment="CENTER_LEFT" spacing="15">
            <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
            
            <VBox spacing="5">
                <Label text="%fiscal.filter.range" styleClass="filter-label"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <DatePicker fx:id="dpFrom" prefWidth="150" promptText="%fiscal.filter.from" onAction="#applyFilters" styleClass="modern-datepicker"/>
                    <Label text="a" style="-fx-text-fill: #94a3b8;"/>
                    <DatePicker fx:id="dpTo" prefWidth="145" promptText="%fiscal.filter.to" onAction="#applyFilters" styleClass="modern-datepicker"/>
                    <HBox fx:id="quickFilterContainer" spacing="8" alignment="CENTER_LEFT" styleClass="date-filter-container" />
                </HBox>
            </VBox>

            <Separator orientation="VERTICAL" prefHeight="40" style="-fx-opacity: 0.1;"/>

            <VBox spacing="5">
                <Label text="%fiscal.filter.type" styleClass="filter-label"/>
                <ComboBox fx:id="cbType" prefWidth="180" promptText="%fiscal.filter.all_types" onAction="#applyFilters"/>
            </VBox>

            <VBox spacing="5">
                <Label text="%fiscal.filter.status" styleClass="filter-label"/>
                <ComboBox fx:id="cbStatus" prefWidth="150" promptText="%fiscal.filter.all_status" onAction="#applyFilters"/>
            </VBox>

            <Region HBox.hgrow="ALWAYS"/>

            <VBox spacing="5" alignment="CENTER_RIGHT">
                <Label text="%fiscal.filter.search_label" styleClass="filter-label"/>
                <HBox alignment="CENTER_RIGHT" spacing="5" styleClass="search-box">
                    <FontAwesomeIconView glyphName="SEARCH" size="14" fill="#94a3b8"/>
                    <TextField fx:id="txtSearch" promptText="Ej: 2026-T-001" prefWidth="200" styleClass="search-input"/>
                </HBox>
            </VBox>
        </HBox>

        <!--  TABLA  -->
        <TableView fx:id="fiscalTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colDate" text="%fiscal.table.date" prefWidth="150"/>
                <TableColumn fx:id="colRef" text="%fiscal.table.ref" prefWidth="180"/>
                <TableColumn fx:id="colType" text="%fiscal.table.type" prefWidth="120"/>
                <TableColumn fx:id="colClient" text="%fiscal.table.client" prefWidth="250"/>
                <TableColumn fx:id="colTotal" text="%fiscal.table.total" prefWidth="130" styleClass="column-right"/>
                <TableColumn fx:id="colStatus" text="%fiscal.table.status" prefWidth="120" styleClass="column-center"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>

        <!-- Conteo y Paginaci&#x00f3;n -->
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row-limit-container">
            <children>
                <Label text="%fiscal.footer.showing" styleClass="label-limit" />
                <ComboBox fx:id="cmbRowLimit" prefWidth="90" styleClass="combo-limit" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblCount" text="0 %fiscal.footer.found" styleClass="label-muted" style="-fx-font-weight: bold;" />
            </children>
        </HBox>

    </VBox>
    </VBox>

    <!--  PANEL DE DETALLE DESLIZANTE (OPCIONAL)  -->
    <HBox fx:id="detailsOverlay" visible="false" managed="false" alignment="CENTER_RIGHT" style="-fx-background-color: rgba(0,0,0,0.3);">
        <VBox fx:id="detailsPanel" prefWidth="450" styleClass="detail-panel">
             <!-- Contenido din&#x00e1;mico del detalle aqu&#x00ed; -->
        </VBox>
    </HBox>

</StackPane>
