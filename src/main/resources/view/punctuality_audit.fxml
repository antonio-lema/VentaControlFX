<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.PunctualityAuditController"
      spacing="0" styleClass="main-content-area">
    <children>
        <!-- Header con estilo Premium -->
        <VBox styleClass="view-header" spacing="0">
            <children>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <children>
                        <StackPane styleClass="view-header-icon-wrap" style="-fx-background-color: -color-primary;">
                            <children><FontAwesomeIconView glyphName="CALENDAR_CHECK_ALT" size="24" fill="white"/></children>
                        </StackPane>
                        <VBox spacing="2">
                            <children>
                                <Label text="%audit.punctuality.title" styleClass="view-title"/>
                                <Label text="%audit.punctuality.subtitle" styleClass="view-subtitle"/>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <DatePicker fx:id="datePicker" onAction="#handleDateChange" prefWidth="150" styleClass="modern-datepicker"/>
                            <Button onAction="#refresh" styleClass="btn-icon">
                                <graphic><FontAwesomeIconView glyphName="REFRESH" size="14"/></graphic>
                            </Button>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </VBox>

        <VBox spacing="20" VBox.vgrow="ALWAYS" style="-fx-padding: 25;">
            <children>
                <GridPane hgap="20" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="33.3" />
                        <ColumnConstraints percentWidth="33.3" />
                        <ColumnConstraints percentWidth="33.3" />
                    </columnConstraints>
                    <children>
                        <VBox styleClass="stats-card">
                            <Label text="%audit.punctuality.stats.general" styleClass="stats-label" />
                            <Label fx:id="lblGeneralPunctuality" text="--%" styleClass="stats-value" />
                        </VBox>
                        <VBox styleClass="stats-card-warning" GridPane.columnIndex="1">
                            <Label text="%audit.punctuality.stats.late" styleClass="stats-label" />
                            <Label fx:id="lblLateCount" text="0" styleClass="stats-value" />
                        </VBox>
                        <VBox styleClass="stats-card-danger" GridPane.columnIndex="2">
                            <Label text="%audit.punctuality.stats.noshow" styleClass="stats-label" />
                            <Label fx:id="lblNoShowCount" text="0" styleClass="stats-value" />
                        </VBox>
                    </children>
                </GridPane>

                <TableView fx:id="tableAudit" VBox.vgrow="ALWAYS" styleClass="modern-table-view">
                    <columns>
                        <TableColumn fx:id="colUser" prefWidth="180" text="%audit.punctuality.table.employee" />
                        <TableColumn fx:id="colShift" prefWidth="180" text="%audit.punctuality.table.shift" />
                        <TableColumn fx:id="colRealStart" prefWidth="130" text="%audit.punctuality.table.start" />
                        <TableColumn fx:id="colDelay" prefWidth="110" text="%audit.punctuality.table.delay" />
                        <TableColumn fx:id="colStatus" prefWidth="150" text="%audit.punctuality.table.status" />
                        <TableColumn fx:id="colEndPunctuality" prefWidth="180" text="%audit.punctuality.table.end" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
