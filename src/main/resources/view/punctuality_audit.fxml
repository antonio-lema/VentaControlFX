<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" styleClass="main-content-area" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.PunctualityAuditController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="page-header">
            <children>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="text-title" text="Auditor\u00eda de Puntualidad" />
                        <Label styleClass="text-subtitle" text="Comparativa entre turnos programados y asistencia real" />
                    </children>
                </VBox>
                <DatePicker fx:id="datePicker" onAction="#handleDateChange" prefWidth="180" />
                <Button onAction="#refresh" styleClass="button-secondary" text="Refrescar" />
            </children>
            <padding>
                <Insets bottom="10" left="20" right="20" top="10" />
            </padding>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
            <content>
                <VBox spacing="20" styleClass="content-padding">
                    <children>
                        <GridPane hgap="20" vgap="20">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33" />
                                <ColumnConstraints percentWidth="33" />
                                <ColumnConstraints percentWidth="34" />
                            </columnConstraints>
                            <children>
                                <VBox styleClass="stats-card">
                                    <Label styleClass="stats-label" text="Puntualidad General" />
                                    <Label fx:id="lblGeneralPunctuality" styleClass="stats-value" text="--%" />
                                </VBox>
                                <VBox styleClass="stats-card-warning" GridPane.columnIndex="1">
                                    <Label styleClass="stats-label" text="Retrasos Detectados" />
                                    <Label fx:id="lblLateCount" styleClass="stats-value" text="0" />
                                </VBox>
                                <VBox styleClass="stats-card-danger" GridPane.columnIndex="2">
                                    <Label styleClass="stats-label" text="Inasistencias" />
                                    <Label fx:id="lblNoShowCount" styleClass="stats-value" text="0" />
                                </VBox>
                            </children>
                        </GridPane>

                        <TableView fx:id="tableAudit" minHeight="500" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colUser" prefWidth="150" text="Empleado" />
                                <TableColumn fx:id="colShift" prefWidth="150" text="Turno Programado" />
                                <TableColumn fx:id="colRealStart" prefWidth="120" text="Inicio Real" />
                                <TableColumn fx:id="colDelay" prefWidth="100" text="Retraso" />
                                <TableColumn fx:id="colStatus" prefWidth="150" text="Estado" />
                                <TableColumn fx:id="colEndPunctuality" prefWidth="150" text="Cierre (Fin Turno)" />
                            </columns>
                        </TableView>
                    </children>
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </children>
</VBox>
