<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import java.net.URL?>

<VBox spacing="0" prefWidth="1280" prefHeight="800" style="-fx-background-color: #f8fafc;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.user.StaffCalendarController">
    
    <!-- Top Nav Header (Premium Dark) -->
    <HBox alignment="CENTER_LEFT" spacing="25" style="-fx-background-color: linear-gradient(to right, #0f172a, #1e293b); -fx-padding: 24 32; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">
        <children>
            <StackPane style="-fx-background-color: #3b82f6; -fx-background-radius: 12; -fx-min-width: 48; -fx-min-height: 48;">
                <children>
                    <FontAwesomeIconView glyphName="CALENDAR" size="24" fill="white" />
                </children>
            </StackPane>
            
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <children>
                    <Label text="Planificador Maestro de Personal" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-text-fill: white;" />
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <children>
                            <Label text="CONTROL DE TURNOS, VACACIONES Y FESTIVOS NACIONALES" style="-fx-text-fill: #94a3b8; -fx-font-size: 11px; -fx-font-weight: bold; -fx-letter-spacing: 1px;" />
                            <Region style="-fx-background-color: #3b82f6; -fx-min-width: 4; -fx-min-height: 4; -fx-background-radius: 2;" />
                            <Label fx:id="lblSummary" text="Espa&#x00f1a; (Nacional)" style="-fx-text-fill: #3b82f6; -fx-font-size: 11px; -fx-font-weight: bold;" />
                        </children>
                    </HBox>
                </children>
            </VBox>

            <!-- Navigation Controls -->
            <HBox spacing="15" alignment="CENTER" style="-fx-background-color: rgba(255,255,255,0.05); -fx-padding: 8 20; -fx-background-radius: 30; -fx-border-color: rgba(255,255,255,0.1); -fx-border-radius: 30;">
                <children>
                    <Button onAction="#handlePrevMonth" style="-fx-background-color: transparent; -fx-cursor: hand;">
                        <graphic><FontAwesomeIconView glyphName="CHEVRON_LEFT" fill="white" size="14" /></graphic>
                    </Button>
                    <Label fx:id="lblMonthYear" text="MARZO 2026" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: white; -fx-min-width: 180;" alignment="CENTER"/>
                    <Button onAction="#handleNextMonth" style="-fx-background-color: transparent; -fx-cursor: hand;">
                        <graphic><FontAwesomeIconView glyphName="CHEVRON_RIGHT" fill="white" size="14" /></graphic>
                    </Button>
                </children>
            </HBox>

            <Button text="SALIR" onAction="#handleClose" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: 900; -fx-padding: 10 24; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" />
        </children>
    </HBox>

    <!-- Days Header (Light Grid) -->
    <GridPane hgap="0" vgap="0" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
        <columnConstraints>
            <ColumnConstraints percentWidth="14.28" halignment="CENTER" />
            <ColumnConstraints percentWidth="14.28" halignment="CENTER" />
            <ColumnConstraints percentWidth="14.28" halignment="CENTER" />
            <ColumnConstraints percentWidth="14.28" halignment="CENTER" />
            <ColumnConstraints percentWidth="14.28" halignment="CENTER" />
            <ColumnConstraints percentWidth="14.28" halignment="CENTER" />
            <ColumnConstraints percentWidth="14.28" halignment="CENTER" />
        </columnConstraints>
        <children>
            <Label text="LUNES" style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b; -fx-padding: 15;" GridPane.columnIndex="0" />
            <Label text="MARTES" style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b; -fx-padding: 15;" GridPane.columnIndex="1" />
            <Label text="MI&#x00c9;RCOLES" style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b; -fx-padding: 15;" GridPane.columnIndex="2" />
            <Label text="JUEVES" style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b; -fx-padding: 15;" GridPane.columnIndex="3" />
            <Label text="VIERNES" style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b; -fx-padding: 15;" GridPane.columnIndex="4" />
            <Label text="S&#x00c1B;ADO" style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #64748b; -fx-padding: 15;" GridPane.columnIndex="5" />
            <Label text="DOMINGO" style="-fx-font-weight: 800; -fx-font-size: 12px; -fx-text-fill: #1e293b; -fx-padding: 15;" GridPane.columnIndex="6" />
        </children>
    </GridPane>

    <!-- Calendar View -->
    <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #f1f5f9; -fx-border-width: 0; -fx-padding: 0;">
        <content>
            <GridPane fx:id="gridCalendar" hgap="1" vgap="1" style="-fx-background-color: #f1f5f9;">
                <!-- Content will be injected by the controller -->
            </GridPane>
        </content>
    </ScrollPane>

    <!-- Legend Footer -->
    <HBox spacing="30" style="-fx-padding: 20; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;" alignment="CENTER">
        <children>
            <HBox alignment="CENTER" spacing="10">
                <children>
                    <Region style="-fx-background-color: #d1fae5; -fx-min-width: 12; -fx-min-height: 12; -fx-background-radius: 4; -fx-border-color: #10b981; -fx-border-width: 1;" />
                    <Label text="Personal Asignado" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #475569;" />
                </children>
            </HBox>
            <HBox alignment="CENTER" spacing="10">
                <children>
                    <Region style="-fx-background-color: #fef2f2; -fx-min-width: 12; -fx-min-height: 12; -fx-background-radius: 4; -fx-border-color: #ef4444; -fx-border-width: 1;" />
                    <Label text="Festivo / Cerrado" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #475569;" />
                </children>
            </HBox>
            <HBox alignment="CENTER" spacing="10">
                <children>
                    <Region style="-fx-background-color: #e0f2fe; -fx-min-width: 12; -fx-min-height: 12; -fx-background-radius: 4; -fx-border-color: #0ea5e9; -fx-border-width: 1;" />
                    <Label text="Vacaciones" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #475569;" />
                </children>
            </HBox>
        </children>
    </HBox>

</VBox>
