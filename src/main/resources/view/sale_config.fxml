<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.SaleConfigController"
      styleClass="main-content-area" spacing="0">
        <VBox styleClass="view-header">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <StackPane styleClass="view-header-icon-wrap">
                    <FontAwesomeIconView glyphName="COG" size="24" fill="white"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="Configuración de Venta" styleClass="view-title"/>
                    <Label text="Ajusta los parámetros generales del punto de venta" styleClass="view-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Botón Guardar (cabecera) -->
                <Button fx:id="btnSaveTop" text="Guardar Cambios" onAction="#handleSave" styleClass="config-btn-save" defaultButton="true">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <FontAwesomeIconView glyphName="SAVE" size="14" fill="white"/>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="detail-scroll, edge-to-edge" VBox.vgrow="ALWAYS">
            <VBox spacing="20" style="-fx-padding: 30;">

                <!-- ─── FILA 1: Empresa + Fiscal ─── -->
                <HBox spacing="20">

                    <!-- Tarjeta: Datos de la Empresa -->
                    <VBox styleClass="config-card" HBox.hgrow="ALWAYS">
                        <!-- Cabecera tarjeta -->
                        <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="config-card-icon-wrap config-icon-blue">
                                <FontAwesomeIconView glyphName="BUILDING" size="16" fill="#1e88e5"/>
                            </StackPane>
                            <Label text="Datos de la Empresa" styleClass="config-card-title"/>
                        </HBox>
                        <Separator styleClass="config-card-separator"/>

                        <VBox spacing="14" styleClass="config-card-body">
                            <!-- Nombre empresa -->
                            <VBox styleClass="config-field-group">
                                <Label text="Nombre de la empresa" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="BRIEFCASE" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtCompanyName" promptText="Ej: Mi Tienda S.L."
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                            <!-- CIF/NIF -->
                            <VBox styleClass="config-field-group">
                                <Label text="CIF / NIF" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="ID_CARD" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtCif" promptText="Ej: B12345678"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                            <!-- Dirección -->
                            <VBox styleClass="config-field-group">
                                <Label text="Dirección" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="MAP_MARKER" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtAddress" promptText="Calle, Número, Ciudad"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                            <!-- Teléfono -->
                            <VBox styleClass="config-field-group">
                                <Label text="Teléfono de contacto" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="PHONE" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtPhone" promptText="Ej: +34 600 000 000"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                            <!-- Email empresa -->
                            <VBox styleClass="config-field-group">
                                <Label text="Email de la empresa" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="ENVELOPE" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtEmail" promptText="Ej: info@mitienda.com"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- Logo de la empresa -->
                            <VBox styleClass="config-field-group">
                                <Label text="Logo de la empresa (Tickets)" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container" spacing="10">
                                    <FontAwesomeIconView glyphName="IMAGE" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtLogoPath" promptText="Ruta del logo para los tickets"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field" editable="false"/>
                                    <Button text="Examinar..." onAction="#handleBrowseLogo" styleClass="btn-secondary"/>
                                </HBox>
                            </VBox>

                            <!-- Icono de la aplicación -->
                            <VBox styleClass="config-field-group">
                                <Label text="Icono de la aplicación (Ventana)" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container" spacing="10">
                                    <FontAwesomeIconView glyphName="DESKTOP" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtAppIconPath" promptText="Ruta del icono de la aplicación"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field" editable="false"/>
                                    <Button text="Examinar..." onAction="#handleBrowseIcon" styleClass="btn-secondary"/>
                                </HBox>
                            </VBox>

                            <!-- Nombre de la aplicación -->
                            <VBox styleClass="config-field-group">
                                <Label text="Nombre de la aplicación" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="WINDOW_MAXIMIZE" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtAppName" promptText="Ej: Mi Sistema TPV"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>

                    <!-- Tarjeta: Configuración Fiscal -->
                    <VBox styleClass="config-card" HBox.hgrow="ALWAYS" maxWidth="350">
                        <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="config-card-icon-wrap config-icon-orange">
                                <FontAwesomeIconView glyphName="BALANCE_SCALE" size="16" fill="#fb8c00"/>
                            </StackPane>
                            <Label text="Configuración Fiscal" styleClass="config-card-title"/>
                        </HBox>
                        <Separator styleClass="config-card-separator"/>

                        <VBox spacing="14" styleClass="config-card-body">
                            <!-- Impuestos incluidos -->
                            <VBox spacing="8">
                                <CheckBox fx:id="chkPricesIncludeTax" text="Los precios ya incluyen IVA"
                                          styleClass="config-checkbox"/>
                                <Label text="Marca esta opción si los precios que introduces en el catálogo ya tienen el IVA incluido." 
                                       styleClass="config-field-hint" wrapText="true"/>
                            </VBox>
                            
                            <Separator styleClass="config-card-separator" style="-fx-opacity: 0.3;"/>
                            
                            <VBox spacing="4">
                                <Label text="Referencia de IVA" styleClass="config-field-label"/>
                                <Label text="Tasa Global: 21.00%" styleClass="section-title" style="-fx-font-size: 15px;"/>
                                <Label text="Gestionable desde Administración > IVA" 
                                       styleClass="config-field-hint" wrapText="true"/>
                            </VBox>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- ─── FILA 3: Horarios ─── -->
                <HBox spacing="20">
                    <VBox styleClass="config-card" HBox.hgrow="ALWAYS" maxWidth="450">
                        <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="config-card-icon-wrap config-icon-purple">
                                <FontAwesomeIconView glyphName="CLOCK_ALT" size="16" fill="#7b1fa2"/>
                            </StackPane>
                            <Label text="Horarios del Establecimiento" styleClass="config-card-title"/>
                        </HBox>
                        <Separator styleClass="config-card-separator"/>
                        <VBox spacing="14" styleClass="config-card-body">
                            <Label text="Configura las horas de apertura y cierre semanales para comparativas en el monitor operativo." 
                                   styleClass="config-field-hint" wrapText="true"/>
                            <Button text="Gestionar Horarios Comerciales" onAction="#handleShowBusinessHours" 
                                    styleClass="btn-secondary-saas" maxWidth="Infinity">
                                <graphic>
                                    <FontAwesomeIconView glyphName="CALENDAR" size="14" />
                                </graphic>
                            </Button>
                        </VBox>
                    </VBox>
                </HBox>

                <!-- ─── FILA 2: Ticket ─── -->
                <HBox spacing="20">

                    <!-- Tarjeta: Ticket / Recibo -->
                    <VBox styleClass="config-card" HBox.hgrow="ALWAYS">
                        <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="config-card-icon-wrap config-icon-orange">
                                <FontAwesomeIconView glyphName="FILE_TEXT" size="16" fill="#fb8c00"/>
                            </StackPane>
                            <Label text="Ticket / Recibo" styleClass="config-card-title"/>
                        </HBox>
                        <Separator styleClass="config-card-separator"/>

                        <VBox spacing="14" styleClass="config-card-body">
                            <!-- Mostrar logo -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="config-check-row">
                                <CheckBox fx:id="chkShowLogo" text="Mostrar logo en el ticket"
                                          styleClass="config-checkbox"/>
                            </HBox>
                            <!-- Mostrar dirección -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="config-check-row">
                                <CheckBox fx:id="chkShowAddress" text="Mostrar dirección en el ticket"
                                          styleClass="config-checkbox"/>
                            </HBox>
                            <!-- Mostrar teléfono -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="config-check-row">
                                <CheckBox fx:id="chkShowPhone" text="Mostrar teléfono en el ticket"
                                          styleClass="config-checkbox"/>
                            </HBox>
                            <!-- Mostrar CIF -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="config-check-row">
                                <CheckBox fx:id="chkShowCif" text="Mostrar CIF/NIF en el ticket"
                                          styleClass="config-checkbox"/>
                            </HBox>

                            <!-- Mensaje pie de ticket -->
                            <VBox styleClass="config-field-group">
                                <Label text="Mensaje al pie del ticket" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="COMMENT" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtFooterMessage" promptText="Ej: ¡Gracias por su compra!"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- Número de copias -->
                            <VBox styleClass="config-field-group">
                                <Label text="Copias de ticket a imprimir" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="PRINT" size="14" styleClass="sidebar-icon"/>
                                    <ComboBox fx:id="cmbTicketCopies" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                              styleClass="modern-combo-box">
                                        <items>
                                            <FXCollections fx:factory="observableArrayList">
                                                <String fx:value="1 copia"/>
                                                <String fx:value="2 copias"/>
                                                <String fx:value="3 copias"/>
                                            </FXCollections>
                                        </items>
                                    </ComboBox>
                                </HBox>
                            </VBox>

                            <!-- Formato de ticket -->
                            <VBox styleClass="config-field-group">
                                <Label text="Formato de papel (Ancho)" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="ARROWS_H" size="14" styleClass="sidebar-icon"/>
                                    <ComboBox fx:id="cmbTicketFormat" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                              styleClass="modern-combo-box">
                                        <items>
                                            <FXCollections fx:factory="observableArrayList">
                                                <String fx:value="80mm (Estándar Térmico)"/>
                                                <String fx:value="58mm (Datáfono/Portátil)"/>
                                                <String fx:value="A4 (Folio)"/>
                                            </FXCollections>
                                        </items>
                                    </ComboBox>
                                </HBox>
                                <Label text="Ajusta el diseño al tamaño de tu impresora" styleClass="config-field-hint"/>
                            </VBox>

                            <!-- Imprimir automáticamente -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="config-check-row">
                                <CheckBox fx:id="chkAutoPrint" text="Imprimir ticket automáticamente tras cobro"
                                          styleClass="config-checkbox"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- Tarjeta: Configuración de Correo (SMTP) -->
                    <VBox styleClass="config-card" HBox.hgrow="ALWAYS">
                        <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="config-card-icon-wrap config-icon-blue">
                                <FontAwesomeIconView glyphName="ENVELOPE" size="16" fill="#1e88e5"/>
                            </StackPane>
                            <Label text="Servidor de Correo (SMTP)" styleClass="config-card-title"/>
                        </HBox>
                        <Separator styleClass="config-card-separator"/>

                        <VBox spacing="14" styleClass="config-card-body">
                            <!-- SMTP Host -->
                            <VBox styleClass="config-field-group">
                                <Label text="Servidor SMTP" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="SERVER" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtSmtpHost" promptText="Ej: smtp.gmail.com"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- SMTP Port -->
                            <VBox styleClass="config-field-group">
                                <Label text="Puerto" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="PLUG" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtSmtpPort" promptText="Ej: 587"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- Email From -->
                            <VBox styleClass="config-field-group">
                                <Label text="Correo emisor" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="AT" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtEmailFrom" promptText="Ej: mitienda@gmail.com"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- Email Password -->
                            <VBox styleClass="config-field-group">
                                <Label text="Contraseña de aplicación" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="KEY" size="14" styleClass="sidebar-icon"/>
                                    <PasswordField fx:id="txtEmailPassword" promptText="Contraseña"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>

                </HBox>


                <!-- ─── Botones de Acción finales ─── -->
                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button text="Restablecer valores" onAction="#handleReset" styleClass="config-btn-reset">
                        <graphic>
                            <HBox spacing="8" alignment="CENTER">
                                <FontAwesomeIconView glyphName="UNDO" size="13" fill="#757575"/>
                            </HBox>
                        </graphic>
                    </Button>
                    <Button text="Guardar Cambios" onAction="#handleSave" styleClass="config-btn-save" defaultButton="true">
                        <graphic>
                            <HBox spacing="8" alignment="CENTER">
                                <FontAwesomeIconView glyphName="CHECK" size="13" fill="white"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>

                <!-- Banner de confirmación -->
                <HBox fx:id="bannerSaved" styleClass="config-banner-success" alignment="CENTER_LEFT" spacing="12"
                      visible="false" managed="false">
                    <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="20" fill="#2e7d32"/>
                    <Label text="✔  Configuración guardada correctamente." styleClass="config-banner-text"/>
                </HBox>

            </VBox>
        </ScrollPane>
</VBox>
