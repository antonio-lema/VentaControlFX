<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.SellerReportController"
      styleClass="view-root" spacing="0">
    <stylesheets>
        <java.net.URL value="@/styles/components/informes.css" />
    </stylesheets>

    <!-- Header de la vista -->
    <HBox styleClass="view-header" alignment="CENTER_LEFT" spacing="16">
        <padding><Insets top="20" right="28" bottom="20" left="28"/></padding>
        <StackPane styleClass="view-header-icon">
            <FontAwesomeIconView glyphName="BAR_CHART" size="24" styleClass="view-header-icon-glyph"/>
        </StackPane>
        <VBox spacing="2">
            <Label text="Análisis de Ventas por Vendedor" styleClass="view-title"/>
            <Label text="Monitorización profesional de rendimiento y KPIs comerciales" styleClass="view-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        
        <!-- Botones de Exportación -->
        <HBox spacing="8" alignment="CENTER">
            <Button text="Excel" onAction="#handleExportExcel" styleClass="export-btn">
                <graphic><FontAwesomeIconView glyphName="FILE_EXCEL_ALT" size="14"/></graphic>
            </Button>
            <Button text="PDF" onAction="#handleExportPDF" styleClass="export-btn">
                <graphic><FontAwesomeIconView glyphName="FILE_PDF_ALT" size="14"/></graphic>
            </Button>
        </HBox>
    </HBox>

    <Separator/>

    <!-- Filtros Avanzados -->
    <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-background-color: -bg-subtle; -fx-padding: 12 28;">
        <Label text="Periodo:" styleClass="filter-label"/>
        <DatePicker fx:id="dpFrom" prefWidth="130" promptText="Desde"/>
        <DatePicker fx:id="dpTo" prefWidth="130" promptText="Hasta"/>
        
        <Separator orientation="VERTICAL" prefHeight="20"/>
        
        <Label text="Método Pago:" styleClass="filter-label"/>
        <ComboBox fx:id="cbPaymentMethod" prefWidth="120" promptText="Todos"/>
        
        <CheckBox fx:id="chkIncludeReturns" text="Incluir Devoluciones" style="-fx-font-size: 12px;"/>
        
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnFilter" text="Actualizar Análisis" styleClass="btn-primary" onAction="#handleFilter">
            <graphic><FontAwesomeIconView glyphName="REFRESH" fill="white"/></graphic>
        </Button>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <VBox spacing="20" style="-fx-padding: 20 28;">
            
            <!-- KPI Cards Row -->
            <HBox spacing="16">
                <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Ventas Totales" styleClass="kpi-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblTrendTotal" text="+0%" styleClass="trend-up"/>
                    </HBox>
                    <Label fx:id="lblKpiTotal" text="0.00 €" styleClass="kpi-value kpi-green"/>
                    <Label text="vs. periodo anterior" styleClass="filter-label" style="-fx-font-size: 10px;"/>
                </VBox>
                
                <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Nº Transacciones" styleClass="kpi-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblTrendCount" text="+0" styleClass="trend-blue"/>
                    </HBox>
                    <Label fx:id="lblKpiCount" text="0" styleClass="kpi-value kpi-blue"/>
                    <Label text="Ventas realizadas" styleClass="filter-label" style="-fx-font-size: 10px;"/>
                </VBox>
                
                <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <Label text="🏆 Mejor Vendedor" styleClass="kpi-label"/>
                    <Label fx:id="lblKpiBest" text="—" styleClass="kpi-value kpi-gold"/>
                    <Label fx:id="lblBestPerformance" text="0.00 € vendidos" styleClass="filter-label" style="-fx-font-size: 10px;"/>
                </VBox>
                
                <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                    <Label text="📊 Ticket Medio" styleClass="kpi-label"/>
                    <Label fx:id="lblKpiAvg" text="0.00 €" styleClass="kpi-value kpi-purple"/>
                    <Label text="Promedio por venta" styleClass="filter-label" style="-fx-font-size: 10px;"/>
                </VBox>
            </HBox>

            <!-- Middle Row: Charts & Ranking -->
            <HBox spacing="20">
                <!-- Gráfico de distribución -->
                <VBox styleClass="chart-container" HBox.hgrow="ALWAYS" prefHeight="300">
                    <Label text="Distribución de Ventas (%)" styleClass="section-title"/>
                    <PieChart fx:id="pieChartDistribution" legendSide="BOTTOM" labelsVisible="true" VBox.vgrow="ALWAYS"/>
                </VBox>
                
                <!-- Tabla de Ranking Avanzada -->
                <VBox spacing="10" prefWidth="450">
                    <Label text="Ranking de Rendimiento" styleClass="section-title"/>
                    <TableView fx:id="sellerTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="colRank" text="#" prefWidth="40" style="-fx-alignment: CENTER;"/>
                            <TableColumn fx:id="colSeller" text="Vendedor" prefWidth="150"/>
                            <TableColumn fx:id="colTotal" text="Total" prefWidth="90"/>
                            <TableColumn fx:id="colAvgTicket" text="Ticket M." prefWidth="80"/>
                            <TableColumn fx:id="colParticip" text="Part. %" prefWidth="70"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>

            <!-- Bottom Row: Payment Summary & Detail -->
            <HBox spacing="20">
                <!-- Resumen Pagos -->
                <VBox spacing="10" prefWidth="300" styleClass="chart-container">
                    <Label text="Resumen de Cobros" styleClass="section-title"/>
                    <VBox spacing="15" alignment="CENTER">
                        <VBox spacing="5" alignment="CENTER_LEFT">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <FontAwesomeIconView glyphName="MONEY" size="14" fill="#22c55e"/>
                                <Label text="Efectivo" style="-fx-font-weight: bold;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblCashTotal" text="0.00 €"/>
                            </HBox>
                            <ProgressBar fx:id="progressCash" progress="0.5" maxWidth="Infinity" style="-fx-accent: #22c55e;"/>
                        </VBox>
                        
                        <VBox spacing="5" alignment="CENTER_LEFT">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <FontAwesomeIconView glyphName="CREDIT_CARD" size="14" fill="#3b82f6"/>
                                <Label text="Tarjeta" style="-fx-font-weight: bold;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblCardTotal" text="0.00 €"/>
                            </HBox>
                            <ProgressBar fx:id="progressCard" progress="0.5" maxWidth="Infinity" style="-fx-accent: #3b82f6;"/>
                        </VBox>
                    </VBox>
                </VBox>

                <!-- Detalle de Ventas -->
                <VBox spacing="10" HBox.hgrow="ALWAYS" minHeight="300">
                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="lblDetailTitle" text="Detalle de Operaciones" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="txtDetailSearch" promptText="Buscar venta..." styleClass="search-field-inline"/>
                    </HBox>
                    <TableView fx:id="detailTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="colDate" text="Fecha" prefWidth="130"/>
                            <TableColumn fx:id="colMethod" text="Método" prefWidth="90"/>
                            <TableColumn fx:id="colClient" text="Cliente" prefWidth="130"/>
                            <TableColumn fx:id="colAmount" text="Importe" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
