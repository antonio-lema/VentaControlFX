<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.main.HeaderController"
      spacing="0" alignment="CENTER_LEFT" styleClass="top-bar">

    <!-- ====== BARRA DE B&#x00da;SQUEDA (izquierda) ====== -->
    <HBox fx:id="searchBarContainer" alignment="CENTER_LEFT" spacing="10" styleClass="search-bar"
          HBox.hgrow="ALWAYS" maxWidth="480">
        <FontAwesomeIconView glyphName="SEARCH" size="16" fill="#adb5bd"/>
        <TextField fx:id="searchField"
                   promptText="%header.search.prompt"
                   styleClass="search-field"
                   HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Separador flexible -->
    <Region HBox.hgrow="ALWAYS"/>

    <!-- ====== ZONA DERECHA: ALERTAS Y USUARIO ====== -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <padding>
            <Insets right="15"/>
        </padding>

        <!-- Botón de Alertas de Stock Premium -->
        <HBox fx:id="btnStockAlerts" alignment="CENTER" onMouseClicked="#handleShowStockAlerts" styleClass="header-alert-button" visible="false" managed="false">
            <StackPane>
                <FontAwesomeIconView glyphName="BELL" size="16" fill="#e53935"/>
                <Label fx:id="lblStockAlertCount" text="0" styleClass="header-alert-badge" StackPane.alignment="TOP_RIGHT">
                    <StackPane.margin><Insets top="-10" right="-12"/></StackPane.margin>
                </Label>
            </StackPane>
            <Label text="Stock Bajo" style="-fx-text-fill: #e53935; -fx-font-weight: 800; -fx-font-size: 11px;"/>
        </HBox>

        <!-- Men&#x00fa; de usuario -->
        <MenuButton fx:id="userMenuButton" styleClass="user-menu-button">
            <graphic>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <VBox alignment="CENTER_RIGHT" spacing="1">
                        <Label fx:id="lblHeaderUsername" text="Administrador" styleClass="label"/>
                        <Label text="%header.status.online" styleClass="label-muted user-status-online"/>
                    </VBox>
                    <StackPane>
                        <Circle radius="18" styleClass="user-avatar-circle"/>
                        <FontAwesomeIconView glyphName="USER" size="14" fill="white"/>
                    </StackPane>
                </HBox>
            </graphic>
            <items>
                <MenuItem fx:id="menuItemCashClosure" text="%header.user.close_cash" onAction="#handleCashClosure">
                    <graphic><FontAwesomeIconView glyphName="MONEY" size="14"/></graphic>
                </MenuItem>
                <SeparatorMenuItem />
                <MenuItem fx:id="menuItemLogout" text="%header.user.logout" onAction="#handleLogout">
                    <graphic><FontAwesomeIconView glyphName="SIGN_OUT" size="14" fill="#e53935"/></graphic>
                </MenuItem>
            </items>
        </MenuButton>

    </HBox>
</HBox>
