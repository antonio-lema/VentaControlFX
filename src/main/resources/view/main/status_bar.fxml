<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.StatusBarController"
      spacing="15" alignment="CENTER_RIGHT" styleClass="status-bar">
    <padding>
        <Insets top="5" right="20" bottom="5" left="20"/>
    </padding>
    <Label text="VentaControl Pro v1.0" styleClass="label-muted" style="-fx-font-size: 10px;"/>
    
    <HBox fx:id="badgeVerifactu" styleClass="status-badge" style="-fx-background-color: #34495e;">
        <StackPane styleClass="status-icon-bg-blue">
            <FontAwesomeIconView glyphName="CLOUD_UPLOAD" size="10" fill="#ffffff"/>
        </StackPane>
        <Label fx:id="lblVerifactuStatus" text="Sincronizando..." styleClass="status-badge-label" style="-fx-text-fill: white;"/>
    </HBox>

    <Region HBox.hgrow="ALWAYS"/>
    
    <HBox fx:id="cardCountProducts" styleClass="status-badge">
        <StackPane styleClass="status-icon-bg-blue">
            <FontAwesomeIconView glyphName="TAGS" size="10" fill="#ffffff"/>
        </StackPane>
        <Label text="%status.products" styleClass="status-badge-label"/>
        <Label fx:id="labelCountProducts" text="0" styleClass="status-badge-value"/>
    </HBox>
    
    <HBox fx:id="cardCountCategories" styleClass="status-badge">
        <StackPane styleClass="status-icon-bg-purple">
            <FontAwesomeIconView glyphName="LIST" size="10" fill="#ffffff"/>
        </StackPane>
        <Label text="%status.categories" styleClass="status-badge-label"/>
        <Label fx:id="labelCountCategories" text="0" styleClass="status-badge-value"/>
    </HBox>
    
    <HBox fx:id="cardCountHistory" styleClass="status-badge">
        <StackPane styleClass="status-icon-bg-orange">
            <FontAwesomeIconView glyphName="HISTORY" size="10" fill="#ffffff"/>
        </StackPane>
        <Label text="%status.sales_today" styleClass="status-badge-label"/>
        <Label fx:id="labelCountHistory" text="0" styleClass="status-badge-value"/>
    </HBox>
    
    <HBox fx:id="cardCountClients" styleClass="status-badge">
        <StackPane styleClass="status-icon-bg-green">
            <FontAwesomeIconView glyphName="USERS" size="10" fill="#ffffff"/>
        </StackPane>
        <Label text="%status.companies" styleClass="status-badge-label"/>
        <Label fx:id="labelCountClients" text="0" styleClass="status-badge-value"/>
    </HBox>
    
    <HBox fx:id="cardCountUsers" styleClass="status-badge">
        <StackPane styleClass="status-icon-bg-red">
            <FontAwesomeIconView glyphName="USER_CIRCLE" size="10" fill="#ffffff"/>
        </StackPane>
        <Label text="%status.users" styleClass="status-badge-label"/>
        <Label fx:id="labelCountUsers" text="0" styleClass="status-badge-value"/>
    </HBox>
    
    <HBox fx:id="cardCountClosures" styleClass="status-badge">
        <StackPane styleClass="status-icon-bg-teal">
            <FontAwesomeIconView glyphName="ARCHIVE" size="10" fill="#ffffff"/>
        </StackPane>
        <Label text="%status.closures" styleClass="status-badge-label"/>
        <Label fx:id="labelCountClosures" text="0" styleClass="status-badge-value"/>
    </HBox>
</HBox>
