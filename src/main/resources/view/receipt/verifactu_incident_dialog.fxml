<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox spacing="0.0" prefWidth="500.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);" 
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.receipt.VerifactuIncidentDialogController">
    
    <children>
        <!-- Header con estilo azul TPV -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #2980b9; -fx-background-radius: 15 15 0 0; -fx-padding: 20;">
            <children>
                <FontAwesomeIconView glyphName="EXCLAMATION_CIRCLE" size="24" fill="white" />
                <VBox spacing="2">
                    <children>
                        <Label text="Incidencia Técnica VeriFactu" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" />
                        <Label text="Protocolo de Seguridad AEAT" style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 11px;" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#handleCancel" style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic><FontAwesomeIconView glyphName="CLOSE" fill="white" size="16" /></graphic>
                </Button>
            </children>
        </HBox>

        <VBox spacing="25.0" style="-fx-padding: 30;">
            <children>
                <Label text="Se ha detectado un retraso en el envío de registros. Por normativa vigente, debe justificar brevemente la causa técnica del retraso." 
                       wrapText="true" style="-fx-text-fill: #34495e; -fx-font-size: 14px; -fx-line-spacing: 5;" />
                
                <VBox spacing="8.0">
                    <children>
                        <Label text="Motivo Principal" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-transform: uppercase;" />
                        <ComboBox fx:id="cmbReason" maxWidth="Infinity" promptText="Seleccione el motivo técnico..." 
                                  style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5;" />
                    </children>
                </VBox>

                <VBox spacing="8.0">
                    <children>
                        <Label text="Detalles de la Incidencia (Opcional)" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-transform: uppercase;" />
                        <TextArea fx:id="txtObservations" prefHeight="100.0" wrapText="true" promptText="Ej: Micro-corte de fibra óptica, mantenimiento del router..." 
                                  style="-fx-control-inner-background: #f8f9fa; -fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 8; -fx-background-radius: 8;" />
                    </children>
                </VBox>

                <HBox spacing="15.0" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <Button text="Omitir Aviso" onAction="#handleCancel" 
                                style="-fx-background-color: transparent; -fx-text-fill: #95a5a6; -fx-cursor: hand; -fx-font-weight: bold;" />
                        <Button text="Registrar Justificación" onAction="#handleSave" 
                                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 25; -fx-background-radius: 10; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(41,128,185,0.3), 10, 0, 0, 3);" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>
