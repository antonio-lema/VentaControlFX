<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.TicketDetailController" 
      spacing="0" prefWidth="450" prefHeight="650" styleClass="ticket-container">
    
    <stylesheets>
        <URL value="@/styles/variables.css" />
        <URL value="@/styles/components/botones.css" />
        <URL value="@/styles/components/ticket.css" />
    </stylesheets>

    <!-- Modal Header (In-app style) -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="ticket-modal-header">
        <StackPane styleClass="ticket-icon-bg">
            <FontAwesomeIconView glyphName="TICKET" fill="white" size="18"/>
        </StackPane>
        <VBox spacing="2">
            <Label fx:id="lblTicketId" text="Ticket #0000" styleClass="ticket-title-label"/>
            <Label fx:id="lblDate" text="01/01/2026 00:00" styleClass="ticket-subtitle-label"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button onAction="#handleClose" styleClass="btn-icon-transparent">
            <graphic><FontAwesomeIconView glyphName="CLOSE" size="18" styleClass="icon-muted"/></graphic>
        </Button>
    </HBox>

    <!-- Receipt Content (Thermal Paper Look) -->
    <ScrollPane fitToWidth="true" styleClass="ticket-scroll-pane" VBox.vgrow="ALWAYS">
        <content>
            <VBox spacing="0" alignment="TOP_CENTER" styleClass="receipt-paper">
                <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>
                
                <!-- Business Info -->
                <VBox alignment="CENTER" spacing="5">
                    <Label text="VENTA CONTROL" styleClass="receipt-brand"/>
                    <Label text="Software de Gesti&#x00f3;n TPV" styleClass="receipt-small"/>
                    <Label text="Calle Principal 123, Madrid" styleClass="receipt-small"/>
                    <Label text="NIF: B12345678" styleClass="receipt-small"/>
                </VBox>

                <Separator styleClass="receipt-divider-dash">
                    <padding><Insets top="20" bottom="20"/></padding>
                </Separator>

                <!-- Customer Info -->
                <GridPane hgap="10" vgap="5">
                    <Label text="CLIENTE:" styleClass="receipt-label-bold" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="lblClient" text="Consumidor Final" styleClass="receipt-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    
                    <Label text="VENDEDOR:" styleClass="receipt-label-bold" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="lblUser" text="Admin" styleClass="receipt-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                </GridPane>

                <Separator styleClass="receipt-divider-dash">
                    <padding><Insets top="20" bottom="20"/></padding>
                </Separator>

                <!-- Status Badge (Optional) -->
                <Label fx:id="lblReturnBadge" text="[ DEVOLUCI&#x00d3;N REGISTRADA ]" visible="false" managed="false" 
                       styleClass="receipt-return-badge"/>

                <!-- Items Table Header -->
                <HBox spacing="10" style="-fx-padding: 0 0 10 0;">
                    <Label text="DESCRIPCI&#x00d3;N" styleClass="receipt-col-header" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Label text="UDS" styleClass="receipt-col-header" prefWidth="40" alignment="CENTER"/>
                    <Label text="TOTAL" styleClass="receipt-col-header" prefWidth="80" alignment="CENTER_RIGHT"/>
                </HBox>
                
                <!-- Items list -->
                <VBox fx:id="itemsContainer" spacing="12" VBox.vgrow="ALWAYS" />

                <Separator styleClass="receipt-divider-heavy">
                    <padding><Insets top="25" bottom="15"/></padding>
                </Separator>

                <!-- Financial Summary -->
                <VBox spacing="6">
                    <HBox alignment="CENTER_RIGHT" spacing="20">
                        <Label text="Subtotal:" styleClass="receipt-summary-label"/>
                        <Label fx:id="lblSubtotal" text="0,00 &#x20ac;" styleClass="receipt-summary-value" prefWidth="100" alignment="CENTER_RIGHT"/>
                    </HBox>
                    <HBox alignment="CENTER_RIGHT" spacing="20">
                        <Label text="Impuestos (IVA):" styleClass="receipt-summary-label"/>
                        <Label fx:id="lblIva" text="0,00 &#x20ac;" styleClass="receipt-summary-value" prefWidth="100" alignment="CENTER_RIGHT"/>
                    </HBox>
                    <HBox alignment="CENTER_RIGHT" spacing="20" style="-fx-padding: 10 0 0 0;">
                        <Label text="TOTAL TICKET:" styleClass="receipt-total-label"/>
                        <Label fx:id="lblTotal" text="0,00 &#x20ac;" styleClass="receipt-total-value" prefWidth="120" alignment="CENTER_RIGHT"/>
                    </HBox>
                </VBox>

                <!-- Tax Breakdown (V2) -->
                <VBox fx:id="taxDetailsContainer" spacing="4" style="-fx-padding: 15 0 0 0;">
                    <!-- Dynamically populated -->
                </VBox>

                <Separator styleClass="receipt-divider-dash">
                    <padding><Insets top="25" bottom="20"/></padding>
                </Separator>

                <!-- Footer info -->
                <VBox alignment="CENTER" spacing="4">
                    <Label text="Forma de Pago:" styleClass="receipt-small"/>
                    <Label fx:id="lblPayment" text="EFECTIVO" styleClass="receipt-value-bold"/>
                    <Label text="&#x00a1;Gracias por su compra!" styleClass="receipt-thank-you">
                        <padding><Insets top="20"/></padding>
                    </Label>
                </VBox>

            </VBox>
        </content>
    </ScrollPane>

    <!-- Modal Actions -->
    <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="ticket-modal-footer">
        <Button fx:id="btnPrint" text="IMPRIMIR" onAction="#handlePrint" styleClass="btn-primary">
            <graphic><FontAwesomeIconView glyphName="PRINT" fill="white"/></graphic>
        </Button>
        <Button text="CERRAR" onAction="#handleClose" styleClass="btn-secondary"/>
    </HBox>

</VBox>
