<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<StackPane styleClass="lock-screen-root" style="-fx-background-color: white;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.controller.LoginController">
    <VBox alignment="CENTER" spacing="20" styleClass="lock-screen-glass" maxWidth="380" maxHeight="-Infinity">
        <padding>
            <Insets bottom="40" left="40" right="40" top="40" />
        </padding>

        <!-- User Avatar -->
        <StackPane>
            <Circle radius="45" styleClass="user-avatar-circle" fill="#f5f5f5"/>
            <FontAwesomeIconView glyphName="USER" size="35" fill="#909090"/>
        </StackPane>

        <VBox alignment="CENTER" spacing="5">
            <Label text="Bienvenido a VentaControl" styleClass="lock-title"/>
            <Label text="Inicia sesión para continuar" styleClass="lock-username"/>
        </VBox>

        <VBox spacing="8" maxWidth="300" alignment="CENTER_LEFT" style="-fx-padding: 20 0 10 0;">
            <Label text="Usuario" styleClass="lock-input-label"/>
            <TextField fx:id="txtUsername" promptText="Introduce tu usuario" styleClass="lock-field"/>
            
            <Label text="Contraseña" styleClass="lock-input-label"/>
            <PasswordField fx:id="txtPassword" promptText="Introduce tu contraseña" styleClass="lock-field" onAction="#handleLogin"/>
        </VBox>

        <Label fx:id="lblMessage" text="" styleClass="error-label" wrapText="true"/>

        <Button fx:id="btnLogin" text="INICIAR SESIÓN" onAction="#handleLogin" styleClass="btn-unlock" maxWidth="300" prefHeight="45" defaultButton="true"/>
        
        <Button text="¿Olvidaste tu contraseña?" onAction="#handleForgotPassword" styleClass="btn-change-user" maxWidth="200"/>

    </VBox>
</StackPane>
