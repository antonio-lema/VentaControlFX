<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ReturnListController" 
      spacing="0" styleClass="main-content-area">
    <stylesheets>
        <java.net.URL value="@/styles/components/historial.css" />
        <java.net.URL value="@/styles/components/filters.css" />
        <java.net.URL value="@/styles/components/informes.css" />
    </stylesheets>

    <!-- Header Section -->
    <VBox styleClass="view-header" spacing="0">
        <children>
            <HBox spacing="16" alignment="CENTER_LEFT">
                <children>
                    <StackPane styleClass="view-header-icon-wrap">
                        <children><FontAwesomeIconView glyphName="HISTORY" size="22" fill="white"/></children>
                    </StackPane>
                    <VBox spacing="2">
                        <children>
                            <Label text="%returns.list.title" styleClass="view-title"/>
                            <Label text="%returns.list.subtitle" styleClass="view-subtitle"/>
                        </children>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button fx:id="btnRefresh" onAction="#loadReturns" styleClass="btn-secondary" text="%returns.btn.refresh">
                            <graphic><FontAwesomeIconView glyphName="REFRESH" size="14"/></graphic>
                        </Button>
                    </HBox>
                </children>
            </HBox>
        </children>
    </VBox>

    <!-- Body Content Section with Standard Padding -->
    <VBox spacing="25" VBox.vgrow="ALWAYS" style="-fx-padding: 30;">
        <!-- KPI Row SaaS Style -->
        <HBox spacing="20" alignment="CENTER">
            <children>
                <!-- Card Blue: Total Count -->
                <VBox styleClass="kpi-card-saas, kpi-card-blue" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="icon-bg-blue"><FontAwesomeIconView glyphName="FILE_TEXT_O" fill="#1e88e5" size="16"/></StackPane>
                            <Label text="TOTAL DEVOLUCIONES" styleClass="kpi-label-saas" />
                        </HBox>
                        <Label fx:id="lblKpiCount" text="0" styleClass="kpi-value-saas" />
                        <Label text="Operaciones en el periodo" styleClass="trend-text" />
                    </children>
                </VBox>

                <!-- Card Red: Total Amount -->
                <VBox styleClass="kpi-card-saas, kpi-card-red" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="icon-bg-red"><FontAwesomeIconView glyphName="EXCLAMATION_TRIANGLE" fill="#ef4444" size="16"/></StackPane>
                            <Label text="TOTAL REEMBOLSADO" styleClass="kpi-label-saas" />
                        </HBox>
                        <Label fx:id="lblKpiTotal" text="0.00 €" styleClass="kpi-value-saas" />
                        <Label text="Suma de abonos detectados" styleClass="trend-text" />
                    </children>
                </VBox>

                <!-- Card Gold: Average -->
                <VBox styleClass="kpi-card-saas, kpi-card-gold" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="icon-bg-gold"><FontAwesomeIconView glyphName="BAR_CHART" fill="#f59e0b" size="16"/></StackPane>
                            <Label text="TICKET MEDIO" styleClass="kpi-label-saas" />
                        </HBox>
                        <Label fx:id="lblKpiAverage" text="0.00 €" styleClass="kpi-value-saas" />
                        <Label text="Promedio por devolución" styleClass="trend-text" />
                    </children>
                </VBox>

                <!-- Card Green: Last Activity -->
                <VBox styleClass="kpi-card-saas, kpi-card-green" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="icon-bg-green"><FontAwesomeIconView glyphName="CLOCK_O" fill="#10b981" size="16"/></StackPane>
                            <Label text="ACTIVIDAD RECIENTE" styleClass="kpi-label-saas" />
                        </HBox>
                        <Label fx:id="lblKpiLast" text="--" styleClass="kpi-value-saas" />
                        <Label text="Fecha de última gestión" styleClass="trend-text" />
                    </children>
                </VBox>
            </children>
        </HBox>
        <!-- Filters Section -->
        <HBox spacing="15" alignment="CENTER_LEFT" styleClass="filter-card">
        <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
        
        <VBox spacing="5">
            <Label text="%returns.filter.start" styleClass="filter-label-cap"/>
            <DatePicker fx:id="datePickerStart" prefWidth="150" styleClass="modern-datepicker"/>
        </VBox>
        
        <VBox spacing="5">
            <Label text="%returns.filter.end" styleClass="filter-label-cap"/>
            <DatePicker fx:id="datePickerEnd" prefWidth="150" styleClass="modern-datepicker"/>
        </VBox>

        <VBox spacing="5">
            <Label text="%returns.filter.payment" styleClass="filter-label-cap"/>
            <ComboBox fx:id="cmbPaymentMethod" prefWidth="120" promptText="%returns.filter.all" styleClass="modern-combobox"/>
        </VBox>

        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="%returns.filter.search.label" styleClass="filter-label-cap"/>
            <TextField fx:id="txtSearch" promptText="%returns.filter.search.prompt" styleClass="modern-textfield"/>
        </VBox>

        <VBox spacing="5" alignment="BOTTOM_LEFT">
             <Button text="%returns.btn.clear" onAction="#handleClearFilters" styleClass="btn-modern-clear">
                 <graphic><FontAwesomeIconView glyphName="ERASER" size="12"/></graphic>
             </Button>
        </VBox>
        
        <HBox fx:id="quickFilterContainer" spacing="8" alignment="BOTTOM_LEFT" styleClass="date-filter-container" />
    </HBox>

    <!-- Table Section with Side Panel -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox HBox.hgrow="ALWAYS" styleClass="table-card">
            <TableView fx:id="returnsTable" VBox.vgrow="ALWAYS" styleClass="modern-table-view">
                <placeholder>
                    <VBox alignment="CENTER" spacing="10">
                        <FontAwesomeIconView glyphName="SEARCH" size="40" fill="#cbd5e1"/>
                        <Label text="%returns.table.empty" styleClass="label-muted"/>
                    </VBox>
                </placeholder>
                <columns>
                    <TableColumn fx:id="colId" text="%returns.table.id" prefWidth="60" styleClass="column-center"/>
                    <TableColumn fx:id="colSaleId" text="%returns.table.ticket" prefWidth="80" styleClass="column-center"/>
                    <TableColumn fx:id="colActions" text="%returns.table.actions" prefWidth="80" styleClass="column-center"/>
                    <TableColumn fx:id="colDate" text="%returns.table.datetime" prefWidth="180"/>
                    <TableColumn fx:id="colUser" text="%returns.table.user" prefWidth="120"/>
                    <TableColumn fx:id="colAmount" text="%returns.table.refund" prefWidth="120" styleClass="column-right"/>
                    <TableColumn fx:id="colReason" text="%returns.table.reason" prefWidth="250"/>
                    <TableColumn fx:id="colClosure" text="%returns.table.closure" prefWidth="80" styleClass="column-center"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
            
            <!-- Summary Footer -->
            <HBox alignment="CENTER_RIGHT" spacing="20" styleClass="table-footer">
                <padding><Insets top="15" right="20" bottom="15" left="20"/></padding>
                <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblCount" text="0 registros" styleClass="label-muted"/>
                </HBox>
                <Label text="%returns.footer.total_refunded" styleClass="footer-label"/>
                <Label fx:id="lblTotalRefunded" text="0,00 &#x20ac;" styleClass="footer-value-danger"/>
            </HBox>
        </VBox>

        <!-- Details Panel Section -->
        <VBox fx:id="detailsPanel" prefWidth="380.0" visible="false" managed="false" styleClass="detail-panel">
            <HBox prefHeight="6.0" styleClass="detail-panel-accent" />
            <VBox spacing="15.0" styleClass="detail-panel-body" VBox.vgrow="ALWAYS">
                <VBox alignment="CENTER" spacing="5">
                    <Label text="%returns.detail.title" styleClass="filter-label-cap" />
                    <HBox spacing="10" alignment="CENTER">
                        <Label fx:id="lblDetailReturnId" text="Devoluci&#x00f3;n #0000" styleClass="detail-sale-id" />
                        <Label fx:id="lblDetailSaleId" text="Ticket #0000" styleClass="badge-primary" />
                    </HBox>
                    <Label fx:id="lblDetailDate" text="18/02/2026 15:30" styleClass="label-muted" />
                </VBox>

                <Separator />

                <Label text="%returns.detail.items_title" styleClass="filter-label-cap" />
                <ScrollPane fitToWidth="true" styleClass="detail-scroll" prefHeight="300.0" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox fx:id="detailsItemsContainer" spacing="12.0" styleClass="detail-items-container" />
                    </content>
                </ScrollPane>

                <Separator />

                <VBox spacing="8.0">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="%returns.detail.reason_label" styleClass="label-muted" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblDetailReason" text="Motivo" styleClass="detail-info-value" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT">
                        <Label text="%returns.detail.user_label" styleClass="label-muted" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblDetailUser" text="Usuario" styleClass="detail-info-value" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                        <Label text="%returns.detail.total_label" styleClass="detail-total-label" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblDetailTotal" text="0,00 &#x20ac;" styleClass="detail-total-value text-danger" />
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />
                
                <VBox spacing="10">
                    <Button onAction="#handleReprint" text="%returns.detail.btn.reprint" maxWidth="Infinity" styleClass="btn-primary">
                        <graphic><FontAwesomeIconView glyphName="PRINT" size="14"/></graphic>
                    </Button>
                    <Button onAction="#handleViewOriginalTicket" text="%returns.detail.btn.view_original" maxWidth="Infinity" styleClass="btn-secondary">
                        <graphic><FontAwesomeIconView glyphName="TICKET" size="14"/></graphic>
                    </Button>
                    <Button onAction="#handleCloseDetails" text="%returns.detail.btn.close" maxWidth="Infinity" styleClass="btn-history-close" />
                </VBox>
            </VBox>
        </VBox>
    </HBox>
    </VBox>
</VBox>