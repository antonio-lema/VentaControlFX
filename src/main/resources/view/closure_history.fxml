<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<AnchorPane id="AnchorPane" prefHeight="750.0" prefWidth="1100.0" styleClass="main-content-area"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ClosureHistoryController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="10.0" left="25.0" right="25.0" top="25.0" />
         </padding>
         <children>
            <!-- Header Section -->
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <VBox>
                     <children>
                        <Label text="📂 Historial de Cierres de Caja" styleClass="section-title"/>
                        <Label text="Consulta el historial de cierres realizados" styleClass="section-subtitle"/>
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />

                  <!-- Filter Card -->
                  <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="filter-card">
                     <children>
                        <VBox spacing="2">
                           <children>
                              <Label text="DESDE" styleClass="filter-label-cap" />
                              <DatePicker fx:id="datePickerStart" onAction="#loadClosures" prefWidth="130.0" styleClass="filter-datepicker" />
                           </children>
                        </VBox>
                        <Separator orientation="VERTICAL" prefHeight="30" />
                        <VBox spacing="2">
                           <children>
                              <Label text="HASTA" styleClass="filter-label-cap" />
                              <DatePicker fx:id="datePickerEnd" onAction="#loadClosures" prefWidth="130.0" styleClass="filter-datepicker" />
                           </children>
                        </VBox>
                        <Separator orientation="VERTICAL" prefHeight="30" />
                        <Button onAction="#loadClosures" styleClass="btn-primary" text="Filtrar">
                           <graphic><FontAwesomeIconView glyphName="SEARCH" fill="WHITE" /></graphic>
                        </Button>
                        <Button onAction="#handleClearFilters" styleClass="btn-secondary" text="Limpiar">
                           <graphic><FontAwesomeIconView glyphName="ERASER" styleClass="sidebar-icon" /></graphic>
                        </Button>
                     </children>
                  </HBox>
               </children>
            </HBox>

            <!-- Summary Cards -->
            <HBox spacing="20.0">
               <children>
                  <VBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <StackPane styleClass="stat-icon-bg stat-icon-bg-blue">
                                 <children><FontAwesomeIconView glyphName="BOOK" size="22" fill="white" /></children>
                              </StackPane>
                              <Label text="📊 Total Cierres" styleClass="stat-label" />
                           </children>
                        </HBox>
                        <Label fx:id="lblTotalClosures" text="0" styleClass="stat-value, text-info" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <StackPane styleClass="stat-icon-bg stat-icon-bg-green">
                                 <children><FontAwesomeIconView glyphName="MONEY" size="22" fill="white" /></children>
                              </StackPane>
                              <Label text="💵 Efectivo Total" styleClass="stat-label" />
                           </children>
                        </HBox>
                        <Label fx:id="lblTotalCash" text="0.00 €" styleClass="stat-value, text-cash" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="5.0" styleClass="stat-card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <StackPane styleClass="stat-icon-bg stat-icon-bg-purple">
                                 <children><FontAwesomeIconView glyphName="CREDIT_CARD" size="22" fill="white" /></children>
                              </StackPane>
                              <Label text="💳 Tarjeta Total" styleClass="stat-label" />
                           </children>
                        </HBox>
                        <Label fx:id="lblTotalCard" text="0.00 €" styleClass="stat-value, text-card" />
                     </children>
                  </VBox>
                  <!-- Highlighted total card -->
                  <VBox alignment="CENTER_LEFT" prefWidth="200.0" spacing="5.0"
                        styleClass="stat-card stat-card-highlight" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <StackPane styleClass="stat-icon-bg stat-icon-bg-white">
                                 <children><FontAwesomeIconView glyphName="EURO" size="22" fill="white" /></children>
                              </StackPane>
                              <Label text="💰 VENTAS TOTALES" styleClass="stat-label-light" />
                           </children>
                        </HBox>
                        <Label fx:id="lblTotalRevenue" text="0.00 €" styleClass="stat-value-light" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <!-- Main Content Area -->
            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <!-- Table Section -->
                  <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="table-card">
                     <children>
                        <TableView fx:id="tableClosures" VBox.vgrow="ALWAYS" styleClass="modern-table-view">
                          <columns>
                            <TableColumn fx:id="colId" prefWidth="80.0" text="ID CIERRE" />
                            <TableColumn fx:id="colDate" prefWidth="120.0" text="FECHA CIERRE" />
                            <TableColumn fx:id="colCreated" prefWidth="180.0" text="REALIZADO EL" />
                            <TableColumn fx:id="colUser" prefWidth="150.0" text="USUARIO" />
                            <TableColumn fx:id="colCash" prefWidth="120.0" text="EFECTIVO" />
                            <TableColumn fx:id="colCard" prefWidth="120.0" text="TARJETA" />
                            <TableColumn fx:id="colTotal" prefWidth="120.0" text="TOTAL" />
                            <TableColumn fx:id="colActions" prefWidth="80.0" text="ACCIONES" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT" prefHeight="30.0" spacing="10.0">
                           <children>
                              <Label fx:id="lblCount" text="0 cierres encontrados" styleClass="label-muted" style="-fx-font-weight: bold;" />
                           </children>
                           <padding>
                              <Insets right="10.0" />
                           </padding>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- Details Side Panel -->
                  <VBox fx:id="detailsPanel" prefWidth="380.0" visible="false" managed="false"
                        styleClass="detail-panel">
                     <children>
                        <HBox prefHeight="6.0" styleClass="detail-panel-accent" />
                        <VBox spacing="20.0" styleClass="detail-panel-body">
                           <children>
                              <VBox alignment="CENTER" spacing="5">
                                 <children>
                                    <Label text="RESUMEN DE PRODUCTOS" styleClass="filter-label-cap" />
                                    <Label fx:id="lblClosureDetailId" text="Cierre #0000" styleClass="detail-sale-id" />
                                    <Label fx:id="lblClosureDetailDate" text="18/02/2026" styleClass="label-muted" />
                                 </children>
                              </VBox>

                              <Separator />

                              <TableView fx:id="tableProductSummary" prefHeight="400.0" styleClass="modern-table-view">
                                 <columns>
                                    <TableColumn fx:id="colProdName" prefWidth="180.0" text="PRODUCTO" />
                                    <TableColumn fx:id="colProdQty" prefWidth="70.0" text="CANT." />
                                    <TableColumn fx:id="colProdTotal" prefWidth="90.0" text="TOTAL" />
                                 </columns>
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                              </TableView>

                              <Region VBox.vgrow="ALWAYS" />
                              <Button onAction="#handleCloseDetails" maxWidth="Infinity"
                                      styleClass="btn-secondary btn-lg" text="CERRAR DETALLES" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
