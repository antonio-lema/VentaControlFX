<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.shape.Circle?>
<?import java.net.URL?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" styleClass="main-content-area"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ClosureHistoryController">
    <children>
        <VBox spacing="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            
            <!-- HEADER SECTION -->
            <VBox styleClass="view-header" spacing="0">
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <children>
                            <StackPane styleClass="view-header-icon-wrap">
                                <children>
                                    <FontAwesomeIconView glyphName="SHIELD" size="24" fill="white" />
                                </children>
                            </StackPane>
                            <VBox spacing="2">
                                <children>
                                    <Label text="%closure_history.title" styleClass="view-title" />
                                    <Label text="%closure_history.subtitle" styleClass="view-subtitle" />
                                </children>
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="search-box-saas">
                                <padding><Insets left="15" right="15"/></padding>
                                <children>
                                    <FontAwesomeIconView glyphName="CALENDAR" fill="#94a3b8" size="14" />
                                    <DatePicker fx:id="datePickerStart" onAction="#loadClosures" promptText="%closure_history.filter.from" prefWidth="145"/>
                                    <Label text="\u2014" textFill="#94a3b8"/>
                                    <DatePicker fx:id="datePickerEnd" onAction="#loadClosures" promptText="%closure_history.filter.to" prefWidth="145"/>
                                </children>
                            </HBox>
                            
                             <HBox fx:id="quickFilterContainer" alignment="CENTER_LEFT" spacing="8" styleClass="date-filter-container" />
                            
                            <Button onAction="#loadClosures" styleClass="btn-primary" text="%closure_history.btn.refresh">
                                <graphic><FontAwesomeIconView glyphName="REFRESH" fill="WHITE" /></graphic>
                            </Button>
                            <Button onAction="#handleMarkAllReviewed" styleClass="btn-secondary" text="%closure_history.btn.review_all">
                                <graphic><FontAwesomeIconView glyphName="CHECK_SQUARE_ALT" /></graphic>
                            </Button>
                        </children>
                    </HBox>
                </children>
            </VBox>

            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: -fx-bg-main;" VBox.vgrow="ALWAYS">
                <content>
                    <VBox spacing="25.0">
                        <padding><Insets bottom="30.0" left="30.0" right="30.0" top="25.0" /></padding>
                        <children>
                            
                            <!-- KPI ROW -->
                            <HBox spacing="20.0">
                                <children>
                                    <VBox styleClass="kpi-card-saas, kpi-card-blue" HBox.hgrow="ALWAYS">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <StackPane styleClass="icon-bg-blue"><FontAwesomeIconView glyphName="LIST_ALT" fill="#2563eb" size="16"/></StackPane>
                                                <Label text="%closure_history.kpi.total_count" styleClass="kpi-label-saas" />
                                            </HBox>
                                            <Label fx:id="lblTotalClosures" text="0" styleClass="kpi-value-saas" />
                                            <Label text="%closure_history.kpi.desc.period" styleClass="trend-text" />
                                        </children>
                                    </VBox>
                                    
                                    <VBox styleClass="kpi-card-saas, kpi-card-red" HBox.hgrow="ALWAYS">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <StackPane styleClass="icon-bg-red"><FontAwesomeIconView glyphName="EXCLAMATION_TRIANGLE" fill="#dc2626" size="16"/></StackPane>
                                                <Label text="%closure_history.kpi.total_difference" styleClass="kpi-label-saas" />
                                            </HBox>
                                            <Label fx:id="lblTotalDifference" text="0.00 \u20ac" styleClass="kpi-value-saas" style="-fx-text-fill: #dc2626;" />
                                            <Label text="%closure_history.kpi.desc.difference" styleClass="trend-text" />
                                        </children>
                                    </VBox>
                                    
                                    <VBox styleClass="kpi-card-saas, kpi-card-gold" HBox.hgrow="ALWAYS">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <StackPane styleClass="icon-bg-gold"><FontAwesomeIconView glyphName="EYE" fill="#d97706" size="16"/></StackPane>
                                                <Label text="%closure_history.kpi.pending_review" styleClass="kpi-label-saas" />
                                            </HBox>
                                            <Label fx:id="lblPendingReview" text="0" styleClass="kpi-value-saas" />
                                            <Label text="%closure_history.kpi.desc.pending" styleClass="trend-text" />
                                        </children>
                                    </VBox>
                                    
                                    <VBox styleClass="kpi-card-saas, kpi-card-green" HBox.hgrow="ALWAYS">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <StackPane styleClass="icon-bg-green"><FontAwesomeIconView glyphName="MONEY" fill="#16a34a" size="16"/></StackPane>
                                                <Label text="%closure_history.kpi.current_cash" styleClass="kpi-label-saas" />
                                            </HBox>
                                            <Label fx:id="lblCurrentCash" text="0.00 \u20ac" styleClass="kpi-value-saas" style="-fx-text-fill: #16a34a;" />
                                            <Label text="%closure_history.kpi.desc.theoretical" styleClass="trend-text" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                            
                            <!-- MAIN CONTENT: TABLE + DETAIL -->
                            <HBox spacing="25.0">
                                <children>
                                    <!-- TABLE SECTION -->
                                    <VBox spacing="15" HBox.hgrow="ALWAYS" styleClass="widget-panel">
                                        <children>
                                            <HBox alignment="CENTER_LEFT" spacing="15">
                                                <children>
                                                    <Label text="%closure_history.list.title" styleClass="widget-title" />
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Button onAction="#handleMarkAllReviewed" text="%closure_history.btn.review_all" styleClass="btn-secondary-saas"/>
                                                    <ComboBox fx:id="cmbStatusFilter" promptText="%closure_history.table.status" styleClass="btn-secondary-saas" />
                                                </children>
                                            </HBox>
                                            
                                            <TableView fx:id="tableClosures" VBox.vgrow="ALWAYS" styleClass="table-saas" prefHeight="500">
                                                <columns>
                                                    <TableColumn fx:id="colStatus" prefWidth="100.0" text="%closure_history.table.status" />
                                                    <TableColumn fx:id="colCreated" prefWidth="160.0" text="%closure_history.table.date" />
                                                    <TableColumn fx:id="colUser" prefWidth="130.0" text="%closure_history.table.user" />
                                                    <TableColumn fx:id="colInitialFund" prefWidth="100.0" text="%closure_history.table.initial" />
                                                    <TableColumn fx:id="colExpected" prefWidth="110.0" text="%closure_history.table.expected" />
                                                    <TableColumn fx:id="colActual" prefWidth="110.0" text="%closure_history.table.count" />
                                                    <TableColumn fx:id="colDifference" prefWidth="100.0" text="%closure_history.table.difference" />
                                                </columns>
                                                <columnResizePolicy>
                                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                                </columnResizePolicy>
                                            </TableView>
                                            
                                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="row-limit-container">
                                                <children>
                                                    <Label text="%products.show_limit" styleClass="label-limit" />
                                                    <ComboBox fx:id="cmbRowLimit" prefWidth="90" styleClass="combo-limit" />
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Label fx:id="lblCount" text="0 registros" styleClass="trend-text" />
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>
                                    
                                    <!-- DETAIL AUDIT PANEL -->
                                    <VBox fx:id="detailsPanel" prefWidth="450.0" minWidth="420.0" spacing="20" visible="false" managed="false" styleClass="widget-panel" style="-fx-border-color: #1e88e5; -fx-border-width: 0 0 0 4; -fx-padding: 20; -fx-background-color: -fx-bg-surface;">
                                        <children>
                                            <!-- CABECERA -->
                                            <HBox alignment="CENTER_LEFT" spacing="10">
                                                <children>
                                                    <Label fx:id="lblClosureDetailId" text="CIERRE #000" styleClass="widget-title" />
                                                    <Region HBox.hgrow="ALWAYS" />
                                                    <Button onAction="#handleCloseDetails" style="-fx-background-color: transparent; -fx-cursor: hand;">
                                                        <graphic><FontAwesomeIconView glyphName="CLOSE" fill="#64748b" size="18"/></graphic>
                                                    </Button>
                                                </children>
                                            </HBox>
                                            <Separator />
                                            
                                            <!-- DESGLOSE -->
                                            <VBox spacing="10" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;">
                                                <children>
                                                    <Label text="%closure_history.detail.summary" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: -fx-text-custom-main;" />
                                                    <GridPane vgap="10" hgap="15">
                                                        <columnConstraints>
                                                            <ColumnConstraints hgrow="ALWAYS" />
                                                            <ColumnConstraints halignment="RIGHT" minWidth="80"/>
                                                        </columnConstraints>
                                                        <children>
                                                            <Label text="%closure_history.detail.initial_decl" GridPane.rowIndex="0" styleClass="trend-text"/>
                                                            <Label fx:id="lblDetInitial" text="0.00 \u20ac" GridPane.rowIndex="0" GridPane.columnIndex="1" style="-fx-font-weight: bold;"/>
                                                            
                                                            <Label text="%closure_history.detail.cash_sales" GridPane.rowIndex="1" styleClass="trend-text"/>
                                                            <Label fx:id="lblDetSales" text="0.00 \u20ac" GridPane.rowIndex="1" GridPane.columnIndex="1" style="-fx-text-fill: #16a34a;"/>
                                                            
                                                            <Label text="%closure_history.detail.manual_in" GridPane.rowIndex="2" styleClass="trend-text"/>
                                                            <Label fx:id="lblDetIn" text="0.00 \u20ac" GridPane.rowIndex="2" GridPane.columnIndex="1" style="-fx-text-fill: #16a34a;"/>
                                                            
                                                            <Label text="%closure_history.detail.manual_out" GridPane.rowIndex="3" styleClass="trend-text"/>
                                                            <Label fx:id="lblDetOut" text="0.00 \u20ac" GridPane.rowIndex="3" GridPane.columnIndex="1" style="-fx-text-fill: #dc2626;"/>
                                                            
                                                            <Label text="%closure_history.detail.total_expected" GridPane.rowIndex="4" style="-fx-font-weight: bold;"/>
                                                            <Label fx:id="lblDetExpected" text="0.00 \u20ac" GridPane.rowIndex="4" GridPane.columnIndex="1" style="-fx-font-weight: bold;"/>
                                                            
                                                            <Separator GridPane.rowIndex="5" GridPane.columnSpan="2" style="-fx-padding: 5 0;"/>
                                                            
                                                            <Label text="%closure_history.detail.total_counted" GridPane.rowIndex="6" style="-fx-font-weight: bold;"/>
                                                            <Label fx:id="lblDetActual" text="0.00 \u20ac" GridPane.rowIndex="6" GridPane.columnIndex="1" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: -fx-text-custom-main;"/>
                                                        </children>
                                                    </GridPane>
                                                </children>
                                            </VBox>
                                            
                                            <!-- MOVIMIENTOS CON SCROLL HORIZONTAL -->
                                            <VBox spacing="10" VBox.vgrow="ALWAYS">
                                                <children>
                                                    <Label text="%closure_history.detail.movements" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: -fx-text-custom-main;" />
                                                    <!-- Quitamos la constrained policy para que aparezca el scroll horizontal -->
                                                    <TableView fx:id="tableMovements" prefHeight="250" styleClass="table-saas">
                                                        <columns>
                                                            <TableColumn fx:id="colMovCreated" text="%closure_history.detail.mov.time" prefWidth="70" minWidth="65"/>
                                                            <TableColumn fx:id="colMovType" text="%closure_history.detail.mov.type" prefWidth="80" minWidth="75"/>
                                                            <TableColumn fx:id="colMovAmount" text="%closure_history.detail.mov.amount" prefWidth="100" minWidth="90"/>
                                                            <TableColumn fx:id="colMovReason" text="%closure_history.detail.mov.reason" prefWidth="300" minWidth="250"/>
                                                            <TableColumn fx:id="colMovUser" text="%closure_history.detail.mov.user" prefWidth="100" minWidth="80"/>
                                                        </columns>
                                                    </TableView>
                                                </children>
                                            </VBox>
                                            
                                            <!-- OBSERVACIONES -->
                                            <VBox spacing="8">
                                                <children>
                                                    <Label text="%closure_history.detail.obs_label" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: -fx-text-custom-main;" />
                                                    <Label fx:id="lblDetNotes" text="..." wrapText="true" style="-fx-background-color: #fffbeb; -fx-padding: 12; -fx-background-radius: 8; -fx-border-color: #fef3c7; -fx-text-fill: #92400e; -fx-font-size: 13px;" maxWidth="Infinity"/>
                                                </children>
                                            </VBox>
                                            
                                            <!-- ACCIONES -->
                                            <VBox spacing="10">
                                                <children>
                                                    <Separator />
                                                    <HBox spacing="12" alignment="CENTER">
                                                        <children>
                                                            <Button fx:id="btnMarkReviewed" onAction="#handleMarkReviewed" text="%closure_history.btn.mark_reviewed" styleClass="btn-primary-saas" maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="45"/>
                                                            <Button fx:id="btnEditClosure" onAction="#handleEditClosure" text="%closure_history.btn.modify" styleClass="btn-secondary-saas" maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="45"/>
                                                            <Button onAction="#handlePrintAudit" styleClass="btn-secondary-saas" prefHeight="45" prefWidth="50">
                                                                <graphic><FontAwesomeIconView glyphName="PRINT" size="18" /></graphic>
                                                            </Button>
                                                        </children>
                                                    </HBox>
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                        </children>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </children>
    
    <!-- CSS Linking -->
    <stylesheets>
        <URL value="@../styles/components/informes.css" />
        <URL value="@../styles/components/filters.css" />
    </stylesheets>
</AnchorPane>
