<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import java.net.URL?>

<AnchorPane id="AnchorPane" prefHeight="750.0" prefWidth="1100.0" styleClass="main-content-area"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.ventacontrolfx.presentation.controller.WorkSessionController">
    <stylesheets>
        <URL value="@/styles/components/work_sessions.css" />
    </stylesheets>
    <children>
        <VBox spacing="0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Header Section -->
                <VBox styleClass="view-header" spacing="0">
                    <children>
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <children>
                                <StackPane styleClass="view-header-icon-wrap">
                                    <children><FontAwesomeIconView glyphName="CLOCK_ALT" size="24" fill="white"/></children>
                                </StackPane>
                                <VBox spacing="2">
                                    <children>
                                        <Label text="Gesti&#x00f3;n de Turnos y Descansos" styleClass="view-title"/>
                                        <Label text="Registra tus entradas, salidas y tiempos de descanso &#x23f1;&#xfe0f;" styleClass="view-subtitle"/>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
                
                <VBox spacing="25.0" VBox.vgrow="ALWAYS" style="-fx-padding: 30;">
                    <children>
                        <!-- Current Status Card -->
                        <HBox spacing="25.0">
                            <children>
                                <VBox styleClass="status-card" HBox.hgrow="ALWAYS" maxWidth="500">
                                    <children>
                                        <HBox spacing="15" alignment="CENTER_LEFT">
                                            <children>
                                                <StackPane fx:id="statusIconContainer" styleClass="status-icon-container, status-inactive">
                                                    <children><FontAwesomeIconView fx:id="statusIcon" glyphName="USER_TIMES" size="32" fill="white"/></children>
                                                </StackPane>
                                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label fx:id="lblCurrentStatus" text="FUERA DE TURNO" styleClass="status-title-label"/>
                                                        <Label fx:id="lblSessionTimer" text="00:00:00" styleClass="timer-label"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <Separator style="-fx-padding: 15 0;">
                                            <VBox.margin>
                                                <Insets top="10.0" bottom="10.0"/>
                                            </VBox.margin>
                                        </Separator>
                                        <HBox spacing="15" alignment="CENTER">
                                            <children>
                                                <Button fx:id="btnStartShift" text="INICIAR TURNO" onAction="#handleStartShift" styleClass="btn-action, btn-success" prefHeight="50" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                                    <graphic><FontAwesomeIconView glyphName="PLAY" fill="white"/></graphic>
                                                </Button>
                                                <Button fx:id="btnStartBreak" text="INICIAR DESCANSO" onAction="#handleStartBreak" styleClass="btn-action, btn-warning" prefHeight="50" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                                    <graphic><FontAwesomeIconView glyphName="PAUSE" fill="white"/></graphic>
                                                </Button>
                                                <Button fx:id="btnEndSession" text="FINALIZAR" onAction="#handleEndSession" styleClass="btn-action, btn-danger" prefHeight="50" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                                    <graphic><FontAwesomeIconView glyphName="STOP" fill="white"/></graphic>
                                                </Button>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                
                                <VBox styleClass="info-card" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="RESUMEN DE HOY" styleClass="card-title-small"/>
                                        <GridPane vgap="15" hgap="20" style="-fx-padding: 10 0 0 0;">
                                            <columnConstraints>
                                                <ColumnConstraints minWidth="120"/>
                                                <ColumnConstraints hgrow="ALWAYS"/>
                                            </columnConstraints>
                                            <children>
                                                <Label text="Inicio Jornada:" styleClass="label-muted" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                                <Label fx:id="lblShiftStart" text="--" styleClass="info-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                                                
                                                <Label text="Total Trabajado:" styleClass="label-muted" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                                <Label fx:id="lblTotalWorked" text="0h 0m" styleClass="info-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                                                
                                                <Label text="Total Descansos:" styleClass="label-muted" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                                <Label fx:id="lblTotalBreak" text="0h 0m" styleClass="info-value" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                                            </children>
                                        </GridPane>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <!-- History Table Card -->
                        <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
                            <children>
                                <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 15 0;">
                                    <children>
                                        <Label text="HISTORIAL DE ACTIVIDAD" styleClass="card-title-small"/>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button text="Refrescar" onAction="#loadHistory" styleClass="btn-refresh">
                                            <graphic><FontAwesomeIconView glyphName="REFRESH" /></graphic>
                                        </Button>
                                    </children>
                                </HBox>
                                <TableView fx:id="historyTable" styleClass="modern-table-view" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colType" prefWidth="150.0" text="TIPO" />
                                        <TableColumn fx:id="colStart" prefWidth="200.0" text="INICIO" />
                                        <TableColumn fx:id="colEnd" prefWidth="200.0" text="FIN" />
                                        <TableColumn fx:id="colDuration" prefWidth="150.0" text="DURACI&#x00d3;N" />
                                        <TableColumn fx:id="colStatus" prefWidth="120.0" text="ESTADO" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
