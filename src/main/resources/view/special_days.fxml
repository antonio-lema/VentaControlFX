<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import java.net.URL?>

<StackPane fx:id="rootStackPane" styleClass="register-popup-background" 
           onMousePressed="#handleMousePressed" onMouseDragged="#handleMouseDragged"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.ventacontrolfx.presentation.controller.SpecialDaysController">
    
    <VBox maxWidth="600" maxHeight="650" spacing="0" alignment="CENTER" styleClass="modern-register-card">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40"/>
        </padding>
        
        <children>
            <!-- Header Section -->
            <VBox styleClass="modern-register-header" alignment="CENTER_LEFT">
                <children>
                    <Label text="%special.days.title" styleClass="modern-register-title" />
                    <Label text="%special.days.subtitle" 
                           styleClass="modern-register-subtitle" style="-fx-text-fill: #64748b;" />
                </children>
            </VBox>

            <Separator style="-fx-padding: 0 0 20 0;" />

            <!-- Input Section -->
            <VBox spacing="15">
                <children>
                    <Label text="A&#x00d1;DIR NUEVA EXCEPCI&#x00d3;N" 
                           style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-letter-spacing: 1px;" />
                    
                    <HBox spacing="20">
                        <children>
                            <VBox styleClass="modern-input-group" HBox.hgrow="ALWAYS">
                                <children>
                                    <Label text="%special.days.field.date" styleClass="modern-label" style="-fx-font-size: 11px;" />
                                    <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                                        <children>
                                            <FontAwesomeIconView glyphName="CALENDAR" size="18" fill="#64748b" />
                                            <DatePicker fx:id="pickerDate" promptText="Seleccionar..." 
                                                        styleClass="modern-input-field" HBox.hgrow="ALWAYS" 
                                                        style="-fx-background-color: transparent;" />
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>
                            
                            <VBox styleClass="modern-input-group" HBox.hgrow="ALWAYS" prefWidth="250">
                                <children>
                                    <Label text="%special.days.field.reason" styleClass="modern-label" style="-fx-font-size: 11px;" />
                                    <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                                        <children>
                                            <FontAwesomeIconView glyphName="EDIT" size="18" fill="#64748b" />
                                            <TextField fx:id="txtReason" promptText="%special.days.field.reason.prompt" 
                                                       styleClass="modern-input-field" HBox.hgrow="ALWAYS" />
                                        </children>
                                    </HBox>
                                </children>
                            </VBox>
                        </children>
                    </HBox>

                    <HBox spacing="20" alignment="CENTER_LEFT">
                        <children>
                            <CheckBox fx:id="chkClosed" text="%special.days.check.closed" 
                                      selected="true" styleClass="modern-checkbox" style="-fx-font-weight: bold;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button text="%special.days.btn.add" onAction="#handleAdd" 
                                    styleClass="modern-btn-primary" prefHeight="40">
                                <graphic>
                                    <FontAwesomeIconView glyphName="PLUS" fill="white" />
                                </graphic>
                            </Button>
                        </children>
                    </HBox>
                </children>
            </VBox>

            <Separator style="-fx-padding: 20 0;">
                <VBox.margin>
                    <Insets top="10" bottom="10" />
                </VBox.margin>
            </Separator>

            <!-- List Section -->
            <VBox spacing="10" VBox.vgrow="ALWAYS">
                <children>
                    <Label text="%special.days.list.title" 
                           style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #94a3b8; -fx-letter-spacing: 1px;" />
                    <ListView fx:id="listSpecials" VBox.vgrow="ALWAYS" 
                              style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e2e8f0;" />
                </children>
            </VBox>

            <!-- Footer Actions -->
            <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 25 0 0 0;">
                <children>
                    <Button text="%special.days.btn.delete" onAction="#handleRemove" 
                            styleClass="modern-btn-secondary" prefHeight="40">
                        <graphic>
                            <FontAwesomeIconView glyphName="TRASH_ALT" />
                        </graphic>
                    </Button>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="%special.days.btn.finish" onAction="#handleSave" 
                            styleClass="modern-btn-primary" prefHeight="40" prefWidth="200" />
                </children>
            </HBox>
        </children>
    </VBox>
</StackPane>
