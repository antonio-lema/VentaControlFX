<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.image.ImageView?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" spacing="0.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ReceiptController">
   <children>
      <!-- LEFT SIDE: The Receipt Preview -->
      <VBox prefWidth="380.0" style="-fx-background-color: -bg-subtle; -fx-padding: 20;">
         <children>
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
               <content>
                   <VBox fx:id="receiptContent" spacing="10.0" style="-fx-background-color: -fx-bg-surface; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0); -fx-padding: 30; -fx-border-color: #ddd; -fx-border-width: 1;">
                      <children>
                                <!-- Header -->
                                <VBox fx:id="companyHeaderSection" alignment="TOP_CENTER" spacing="5.0">
                                   <!-- Logo/Brand -->
                                    <HBox alignment="CENTER" spacing="5">
                                        <Label fx:id="lblCompanyIcon" style="-fx-text-fill: #2196F3; -fx-font-size: 24; -fx-font-weight: bold;" text="☁" />
                                        <ImageView fx:id="imgCompanyLogo" fitWidth="60.0" fitHeight="60.0" preserveRatio="true" managed="false" visible="false" />
                                        <Label fx:id="lblCompanyBrand" style="-fx-font-weight: bold; -fx-font-size: 22; -fx-text-fill: #2196F3;" text="GestionTPV" />
                                    </HBox>
                                    
                                   <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: -fx-text-custom-main;" fx:id="lblCompanyName" text="" />
                                   <Label style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" fx:id="lblCompanyAddress" text="" />
                                   <Label style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" fx:id="lblCompanyPhone" text="" />
                                   <Label style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" fx:id="lblCompanyCif" text="" />
                                </VBox>
                                
                                <Separator style="-fx-background-color: black; -fx-opacity: 0.1;" />

                                <!-- Client Info -->
                                <VBox fx:id="clientInfoSection" managed="false" visible="false" spacing="2.0" style="-fx-padding: 10; -fx-border-color: #ddd; -fx-border-width: 1; -fx-border-radius: -fx-radius-sm; -fx-background-color: #fcfcfc;">
                                    <Label style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: -fx-text-custom-main;" text="%receipt.client.title" />
                                    <Label fx:id="lblClientName" style="-fx-font-weight: bold; -fx-font-size: 12; -fx-text-fill: #1a73e8;" text="" />
                                    <Label fx:id="lblClientTaxId" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="" />
                                    <Label fx:id="lblClientAddress" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="" wrapText="true" />
                                </VBox>
                                
                                <Separator style="-fx-background-color: black; -fx-opacity: 0.1;" />
                                
                                <!-- Ticket Info -->
                                <VBox fx:id="ticketInfoSection" alignment="CENTER_LEFT" spacing="2.0">
                                    <Label fx:id="lblGiftIndicator" style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #1a73e8; -fx-padding: 0 0 5 0;" text="%receipt.title.gift" managed="false" visible="false" />
                                    <Label fx:id="lblTicketTitle" style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: -fx-text-custom-main;" text="Factura simplificada Nº: 01/4246" />
                                    <Label fx:id="lblDate" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="Fecha: 18 Feb, 2026 Hora: 12:20:38 Caja: 01" />
                                </VBox>

                                <!-- Observations -->
                                <VBox fx:id="observationSection" managed="false" visible="false" spacing="2.0" style="-fx-padding: 5 10; -fx-background-color: #f8f9fa; -fx-border-color: #eee; -fx-border-width: 1; -fx-border-radius: 4;">
                                    <HBox spacing="5" alignment="CENTER_LEFT">
                                        <Label text="%receipt.observations.label" style="-fx-font-weight: bold; -fx-font-size: 9; -fx-text-fill: #666;" />
                                    </HBox>
                                    <Label fx:id="lblObservations" style="-fx-font-size: 10; -fx-text-fill: #333; -fx-font-style: italic;" wrapText="true" text="" />
                                </VBox>
                                
                                <Separator style="-fx-background-color: black; -fx-opacity: 0.1;" />
                                
                                <!-- Items Header -->
                                <HBox fx:id="itemsHeaderHBox" spacing="10.0" style="-fx-padding: 0 0 2 0;">
                                   <children>
                                      <Label maxWidth="Infinity" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="%receipt.table.desc" HBox.hgrow="ALWAYS" />
                                      <Label alignment="CENTER_RIGHT" prefWidth="30.0" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="%receipt.table.qty" />
                                      <Label alignment="CENTER_RIGHT" prefWidth="55.0" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" fx:id="lblPVPHeader" text="%receipt.table.price" />
                                      <Label alignment="CENTER_RIGHT" prefWidth="55.0" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" fx:id="lblTotalHeader" text="%receipt.summary.total" />
                                   </children>
                                </HBox>
                                
                                <!-- Items Container -->
                                <VBox fx:id="itemsContainer" spacing="5.0" minHeight="50" />
                                
                                <Separator style="-fx-background-color: black; -fx-opacity: 0.1;" />
                                
                                <!-- Totals -->
                                <VBox fx:id="totalsContainer" spacing="3.0">
                                    <HBox>
                                       <Label maxWidth="Infinity" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="%receipt.summary.subtotal" HBox.hgrow="ALWAYS" />
                                       <Label fx:id="lblSubtotal" style="-fx-font-size: 10; -fx-alignment: CENTER_RIGHT; -fx-text-fill: -fx-text-custom-main;" text="0,00 €" />
                                    </HBox>
                                     <VBox fx:id="vatBreakdownContainer" spacing="2.0" />
                                     <VBox fx:id="hboxSavings" managed="false" visible="false">
                                         <HBox>
                                            <Label maxWidth="Infinity" style="-fx-font-size: 10; -fx-text-fill: #2e7d32; -fx-font-weight: bold;" text="%receipt.summary.discount" HBox.hgrow="ALWAYS" />
                                            <Label fx:id="lblSavings" style="-fx-font-size: 10; -fx-text-fill: #2e7d32; -fx-font-weight: bold;" text="0,00 €" />
                                         </HBox>
                                     </VBox>
                                     <HBox fx:id="hboxVatTotal" managed="false" visible="false">
                                        <Label maxWidth="Infinity" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="%receipt.summary.vat_total" HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblVat" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="0,00 €" />
                                     </HBox>
                                    <HBox style="-fx-padding: 5 0 0 0;">
                                       <Label maxWidth="Infinity" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: -fx-text-custom-main;" text="%receipt.summary.total" HBox.hgrow="ALWAYS" />
                                       <Label fx:id="lblTotal" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: -fx-text-custom-main;" text="0,00 €" />
                                    </HBox>
                                </VBox>
                                
                                <Separator style="-fx-background-color: black; -fx-opacity: 0.1;" />
                                
                                <!-- Payment Info -->
                                <VBox fx:id="paymentInfoContainer" spacing="2.0">
                                    <HBox>
                                        <Label maxWidth="Infinity" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="%receipt.payment.method" HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblPaymentMethod" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="---" />
                                    </HBox>
                                     <HBox>
                                        <Label maxWidth="Infinity" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="%receipt.payment.paid" HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblPaid" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="0,00 €" />
                                    </HBox>
                                     <HBox>
                                        <Label maxWidth="Infinity" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="%receipt.payment.change" HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblChange" style="-fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="0,00 €" />
                                    </HBox>
                                </VBox>
                                
                                <!-- Footer -->
                                <VBox alignment="CENTER" spacing="5.0" style="-fx-padding: 20 0 0 0;">
                                    <Label fx:id="lblAttendedBy" style="-fx-text-fill: grey; -fx-font-size: 9;" text="" />
                                    <Label fx:id="lblFooterMessage" style="-fx-font-weight: bold; -fx-font-size: 10; -fx-text-fill: -fx-text-custom-main;" text="%receipt.footer.thanks" />
                                    <Label fx:id="lblWebsiteUrl" style="-fx-font-size: 8; -fx-text-fill: grey;" text="" />
                                </VBox>
                                
                                <!-- Barcode (Gift Ticket) -->
                                <VBox fx:id="barcodeSection" alignment="CENTER" spacing="5" managed="false" visible="false">
                                    <Label fx:id="lblModalTitle" alignment="CENTER" maxWidth="Infinity" style="-fx-font-size: 12; -fx-font-weight: bold;" text="%receipt.success.title" />
                                    <HBox fx:id="barcodeContainer" alignment="CENTER" spacing="1" style="-fx-padding: 10 0;" />
                                    <Label fx:id="lblBarcodeValue" style="-fx-font-size: 8; -fx-text-fill: -fx-text-custom-main;" text="0123456789" />
                                </VBox>
                        
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
      
      <!-- RIGHT SIDE: Status and Actions -->
      <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: -bg-main; -fx-padding: 30;" spacing="20.0" alignment="TOP_CENTER">
         <children>
            <!-- Success Icon/Message -->
            <VBox alignment="CENTER" spacing="10.0">
               <StackPane>
                  <Label fx:id="lblSuccessIcon" text="✔" style="-fx-font-size: 60; -fx-text-fill: #4CAF50;" />
                  <ImageView fx:id="imgAppLogoRight" fitHeight="80.0" preserveRatio="true" managed="false" visible="false" />
               </StackPane>
                <Label fx:id="lblSuccessMessage" text="%receipt.success.title" style="-fx-font-size: 24; -fx-text-fill: -fx-text-custom-main;" />
               
               <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10;">
                  <VBox alignment="CENTER">
                      <Label fx:id="lblTotalRight" text="" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: -fx-text-custom-main;" />
                      <Label text="%receipt.success.total_label" style="-fx-text-fill: grey;" />
                  </VBox>
                  <Separator orientation="VERTICAL" />
                  <VBox alignment="CENTER">
                      <Label fx:id="lblChangeRight" text="" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: -fx-custom-color-primary;" />
                      <Label text="%receipt.payment.change" style="-fx-text-fill: -fx-custom-color-primary;" />
                  </VBox>
               </HBox>
            </VBox>
            
            <Separator />
            
            <!-- Printing Options -->
            <VBox spacing="10.0">
               <Label style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: black;" text="%receipt.btn.print" />
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <Button graphicTextGap="10" onAction="#handlePrint" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: -fx-radius-xl; -fx-cursor: hand;" text="%receipt.btn.print">
                      <graphic>
                          <Label style="-fx-text-fill: white; -fx-font-size: 16;" text="⎙" />
                      </graphic>
                  </Button>
                   <Button fx:id="btnSendEmail" onAction="#handleSendEmail" managed="false" visible="false" style="-fx-background-color: #34a853; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: -fx-radius-xl; -fx-cursor: hand;" text="%receipt.btn.email">
                       <graphic>
                           <Label style="-fx-font-size: 16; -fx-text-fill: white;" text="✉" />
                       </graphic>
                   </Button>
                   <Button fx:id="btnGiftTicket" onAction="#handleGiftTicket" style="-fx-background-color: -fx-bg-surface; -fx-text-fill: #1a73e8; -fx-border-color: #1a73e8; -fx-border-radius: -fx-radius-xl; -fx-border-width: 1; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: -fx-radius-xl; -fx-cursor: hand;" text="%receipt.btn.gift">
                      <graphic>
                          <Label fx:id="lblGiftIcon" style="-fx-font-size: 16; -fx-text-fill: #1a73e8;" text="🎁" />
                      </graphic>
                  </Button>
               </HBox>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Separator style="-fx-padding: 10 0;" />
            
            <!-- Bottom Buttons -->
            <HBox alignment="CENTER" spacing="15.0">
               <Button onAction="#handleBack" style="-fx-background-color: #ea4335; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30; -fx-background-radius: -fx-radius-xl; -fx-cursor: hand;" text="%receipt.btn.back" cancelButton="true" />
               <Button onAction="#handleNewSale" style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30; -fx-background-radius: -fx-radius-xl; -fx-cursor: hand;" text="%receipt.btn.new_sale" defaultButton="true" />
            </HBox>
            
         </children>
      </VBox>
   </children>
</HBox>


