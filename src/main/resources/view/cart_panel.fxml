<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.controller.CartController"
      spacing="0" styleClass="cart-panel" prefWidth="450">
    
    <HBox alignment="CENTER_LEFT" styleClass="cart-customer-header">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <StackPane styleClass="icon-container-small-blue">
                <FontAwesomeIconView glyphName="USER_PLUS" size="14" fill="#1e88e5"/>
            </StackPane>
            <Label fx:id="lblSelectedClient" text="Añadir empresa" styleClass="cart-customer-title"/>
        </HBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="5" alignment="CENTER_RIGHT">
            <Button fx:id="btnRemoveClient" onAction="#handleRemoveSelectedClient" visible="false" managed="false" styleClass="btn-remove-client" style="-fx-background-color: #fff5f5; -fx-padding: 5; -fx-background-radius: 5; -fx-cursor: hand;">
                <graphic>
                    <FontAwesomeIconView glyphName="TRASH" size="12" fill="#e53935"/>
                </graphic>
            </Button>
            <Button onAction="#showAddClientDialog" styleClass="btn-add-customer">
                <tooltip><Tooltip text="Añadir nueva empresa"/></tooltip>
                <graphic><FontAwesomeIconView glyphName="PLUS" size="14" styleClass="add-customer-icon"/></graphic>
            </Button>
        </HBox>
    </HBox>
    
    <HBox alignment="CENTER_LEFT" styleClass="cart-items-header">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <StackPane styleClass="icon-container-small">
                <FontAwesomeIconView glyphName="LIST_UL" size="14" fill="#555"/>
            </StackPane>
            <Label text="Artículos" styleClass="cart-section-title"/>
        </HBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnClearCart" onAction="#clearCart" styleClass="btn-clear-cart">
            <tooltip><Tooltip text="Vaciar carrito"/></tooltip>
            <graphic>
                <HBox spacing="8" alignment="CENTER">
                    <Label text="Vaciar carrito" styleClass="btn-clear-cart-text"/>
                    <FontAwesomeIconView glyphName="TRASH" size="14" fill="#e53935"/>
                </HBox>
            </graphic>
        </Button>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS" style="-fx-background-color: white;">
        <VBox fx:id="emptyCartView" alignment="CENTER" spacing="10">
            <Label text="🛒" style="-fx-font-size: 60px; -fx-text-fill: #eee;"/>
        </VBox>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" hbarPolicy="NEVER">
            <VBox fx:id="cartItemsContainer" spacing="0" styleClass="cart-list-container"/>
        </ScrollPane>
    </StackPane>
    
    <VBox styleClass="checkout-summary">
        <HBox alignment="CENTER_LEFT">
            <Label fx:id="itemsCountLabel" text="Subtotal (0 item)" styleClass="summary-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="subtotalLabel" text="0,00 €" styleClass="summary-value"/>
        </HBox>
        <HBox alignment="CENTER_LEFT">
            <Label text="Impuestos (21%)" styleClass="summary-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="taxLabel" text="0,00 €" styleClass="summary-value"/>
        </HBox>
        <Separator/>
        <HBox alignment="CENTER_LEFT">
            <Label text="TOTAL COBRAR" styleClass="total-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="totalButtonLabel" text="0,00 €" styleClass="total-value"/>
        </HBox>
        <Button fx:id="payButton" text="REALIZAR PAGO" onAction="#handlePayButton" styleClass="btn-pay" maxWidth="Infinity"/>
    </VBox>
</VBox>
