<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.layout.StackPane?>

<AnchorPane id="AnchorPane" prefHeight="700.0" prefWidth="1000.0" styleClass="main-content-area" stylesheets="@../styles/main.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.VatManagementController">
   <children>
      <VBox spacing="0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- Header section -->
            <VBox styleClass="view-header" spacing="0">
                <children>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <children>
                            <StackPane styleClass="view-header-icon-wrap">
                                <children><FontAwesomeIconView glyphName="PERCENT" size="24" fill="white"/></children>
                            </StackPane>
                            <VBox spacing="2">
                                <children>
                                    <Label text="%vat.title" styleClass="view-title"/>
                                    <Label text="%vat.subtitle" styleClass="view-subtitle"/>
                                </children>
                            </VBox>
                        </children>
                    </HBox>
                </children>
            </VBox>
            
            <VBox styleClass="view-body-padding" VBox.vgrow="ALWAYS">
               <children>

            <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" styleClass="modern-tab-pane">
              <tabs>
                <Tab fx:id="tabCurrentConfig" text="%vat.tab.current">
                    <graphic>
                        <FontAwesomeIconView glyphName="COG" size="14" />
                    </graphic>
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <VBox spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="20.0">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="info-banner">
                                       <children>
                                          <FontAwesomeIconView glyphName="INFO_CIRCLE" size="16" styleClass="text-info" />
                                          <Label wrapText="true" text="%vat.banner.note" styleClass="label-muted" />
                                       </children>
                                    </HBox>

                                                                         <HBox spacing="20.0" VBox.vgrow="ALWAYS">
                                        <children>
                                           <!-- Columna Izquierda: Global -->
                                           <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="config-card">
                                              <children>
                                                  <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="12">
                                                      <children>
                                                          <StackPane styleClass="config-card-icon-wrap, config-icon-blue">
                                                              <children><FontAwesomeIconView glyphName="GEAR" size="16" fill="#1e88e5"/></children>
                                                          </StackPane>
                                                          <Label styleClass="config-card-title" text="%vat.card.global" />
                                                      </children>
                                                  </HBox>
                                                  <VBox spacing="18.0" styleClass="config-card-body" VBox.vgrow="ALWAYS">
                                                      <children>
                                                         <HBox alignment="CENTER_LEFT" spacing="15.0">
                                                            <children>
                                                               <Label text="%vat.field.current_group" styleClass="label-muted"/>
                                                               <Label fx:id="lblCurrentGlobalTaxGroup" styleClass="label-highlight" text="%vat.loading" />
                                                            </children>
                                                         </HBox>
                                                         <VBox spacing="8.0">
                                                            <children>
                                                               <Label text="%vat.field.change_global" styleClass="label-bold"/>
                                                               <ComboBox fx:id="cmbGlobalTaxGroup" maxWidth="1.7976931348623157E308" promptText="%vat.field.select_group.prompt" styleClass="modern-combo-box" />
                                                            </children>
                                                         </VBox>
                                                         <Region VBox.vgrow="ALWAYS" />
                                                         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleUpdateGlobalTaxGroup" styleClass="btn-primary" text="%vat.btn.set_global" />
                                                      </children>
                                                  </VBox>
                                              </children>
                                           </VBox>

                                           <!-- Columna Derecha: Categor&#x00eda; -->
                                           <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="config-card">
                                              <children>
                                                  <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="12">
                                                      <children>
                                                          <StackPane styleClass="config-card-icon-wrap, config-icon-green">
                                                              <children><FontAwesomeIconView glyphName="TAGS" size="16" fill="#10b981"/></children>
                                                          </StackPane>
                                                          <Label styleClass="config-card-title" text="%vat.card.category" />
                                                      </children>
                                                  </HBox>
                                                  <VBox spacing="18.0" styleClass="config-card-body" VBox.vgrow="ALWAYS">
                                                      <children>
                                                         <VBox spacing="8.0">
                                                            <children>
                                                               <Label text="%vat.field.select_category" styleClass="label-bold"/>
                                                               <MenuButton fx:id="cmbCategory" maxWidth="1.7976931348623157E308" text="%vat.field.choose.prompt" styleClass="modern-combo-box" />
                                                            </children>
                                                         </VBox>
                                                         <VBox spacing="8.0">
                                                            <children>
                                                               <Label text="%vat.field.group_category" styleClass="label-bold"/>
                                                               <ComboBox fx:id="cmbCategoryTaxGroup" maxWidth="1.7976931348623157E308" promptText="%vat.field.inherit_global.prompt" styleClass="modern-combo-box" />
                                                            </children>
                                                         </VBox>
                                                         <Region VBox.vgrow="ALWAYS" />
                                                         <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleUpdateCategoryTaxGroup" styleClass="btn-success" text="%vat.btn.assign_category" />
                                                      </children>
                                                  </VBox>
                                              </children>
                                           </VBox>

                                           <!-- Columna: Producto Espec&#x00edf;ico -->
                                           <VBox spacing="0" HBox.hgrow="ALWAYS" styleClass="config-card">
                                              <children>
                                                  <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="12">
                                                      <children>
                                                          <StackPane styleClass="config-card-icon-wrap, config-icon-orange">
                                                              <children><FontAwesomeIconView glyphName="CUBE" size="16" fill="#f59e0b"/></children>
                                                          </StackPane>
                                                          <Label styleClass="config-card-title" text="%vat.card.product" />
                                                      </children>
                                                  </HBox>
                                                  <VBox spacing="15.0" styleClass="config-card-body" VBox.vgrow="ALWAYS">
                                                      <children>
                                                          <VBox spacing="8.0">
                                                             <children>
                                                                <Label text="%vat.field.select_products" styleClass="label-bold"/>
                                                                <TextField fx:id="txtVatProductSearch" promptText="%vat.field.search.prompt" styleClass="modern-text-field" />
                                                                 <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                                    <children>
                                                                       <MenuButton fx:id="btnVatProductExplorer" maxWidth="1.7976931348623157E308" text="%vat.btn.explore" styleClass="modern-combo-box" HBox.hgrow="ALWAYS" />
                                                                       <Button fx:id="btnClearVatSelection" onAction="#handleClearVatSelection" styleClass="btn-icon, btn-danger" prefHeight="40" prefWidth="40">
                                                                          <graphic><FontAwesomeIconView glyphName="TRASH" size="16" fill="#ef4444"/></graphic>
                                                                       </Button>
                                                                    </children>
                                                                 </HBox>
                                                             </children>
                                                          </VBox>
                                                          <ListView fx:id="listVatSelectedProducts" prefHeight="80.0" styleClass="modern-list-view" VBox.vgrow="ALWAYS" />
                                                          <VBox spacing="8.0">
                                                             <children>
                                                                <Label text="%vat.field.new_group" styleClass="label-bold"/>
                                                                <ComboBox fx:id="cmbProductTaxGroup" maxWidth="1.7976931348623157E308" promptText="%vat.field.select_group.prompt" styleClass="modern-combo-box" />
                                                             </children>
                                                          </VBox>
                                                          <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleUpdateProductTaxGroup" styleClass="btn-primary" text="%vat.btn.assign_products" />
                                                      </children>
                                                  </VBox>
                                              </children>
                                           </VBox>
                                        </children>
                                     </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </AnchorPane>
                  </content>
                </Tab>

                <!-- PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP -->
                <!--  PESTA&#x00d1A;: SUBIDA MASIVA DE PRECIOS &#x2014; UI DIN&#x00c1;MICA              -->
                <!-- PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP -->
                <Tab fx:id="tabMassUpdate" text="%vat.tab.mass_update">
                    <graphic>
                        <FontAwesomeIconView glyphName="LINE_CHART" size="14" />
                    </graphic>
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0">
                           <children>
                              <ScrollPane fitToWidth="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0" styleClass="scroll-pane">
                                <content>
                                 <VBox spacing="18.0" styleClass="mass-update-padding">
                                 <children>

                                     <!-- Top Banner / Header -->
                                     <HBox styleClass="estetica-header" alignment="CENTER_LEFT" spacing="20">
                                         <children>
                                             <VBox styleClass="estetica-header-icon-wrap">
                                                 <children>
                                                     <FontAwesomeIconView glyphName="LINE_CHART" size="28" styleClass="icon-white" />
                                                 </children>
                                             </VBox>
                                             <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                 <children>
                                                     <Label styleClass="estetica-title" text="%vat.mass.title" />
                                                     <Label styleClass="estetica-subtitle" wrapText="true"
                                                            text="%vat.mass.subtitle" />
                                                 </children>
                                             </VBox>
                                         </children>
                                         <VBox.margin>
                                             <Insets left="-30.0" right="-30.0" top="-20.0" />
                                         </VBox.margin>
                                     </HBox>

                                     <!--  STEP 1: Selecci&#x00f3;n de Objetivo  -->
                                     <VBox spacing="10.0">
                                         <children>
                                             <HBox alignment="CENTER_LEFT" spacing="10">
                                                 <children>
                                                     <Label text="1" styleClass="step-number" />
                                                     <Label styleClass="estetica-card-title" text="%vat.mass.step1" />
                                                 </children>
                                             </HBox>
                                             
                                             <VBox spacing="16.0" styleClass="estetica-card">
                                                 <children>
                                                     <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="estetica-card-body">
                                                         <children>
                                                             <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                                <children>
                                                                   <HBox alignment="CENTER_LEFT" spacing="6">
                                                                       <children>
                                                                           <FontAwesomeIconView glyphName="TAG" size="12" styleClass="icon-primary"/>
                                                                           <Label styleClass="label-bold" text="%vat.mass.field.price_list" />
                                                                       </children>
                                                                   </HBox>
                                                                   <ComboBox fx:id="cmbPriceListUpdate"
                                                                             maxWidth="1.7976931348623157E308"
                                                                             promptText="%vat.mass.field.price_list.prompt"
                                                                             styleClass="modern-combo-box" />
                                                                </children>
                                                             </VBox>
                                                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                               <children>
                                                                  <Label styleClass="label-bold" text="%vat.mass.field.grouping" />
                                                                  <ComboBox fx:id="cmbGroupingType"
                                                                            maxWidth="1.7976931348623157E308"
                                                                            promptText="%vat.mass.field.grouping.prompt"
                                                                            styleClass="modern-combo-box" />
                                                               </children>
                                                            </VBox>
                                                            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                                               <children>
                                                                  <Label styleClass="label-bold" text="%vat.mass.field.operation" />
                                                                  <ComboBox fx:id="cmbPriceUpdateType"
                                                                            maxWidth="1.7976931348623157E308"
                                                                            styleClass="modern-combo-box" />
                                                               </children>
                                                            </VBox>
                                                         </children>
                                                     </HBox>
                                                 </children>
                                             </VBox>
                                         </children>
                                     </VBox>

                                     <!--  STEP 2: Configuraci&#x00f3;n Detallada  -->
                                     <VBox spacing="10.0">
                                         <children>
                                             <HBox alignment="CENTER_LEFT" spacing="10">
                                                 <children>
                                                     <Label text="2" styleClass="step-number" />
                                                     <Label styleClass="estetica-card-title" text="%vat.mass.step2" />
                                                 </children>
                                             </HBox>

                                             <VBox styleClass="estetica-card">
                                                <children>
                                                    <VBox styleClass="estetica-card-body">
                                                        <children>
                                                           <!-- Sub-panel: Por CATEGOR&#x00cdA; -->
                                                           <HBox fx:id="panelCategory" alignment="CENTER_LEFT" spacing="15.0"
                                                                 visible="true" managed="true"
                                                                 styleClass="panel-accent-blue">
                                                              <children>
                                                                  <HBox alignment="CENTER_LEFT" spacing="8">
                                                                      <children>
                                                                          <FontAwesomeIconView glyphName="FOLDER_OPEN" size="14" styleClass="icon-success"/>
                                                                          <Label styleClass="label-bold" text="%vat.mass.field.category" />
                                                                      </children>
                                                                  </HBox>
                                                                  <ComboBox fx:id="cmbPriceCategory"
                                                                            maxWidth="1.7976931348623157E308"
                                                                            promptText="%vat.mass.field.category.all"
                                                                            styleClass="modern-combo-box" />
                                                              </children>
                                                           </HBox>

                                                           <!-- Sub-panel: CLONACI&#x00d3;N -->
                                                           <HBox fx:id="panelClone" alignment="CENTER_LEFT" spacing="15.0"
                                                                 visible="false" managed="false"
                                                                 styleClass="panel-accent-lightblue">
                                                               <children>
                                                                  <FontAwesomeIconView glyphName="COPY" size="20" styleClass="text-info" />
                                                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                                     <children>
                                                                        <Label styleClass="label-muted" text="%vat.mass.field.source_list" />
                                                                        <ComboBox fx:id="cmbSourcePriceList"
                                                                                  maxWidth="1.7976931348623157E308"
                                                                                  promptText="%vat.mass.field.source_list.prompt"
                                                                                  styleClass="modern-combo-box" />
                                                                     </children>
                                                                  </VBox>
                                                                  <VBox spacing="4.0" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                                                                      <children>
                                                                         <Label styleClass="label-muted, font-italic" wrapText="true"
                                                                                text="%vat.mass.field.clone.desc" />
                                                                      </children>
                                                                  </VBox>
                                                               </children>
                                                           </HBox>

                                                           <!-- Sub-panel: TOP VENDIDOS -->
                                                           <HBox fx:id="panelTopSellers" alignment="CENTER_LEFT" spacing="20.0"
                                                                 visible="false" managed="false"
                                                                 styleClass="panel-accent-yellow">
                                                              <children>
                                                                 <VBox styleClass="icon-wrap-accent-warning">
                                                                    <children><FontAwesomeIconView glyphName="STAR" size="20" fill="#ffffff" /></children>
                                                                 </VBox>
                                                                 <VBox spacing="4.0">
                                                                    <children>
                                                                       <Label styleClass="label-muted" text="%vat.mass.field.top_n" />
                                                                       <TextField fx:id="txtTopN" prefWidth="100.0" promptText="Ej: 20" styleClass="modern-text-field" />
                                                                    </children>
                                                                 </VBox>
                                                                 <VBox spacing="4.0">
                                                                    <children>
                                                                       <Label styleClass="label-muted" text="%vat.mass.field.top_days" />
                                                                       <TextField fx:id="txtTopDays" prefWidth="120.0" promptText="Ej: 90" styleClass="modern-text-field" />
                                                                    </children>
                                                                 </VBox>
                                                                 <VBox spacing="4.0" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                                                                    <children>
                                                                       <Label styleClass="label-muted, font-italic" wrapText="true"
                                                                              text="%vat.mass.field.top.desc" />
                                                                    </children>
                                                                 </VBox>
                                                              </children>
                                                           </HBox>

                                                           <!-- Sub-panel: MENOS VENDIDOS -->
                                                           <HBox fx:id="panelBottomSellers" alignment="CENTER_LEFT" spacing="20.0"
                                                                 visible="false" managed="false"
                                                                 styleClass="panel-accent-orange">
                                                              <children>
                                                                 <VBox styleClass="icon-wrap-accent-orange">
                                                                     <children><FontAwesomeIconView glyphName="ARROW_DOWN" size="20" fill="#ffffff" /></children>
                                                                 </VBox>
                                                                 <VBox spacing="4.0">
                                                                    <children>
                                                                       <Label styleClass="label-muted" text="%vat.mass.field.bottom_n" />
                                                                       <TextField fx:id="txtBottomN" prefWidth="100.0" promptText="Ej: 5" styleClass="modern-text-field" />
                                                                    </children>
                                                                 </VBox>
                                                                 <VBox spacing="4.0">
                                                                    <children>
                                                                       <Label styleClass="label-muted" text="%vat.mass.field.bottom_days" />
                                                                       <TextField fx:id="txtBottomDays" prefWidth="100.0" promptText="Ej: 90" styleClass="modern-text-field" />
                                                                    </children>
                                                                 </VBox>
                                                                 <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                       <Label styleClass="label-muted" wrapText="true"
                                                                              text="%vat.mass.field.bottom.desc" />
                                                                    </children>
                                                                 </VBox>
                                                              </children>
                                                           </HBox>

                                                           <!-- Sub-panel: SIN MOVIMIENTO -->
                                                           <HBox fx:id="panelSlowMovers" alignment="CENTER_LEFT" spacing="20.0"
                                                                 visible="false" managed="false"
                                                                 styleClass="panel-accent-pink">
                                                              <children>
                                                                 <VBox styleClass="icon-wrap-accent-pink">
                                                                     <children><FontAwesomeIconView glyphName="CLOCK_ALT" size="20" fill="#ffffff" /></children>
                                                                 </VBox>
                                                                 <VBox spacing="4.0">
                                                                    <children>
                                                                       <Label styleClass="label-muted" text="%vat.mass.field.slow_days" />
                                                                       <TextField fx:id="txtSlowDays" prefWidth="130.0" promptText="Ej: 60" styleClass="modern-text-field" />
                                                                    </children>
                                                                 </VBox>
                                                                 <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                                    <children>
                                                                       <Label styleClass="label-muted" wrapText="true"
                                                                              text="%vat.mass.field.slow.desc" />
                                                                    </children>
                                                                 </VBox>
                                                              </children>
                                                           </HBox>

                                                           <!-- Sub-panel: RANGO DE PRECIO -->
                                                           <HBox fx:id="panelPriceRange" alignment="CENTER_LEFT" spacing="20.0"
                                                                 visible="false" managed="false"
                                                                 styleClass="panel-accent-green">
                                                              <children>
                                                                 <VBox styleClass="icon-wrap-accent-green">
                                                                     <children><FontAwesomeIconView glyphName="EUR" size="20" fill="#ffffff" /></children>
                                                                 </VBox>
                                                                 <VBox spacing="4.0">
                                                                    <children>
                                                                       <Label styleClass="label-muted" text="%vat.mass.field.min_price" />
                                                                       <TextField fx:id="txtMinPrice" prefWidth="110.0" promptText="0.00" styleClass="modern-text-field" />
                                                                    </children>
                                                                 </VBox>
                                                                 <VBox spacing="4.0">
                                                                    <children>
                                                                       <Label styleClass="label-muted" text="%vat.mass.field.max_price" />
                                                                       <TextField fx:id="txtMaxPrice" prefWidth="110.0" promptText="20.00" styleClass="modern-text-field" />
                                                                    </children>
                                                                 </VBox>
                                                              </children>
                                                           </HBox>

                                                           <!-- Sub-panel: FAVORITOS -->
                                                           <HBox fx:id="panelFavorites" alignment="CENTER_LEFT" spacing="20.0"
                                                                 visible="false" managed="false"
                                                                 styleClass="panel-accent-purple">
                                                              <children>
                                                                 <VBox styleClass="icon-wrap-accent-purple">
                                                                     <children><FontAwesomeIconView glyphName="HEART" size="20" fill="#ffffff" /></children>
                                                                 </VBox>
                                                                 <Label styleClass="label-muted" wrapText="true" HBox.hgrow="ALWAYS"
                                                                        text="%vat.mass.field.favorites.desc" />
                                                              </children>
                                                           </HBox>

                                                           <!-- Sub-panel: PRODUCTOS ESPEC&#x00cdF;ICOS -->
                                                           <VBox fx:id="panelProducts" spacing="10.0" 
                                                                 visible="false" managed="false"
                                                                 styleClass="panel-accent-teal">
                                                               <children>
                                                                  <HBox spacing="10.0" alignment="CENTER_LEFT">
                                                                      <children>
                                                                          <VBox styleClass="icon-wrap-accent-teal">
                                                                              <children><FontAwesomeIconView glyphName="LIST" size="20" fill="#ffffff" /></children>
                                                                          </VBox>
                                                                          <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                                             <children>
                                                                                <Label styleClass="label-muted" text="%vat.mass.field.search_products" />
                                                                                <TextField fx:id="txtProductSearch" promptText="%vat.mass.field.search_products.prompt" styleClass="modern-text-field" />
                                                                             </children>
                                                                          </VBox>
                                                                      </children>
                                                                  </HBox>
                                                                  <ListView fx:id="listSelectedProducts" prefHeight="150.0" styleClass="modern-list-view" />
                                                                  <HBox alignment="CENTER_RIGHT">
                                                                      <children>
                                                                          <Label fx:id="lblSelectedCount" text="%vat.mass.selected_count" styleClass="label-muted" />
                                                                      </children>
                                                                  </HBox>
                                                               </children>
                                                            </VBox>
                                                        </children>
                                                    </VBox>
                                                </children>
                                             </VBox>
                                         </children>
                                     </VBox>

                                     <!--  STEP 3: Aplicaci&#x00f3;n del Reajuste  -->
                                     <VBox spacing="10.0">
                                         <children>
                                             <HBox alignment="CENTER_LEFT" spacing="10">
                                                 <children>
                                                     <Label text="3" styleClass="step-number" />
                                                     <Label styleClass="estetica-card-title" text="%vat.mass.step3" />
                                                 </children>
                                             </HBox>

                                             <VBox styleClass="estetica-card">
                                                <children>
                                                    <VBox spacing="20.0" styleClass="estetica-card-body">
                                                        <children>
                                                           <HBox alignment="CENTER_LEFT" spacing="25.0">
                                                              <children>
                                                                 <VBox spacing="6.0" minWidth="150">
                                                                    <children>
                                                                       <Label fx:id="lblPriceValue" styleClass="label-bold" text="%vat.mass.field.value" />
                                                                       <TextField fx:id="txtPriceValue" prefWidth="150.0" promptText="Ej: 5 (o -5)" styleClass="modern-text-field, font-large-bold"/>
                                                                    </children>
                                                                 </VBox>
                                                                  <VBox spacing="6.0" minWidth="150">
                                                                     <children>
                                                                        <Label styleClass="label-bold" text="%vat.mass.field.start_date" />
                                                                        <DatePicker fx:id="dpPriceStartDate" prefWidth="150.0" promptText="%vat.mass.field.start_date.prompt" styleClass="modern-datepicker" />
                                                                     </children>
                                                                  </VBox>
                                                                  <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                                     <children>
                                                                        <Label styleClass="label-bold" text="%vat.mass.field.reason" />
                                                                        <TextField fx:id="txtPriceReason"
                                                                                   promptText="%vat.mass.field.reason.prompt"
                                                                                   styleClass="modern-text-field" />
                                                                     </children>
                                                                  </VBox>
                                                              </children>
                                                           </HBox>

                                                           <Button fx:id="btnApplyPriceHike"
                                                                   maxWidth="1.7976931348623157E308"
                                                                   mnemonicParsing="false"
                                                                   onAction="#handleMassivePriceUpdate"
                                                                   styleClass="estetica-btn-save"
                                                                   text="%vat.mass.btn.execute">
                                                              <graphic>
                                                                  <FontAwesomeIconView glyphName="BOLT" />
                                                              </graphic>
                                                           </Button>
                                                        </children>
                                                    </VBox>
                                                </children>
                                             </VBox>
                                         </children>
                                     </VBox>
                                 </children>
                                 </VBox>
                                </content>
                              </ScrollPane>
                           </children>
                        </AnchorPane>
                  </content>
                </Tab>

                <!-- PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP -->
                <!--  PESTA&#x00d1A;: CAT&#x00c1;LOGO DE IMPUESTOS (MANTENIMIENTO)                -->
                <!-- PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP -->
                <Tab fx:id="tabCatalog" text="%vat.tab.catalog">
                    <graphic>
                        <FontAwesomeIconView glyphName="LIST_ALT" size="14" />
                    </graphic>
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0">
                       <children>
                          <ScrollPane fitToWidth="true" styleClass="scroll-pane" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                             <content>
                                <VBox spacing="25.0" styleClass="view-body-padding">
                                   <children>
                                      <!-- Secci&#x00f3;n 1: Tasas Impositivas -->
                                      <VBox spacing="15.0" styleClass="config-card">
                                         <children>
                                            <HBox alignment="CENTER_LEFT" spacing="15.0">
                                               <children>
                                                  <VBox styleClass="view-header-icon-wrap, icon-wrap-primary">
                                                     <children>
                                                        <FontAwesomeIconView fill="WHITE" glyphName="PERCENT" size="20" />
                                                     </children>
                                                  </VBox>
                                                  <VBox HBox.hgrow="ALWAYS">
                                                     <children>
                                                        <Label styleClass="config-card-title" text="%vat.catalog.rates.title" />
                                                        <Label styleClass="label-muted" text="%vat.catalog.rates.desc" />
                                                     </children>
                                                  </VBox>
                                                  <Button mnemonicParsing="false" onAction="#handleAddTaxRate" styleClass="btn-primary" text="%vat.catalog.btn.new_rate">
                                                     <graphic>
                                                        <FontAwesomeIconView glyphName="PLUS" size="14" />
                                                     </graphic>
                                                  </Button>
                                               </children>
                                            </HBox>
                                            
                                            <TableView fx:id="taxRatesTable" prefHeight="200.0" styleClass="modern-table-view">
                                               <columns>
                                                  <TableColumn fx:id="colRateName" prefWidth="150.0" text="%vat.table.name" />
                                                  <TableColumn fx:id="colRateValue" prefWidth="100.0" text="%vat.table.rate" />
                                                  <TableColumn fx:id="colRateCountry" prefWidth="120.0" text="%vat.table.country" />
                                                  <TableColumn fx:id="colRateStatus" prefWidth="100.0" text="%vat.table.status" />
                                                  <TableColumn fx:id="colRateActions" prefWidth="120.0" text="%vat.table.actions" />
                                               </columns>
                                               <columnResizePolicy>
                                                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                               </columnResizePolicy>
                                            </TableView>
                                         </children>
                                      </VBox>

                                      <!-- Secci&#x00f3;n 2: Grupos Fiscales -->
                                      <VBox spacing="15.0" styleClass="config-card">
                                         <children>
                                            <HBox alignment="CENTER_LEFT" spacing="15.0">
                                               <children>
                                                  <VBox styleClass="view-header-icon-wrap, icon-wrap-success">
                                                     <children>
                                                        <FontAwesomeIconView fill="WHITE" glyphName="TAGS" size="20" />
                                                     </children>
                                                  </VBox>
                                                  <VBox HBox.hgrow="ALWAYS">
                                                     <children>
                                                        <Label styleClass="config-card-title" text="%vat.catalog.groups.title" />
                                                        <Label styleClass="label-muted" text="%vat.catalog.groups.desc" />
                                                     </children>
                                                  </VBox>
                                                  <Button mnemonicParsing="false" onAction="#handleAddTaxGroup" styleClass="btn-success" text="%vat.catalog.btn.new_group">
                                                     <graphic>
                                                        <FontAwesomeIconView glyphName="PLUS" size="14" />
                                                     </graphic>
                                                  </Button>
                                               </children>
                                            </HBox>
                                            
                                            <TableView fx:id="taxGroupsTable" prefHeight="220.0" styleClass="modern-table-view">
                                               <columns>
                                                  <TableColumn fx:id="colGroupName" prefWidth="200.0" text="%vat.table.group_name" />
                                                  <TableColumn fx:id="colGroupDefault" prefWidth="120.0" text="%vat.table.default" />
                                                  <TableColumn fx:id="colGroupRates" prefWidth="300.0" text="%vat.table.included_rates" />
                                                  <TableColumn fx:id="colGroupActions" prefWidth="150.0" text="%vat.table.actions" />
                                               </columns>
                                               <columnResizePolicy>
                                                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                               </columnResizePolicy>
                                            </TableView>
                                         </children>
                                      </VBox>
                                   </children>
                                </VBox>
                             </content>
                          </ScrollPane>
                       </children>
                    </AnchorPane>
                  </content>
                </Tab>

                <!-- PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP -->
                <!--  PESTA&#x00d1A;: HISTORIAL DE REVISIONES                             -->
                <!-- PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP -->
                <Tab fx:id="tabHistory" text="%vat.tab.history">
                    <graphic>
                        <FontAwesomeIconView glyphName="HISTORY" size="14" />
                    </graphic>
                  <content>
                    <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="10.0">
                                 <children>

                                    <!-- Filtro de historial IVA -->
                                    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="modern-filter-bar">
                                       <children>
                                          <Label styleClass="label-muted" text="%vat.field.date" />
                                          <HBox spacing="8" styleClass="date-filter-container">
                                              <children>
                                                  <ToggleButton fx:id="tglHistHoy" text="%btn.today" styleClass="date-filter-chip" onAction="#handleQuickDateFilter" />
                                                  <ToggleButton fx:id="tglHist7d" text="%btn.7days" styleClass="date-filter-chip" onAction="#handleQuickDateFilter" />
                                                  <ToggleButton fx:id="tglHist1m" text="%btn.1month" styleClass="date-filter-chip" onAction="#handleQuickDateFilter" />
                                                  <ToggleButton fx:id="tglHistTodo" text="%btn.all" styleClass="date-filter-chip" onAction="#handleQuickDateFilter" selected="true" />
                                              </children>
                                          </HBox>
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Button mnemonicParsing="false" onAction="#handleRefreshHistory" styleClass="btn-history-close" text="%btn.refresh">
                                             <graphic>
                                                <FontAwesomeIconView glyphName="REFRESH" />
                                             </graphic>
                                          </Button>
                                       </children>
                                    </HBox>

                                    <!-- Tabla historial IVA -->
                                    <TableView fx:id="historyTable" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" styleClass="modern-table-view">
                                      <columns>
                                        <TableColumn fx:id="colDate" prefWidth="150.0" text="%vat.table.start_date" />
                                          <TableColumn fx:id="colEndDate" prefWidth="150.0" text="%vat.table.end_date" />
                                        <TableColumn fx:id="colScope" prefWidth="120.0" text="%vat.table.scope" />
                                          <TableColumn fx:id="colTarget" prefWidth="150.0" text="%vat.table.target" />
                                          <TableColumn fx:id="colRate" prefWidth="80.0" text="%vat.table.rate_alias" />
                                          <TableColumn fx:id="colReason" prefWidth="250.0" text="%vat.table.reason" />
                                      </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>

                                    <!-- Separador -->
                                    <Label styleClass="history-subtitle" text="&#x25bc;  %vat.history.mass.title" />

                                    <!-- Tabla historial actualizaciones de precio -->
                                    <TableView fx:id="priceLogTable" prefHeight="180.0" VBox.vgrow="ALWAYS" styleClass="modern-table-view">
                                       <columns>
                                          <TableColumn fx:id="colLogDate" prefWidth="150.0" text="%vat.table.date_alias" />
                                          <TableColumn fx:id="colLogType" prefWidth="160.0" text="%vat.table.type" />
                                          <TableColumn fx:id="colLogScope" prefWidth="130.0" text="%vat.table.grouping_alias" />
                                          <TableColumn fx:id="colLogCategory" prefWidth="150.0" text="%vat.table.detail" />
                                          <TableColumn fx:id="colLogValue" prefWidth="100.0" text="%vat.table.value_alias" />
                                          <TableColumn fx:id="colLogProducts" prefWidth="100.0" text="%vat.table.products_count" />
                                          <TableColumn fx:id="colLogReason" prefWidth="250.0" text="MOTIVO" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>

                                 </children>
                              </VBox>
                           </children></AnchorPane>
                  </content>
                </Tab>
              </tabs>
            </TabPane>
         </children>
      </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>


