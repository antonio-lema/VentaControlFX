<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="rootPane"
            fx:controller="com.mycompany.ventacontrolfx.controller.MainController"
            prefWidth="1200" prefHeight="800"
            style="-fx-background-color: #f4f6f9;">

    <top>
        <StackPane fx:id="headerContainer" />
    </top>

    <left>
        <StackPane fx:id="sidebarContainer" />
    </left>

    <center>
        <StackPane>
            <ScrollPane fx:id="mainContent" fitToHeight="true" fitToWidth="true" style="-fx-background: #f4f6f9; -fx-background-color: transparent;">
                <!-- Main view content will be injected here -->
            </ScrollPane>
            
            <!-- Loading Overlay (Global for center) -->
            <VBox fx:id="loadingOverlay" visible="false" alignment="CENTER" style="-fx-background-color: rgba(244, 246, 249, 0.7);">
                <ProgressIndicator />
                <Label text="Cargando..." style="-fx-text-fill: #666; -fx-padding: 10 0 0 0;"/>
            </VBox>
        </StackPane>
    </center>

    <right>
        <StackPane fx:id="cartContainer" />
    </right>

</BorderPane>
