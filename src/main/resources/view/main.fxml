<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.ventacontrolfx.controller.MainController"
            prefWidth="1200" prefHeight="800"
            style="-fx-background-color: #f4f6f9;">

    <!-- TOP HEADER -->
    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="top-bar">
            <padding>
                <Insets top="10" right="20" bottom="10" left="20"/>
            </padding>
            
            <!-- Logo area -->
            <Label text="TPV" styleClass="logo-text"/>
            <Label text="GestionTPV" styleClass="brand-text"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Search Bar -->
            <HBox fx:id="searchBarContainer" alignment="CENTER_LEFT" styleClass="search-bar">
                <Label text="🔍" style="-fx-text-fill: #aaa; -fx-padding: 0 5 0 10;"/>
                <TextField fx:id="searchField" promptText="Código, ref o nombre" styleClass="search-field"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Admin Panel with Dropdown Menu -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <!-- Three dots menu button -->
                <MenuButton fx:id="menuButton" text="⋮" styleClass="menu-button" style="-fx-padding: 2 8; -fx-font-size: 20px;">
                    <items>
                        <MenuItem text="Cerrar caja"/>
                        <MenuItem text="Usuario"/>
                    </items>
                </MenuButton>
                
                <!-- Admin Profile -->
                <HBox spacing="5" alignment="CENTER_LEFT" styleClass="user-profile">
                     <Circle radius="15" fill="white"/>
                     <Label text="Admin" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>
            </HBox>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="5" styleClass="sidebar">
            <padding>
                <Insets top="20" right="10" bottom="20" left="10"/>
            </padding>
            
            <Button fx:id="btnPanel" styleClass="sidebar-button" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="icon-container">
                            <FontAwesomeIconView glyphName="DASHBOARD" size="20" styleClass="sidebar-icon"/>
                        </StackPane>
                        <Label text="Panel" styleClass="sidebar-button-label"/>
                    </HBox>
                </graphic>
            </Button>
            <Button fx:id="btnSell" styleClass="sidebar-button, active-sidebar-button" onAction="#showSellView" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                       <StackPane styleClass="icon-container">
                            <FontAwesomeIconView glyphName="SHOPPING_CART" size="20" styleClass="sidebar-icon"/>
                       </StackPane>
                       <Label text="Vender" styleClass="sidebar-button-label"/>
                    </HBox>
                </graphic>
            </Button>

            <!-- Products Dropdown -->
            <!-- Products Dropdown -->
            <Button fx:id="btnProducts" styleClass="sidebar-button" onAction="#toggleProductsMenu" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity">
                <graphic>
                   <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="15">
                       <StackPane styleClass="icon-container">
                           <FontAwesomeIconView glyphName="TAGS" size="20" styleClass="sidebar-icon"/>
                       </StackPane>
                       <Label text="Productos" styleClass="sidebar-button-label"/> 
                       <Region HBox.hgrow="ALWAYS"/>
                       <Label fx:id="lblProductsArrow" text="&lt;" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                   </HBox>
                </graphic>
            </Button>
            <VBox fx:id="productsSubmenu" managed="false" visible="false" spacing="0">
                <padding><Insets left="20"/></padding>
                <Button fx:id="btnProductsList" text="Lista de Productos" styleClass="sidebar-button" onAction="#showProductsView"/>
                <Button fx:id="btnCategories" text="Categorías" styleClass="sidebar-button" onAction="#showCategoriesView"/>
            </VBox>
            <Button fx:id="btnHistory" styleClass="sidebar-button" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity">
                 <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="icon-container">
                            <FontAwesomeIconView glyphName="HISTORY" size="20" styleClass="sidebar-icon"/>
                        </StackPane>
                        <Label text="Historial" styleClass="sidebar-button-label"/>
                    </HBox>
                </graphic>
            </Button>
            <Button fx:id="btnClients" styleClass="sidebar-button" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="icon-container">
                            <FontAwesomeIconView glyphName="USERS" size="20" styleClass="sidebar-icon"/>
                        </StackPane>
                        <Label text="Clientes" styleClass="sidebar-button-label"/>
                    </HBox>
                </graphic>
            </Button>

            <Button fx:id="btnUsers" styleClass="sidebar-button" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="icon-container">
                            <FontAwesomeIconView glyphName="USER_CIRCLE" size="20" styleClass="sidebar-icon"/>
                        </StackPane>
                        <Label text="Usuarios" styleClass="sidebar-button-label"/>
                    </HBox>
                </graphic>
            </Button>
            <Button fx:id="btnConfig" styleClass="sidebar-button" contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity">
                <graphic>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <StackPane styleClass="icon-container">
                            <FontAwesomeIconView glyphName="COG" size="20" styleClass="sidebar-icon"/>
                        </StackPane>
                        <Label text="Configuración" styleClass="sidebar-button-label"/>
                    </HBox>
                </graphic>
            </Button>
            
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="15" alignment="CENTER">
                 <Button text="⚙" styleClass="sidebar-icon-only"/>
                 <Button text="✉" styleClass="sidebar-icon-only"/>
                 <Button text="⏻" styleClass="sidebar-icon-only"/>
            </HBox>
        </VBox>
    </left>


    <!-- CENTER CONTENT (Start with Products) -->
    <center>
        <BorderPane>
            <center>
                <VBox>
                    <!-- Filter Display Label -->
                    <HBox fx:id="filterDisplayContainer" alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to right, #f8f9fa, #ffffff); -fx-padding: 15 25; -fx-border-color: #e3f2fd; -fx-border-width: 0 0 2 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                        <Label text="Mostrando:" style="-fx-font-size: 14px; -fx-text-fill: #666; -fx-font-weight: 500;"/>
                        <Label fx:id="filterLabel" text="Favoritos ⭐" style="-fx-font-size: 20px; -fx-text-fill: #1e88e5; -fx-font-weight: bold; -fx-padding: 0 0 0 10;"/>
                    </HBox>
                    
                    <!-- Products Area -->
                    <StackPane VBox.vgrow="ALWAYS">
                        <ScrollPane fx:id="mainContent" fitToWidth="true" style="-fx-background: #f4f6f9; -fx-background-color: transparent;">
                            <TilePane fx:id="productsPane" hgap="15" vgap="15" prefColumns="4" style="-fx-padding: 20;">
                                <!-- Products will be added here dynamically -->
                            </TilePane>
                        </ScrollPane>
                        
                        <!-- Loading Overlay -->
                        <VBox fx:id="loadingOverlay" visible="false" alignment="CENTER" style="-fx-background-color: rgba(244, 246, 249, 0.7);">
                            <ProgressIndicator />
                            <Label text="Cargando..." style="-fx-text-fill: #666; -fx-padding: 10 0 0 0;"/>
                        </VBox>
                    </StackPane>
                </VBox>
            </center>
            <bottom>
                <HBox alignment="TOP_LEFT" spacing="10" style="-fx-padding: 10;">
                    <ScrollPane fx:id="categoriesScrollPane" hbarPolicy="NEVER" vbarPolicy="NEVER" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" prefHeight="85" maxHeight="85" HBox.hgrow="ALWAYS">
                        <FlowPane fx:id="categoriesFlowPane" hgap="10" vgap="10" style="-fx-background-color: transparent;" />
                    </ScrollPane>
                    <Button fx:id="btnExpandCategories" text="▼" styleClass="action-btn" onAction="#handleExpandCategories" />
                </HBox>
            </bottom>
        </BorderPane>
    </center>

    <!-- RIGHT PANEL (Cart) -->
    <right>
        <VBox fx:id="cartPanel" spacing="0" styleClass="cart-panel" prefWidth="450">
            
            <!-- Customer Selection -->
            <HBox alignment="CENTER_LEFT" styleClass="cart-header">
                <Label text="👤 Añadir empresa" style="-fx-text-fill: #888; -fx-font-size: 20px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="+" style="-fx-background-color: transparent; -fx-text-fill: #999; -fx-font-size: 30px;"/>
            </HBox>
            
            <!-- Cart Items Header -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 10 15; -fx-border-color: #eee; -fx-border-width: 0 0 1 0;">
                <Label text="Artículos" style="-fx-font-weight: bold; -fx-text-fill: #555;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnClearCart" onAction="#clearCart" style="-fx-background-color: transparent; -fx-text-fill: #e53935; -fx-cursor: hand; -fx-font-size: 13px; -fx-font-weight: bold;" text="Vaciar 🗑"/>
            </HBox>

            <!-- Cart Items (Use ScrollPane + VBox for custom rows) -->
            <StackPane VBox.vgrow="ALWAYS" style="-fx-background-color: white;">
                <VBox fx:id="emptyCartView" alignment="CENTER" spacing="10">
                    <Label text="🛒" style="-fx-font-size: 60px; -fx-text-fill: #eee;"/>
                </VBox>
                
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" hbarPolicy="NEVER">
                    <VBox fx:id="cartItemsContainer" spacing="0" styleClass="cart-list-container"/>
                </ScrollPane>
            </StackPane>
            
            <!-- Bottom Actions -->
            <VBox spacing="0" style="-fx-background-color: white;" minHeight="-Infinity">
                
                <!-- Subtotal -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 15 15 5 15;">
                    <Label fx:id="itemsCountLabel" text="Subtotal (0 item)" style="-fx-text-fill: #666; -fx-font-size: 14px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="subtotalLabel" text="0,00 €" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                </HBox>

                <!-- Tax (Impuestos) -->
                <HBox alignment="CENTER_LEFT" style="-fx-padding: 5 15 15 15;">
                    <Label text="Impuestos (21%)" style="-fx-text-fill: #666; -fx-font-size: 14px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="taxLabel" text="0,00 €" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                </HBox>
                
                <!-- Pay Button (Pink) -->
                <StackPane style="-fx-padding: 0 15 15 15;">
                     <Button fx:id="payButton" text="Pagar" 
                             onAction="#handlePayButton"
                             styleClass="pay-button" 
                             maxWidth="Infinity" 
                             prefHeight="55" alignment="CENTER_LEFT">
                        <padding>
                            <Insets left="20"/>
                        </padding>
                     </Button>
                     <Label fx:id="totalButtonLabel" text="0,00 €" mouseTransparent="true"
                            style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;" 
                            StackPane.alignment="CENTER_RIGHT">
                        <padding>
                            <Insets right="20"/>
                        </padding>
                     </Label>
                </StackPane>
                
            </VBox>

        </VBox>
    </right>

</BorderPane>
