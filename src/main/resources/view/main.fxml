<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="rootPane"
            fx:controller="com.mycompany.ventacontrolfx.presentation.controller.MainController"
            prefWidth="1200" prefHeight="800"
            styleClass="main-background">

    <top>
        <StackPane fx:id="headerContainer" />
    </top>

    <left>
        <StackPane fx:id="sidebarContainer" />
    </left>

    <center>
        <StackPane>
            <ScrollPane fx:id="mainContent" fitToHeight="true" fitToWidth="true" styleClass="main-content-scroll">
                <!-- Main view content will be injected here -->
            </ScrollPane>
            
            <!-- Loading Overlay (Global for center) -->
            <VBox fx:id="loadingOverlay" visible="false" alignment="CENTER" styleClass="loading-overlay">
                <ProgressIndicator />
                <Label text="Cargando..." styleClass="label-muted"/>
            </VBox>
        </StackPane>
    </center>

    <right>
        <StackPane fx:id="cartContainer" />
    </right>

</BorderPane>
