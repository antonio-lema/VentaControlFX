<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.controller.RegisterUserController"
           styleClass="register-popup-background" fx:id="rootStackPane"
           onMousePressed="#handleMousePressed" onMouseDragged="#handleMouseDragged">

    <!-- Modern Registration Card -->
    <VBox alignment="CENTER" spacing="0" maxWidth="450" styleClass="modern-register-card">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Header -->
        <VBox styleClass="modern-register-header" alignment="CENTER_LEFT">
             <Label text="Crear Nueva Cuenta" styleClass="modern-register-title"/>
             <Label text="Introduce los datos del nuevo usuario" styleClass="modern-register-subtitle"/>
        </VBox>

        <!-- Form Fields -->
        <VBox spacing="15">
            
            <!-- Full Name -->
            <VBox styleClass="modern-input-group">
                <HBox styleClass="modern-input-container">
                    <FontAwesomeIconView fx:id="iconUser" glyphName="USER" size="18" fill="#b0b0b0"/>
                    <TextField fx:id="txtFullName" promptText="Nombre completo" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                </HBox>
            </VBox>
            
            <!-- Username & Email Row -->
            <HBox spacing="15">
                <VBox styleClass="modern-input-group" HBox.hgrow="ALWAYS">
                    <HBox styleClass="modern-input-container">
                        <FontAwesomeIconView fx:id="iconUserCircle" glyphName="USER_CIRCLE" size="18" fill="#b0b0b0"/>
                        <TextField fx:id="txtUsername" promptText="Usuario" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                    </HBox>
                </VBox>
                
                 <VBox styleClass="modern-input-group" HBox.hgrow="ALWAYS">
                    <HBox styleClass="modern-input-container">
                        <FontAwesomeIconView fx:id="iconEnvelope" glyphName="ENVELOPE" size="16" fill="#b0b0b0"/>
                        <TextField fx:id="txtEmail" promptText="Email (Opcional)" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                    </HBox>
                </VBox>
            </HBox>
            
            <!-- Role Selection -->
            <VBox styleClass="modern-input-group">
                <HBox styleClass="modern-input-container">
                    <FontAwesomeIconView fx:id="iconUsers" glyphName="USERS" size="16" fill="#b0b0b0"/>
                    <ComboBox fx:id="cmbRole" promptText="Seleccionar Rol" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="modern-combo-box">
                         <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="admin"/>
                                <String fx:value="cajero"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                </HBox>
            </VBox>

            <!-- Password -->
            <VBox styleClass="modern-input-group">
                <HBox styleClass="modern-input-container">
                    <FontAwesomeIconView fx:id="iconLock" glyphName="LOCK" size="18" fill="#b0b0b0"/>
                    <PasswordField fx:id="txtPassword" promptText="Contraseña" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                </HBox>
            </VBox>

            <!-- Confirm Password -->
            <VBox styleClass="modern-input-group">
                <HBox styleClass="modern-input-container">
                    <FontAwesomeIconView fx:id="iconCheck" glyphName="CHECK_CIRCLE" size="18" fill="#b0b0b0"/>
                    <PasswordField fx:id="txtConfirmPassword" promptText="Confirmar contraseña" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                </HBox>
            </VBox>
        </VBox>

        <Label fx:id="lblError" text="" styleClass="modern-error-label" wrapText="true" visible="false" managed="false"/>
        
        <!-- Spacer -->
        <VBox minHeight="20" />

        <!-- Actions -->
        <HBox spacing="15" alignment="CENTER_RIGHT">
             <Button text="Cancelar" onAction="#handleCancel" styleClass="modern-btn-secondary"/>
             <Button text="Registrar Usuario" onAction="#handleRegister" styleClass="modern-btn-primary"/>
        </HBox>

    </VBox>
</StackPane>
