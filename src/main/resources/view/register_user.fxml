<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.ventacontrolfx.presentation.controller.RegisterUserController"
           styleClass="register-popup-background" fx:id="rootStackPane"
           onMousePressed="#handleMousePressed" onMouseDragged="#handleMouseDragged">

    <!-- Modern Registration Card -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-background: transparent;" maxHeight="700">
        <content>
            <VBox alignment="CENTER" spacing="0" maxWidth="480" minWidth="480" styleClass="modern-register-card">
                <padding>
                    <Insets top="35" right="40" bottom="35" left="40"/>
                </padding>

                <!-- Header -->
                <VBox styleClass="modern-register-header" alignment="CENTER_LEFT">
                    <Label fx:id="lblTitle" text="Crear Nueva Cuenta" styleClass="modern-register-title"/>
                    <Label text="Introduce los datos del nuevo usuario" styleClass="modern-register-subtitle"/>
                </VBox>

                <!-- ── DATOS BÁSICOS ── -->
                <VBox spacing="12">

                    <!-- Full Name -->
                    <VBox styleClass="modern-input-group">
                        <HBox styleClass="modern-input-container">
                            <FontAwesomeIconView fx:id="iconUser" glyphName="USER" size="18" styleClass="sidebar-icon"/>
                            <TextField fx:id="txtFullName" promptText="Nombre completo" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                        </HBox>
                    </VBox>

                    <!-- Username & Email Row -->
                    <HBox spacing="12">
                        <VBox styleClass="modern-input-group" HBox.hgrow="ALWAYS">
                            <HBox styleClass="modern-input-container">
                                <FontAwesomeIconView glyphName="USER_CIRCLE" size="18" styleClass="sidebar-icon"/>
                                <TextField fx:id="txtUsername" promptText="Usuario" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                            </HBox>
                        </VBox>
                        <VBox styleClass="modern-input-group" HBox.hgrow="ALWAYS">
                            <HBox styleClass="modern-input-container">
                                <FontAwesomeIconView glyphName="ENVELOPE" size="16" styleClass="sidebar-icon"/>
                                <TextField fx:id="txtEmail" promptText="Email (Opcional)" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- Role Selection -->
                    <VBox styleClass="modern-input-group">
                        <HBox styleClass="modern-input-container">
                            <FontAwesomeIconView glyphName="USERS" size="16" styleClass="sidebar-icon"/>
                            <ComboBox fx:id="cmbRole" promptText="Seleccionar Rol" maxWidth="Infinity" HBox.hgrow="ALWAYS" styleClass="modern-combo-box">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="admin"/>
                                        <String fx:value="cajero"/>
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </HBox>
                    </VBox>

                    <!-- Password Row -->
                    <HBox spacing="12">
                        <VBox styleClass="modern-input-group" HBox.hgrow="ALWAYS">
                            <HBox styleClass="modern-input-container">
                                <FontAwesomeIconView glyphName="LOCK" size="18" styleClass="sidebar-icon"/>
                                <PasswordField fx:id="txtPassword" promptText="Contraseña" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                            </HBox>
                        </VBox>
                        <VBox styleClass="modern-input-group" HBox.hgrow="ALWAYS">
                            <HBox styleClass="modern-input-container">
                                <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="18" styleClass="sidebar-icon"/>
                                <PasswordField fx:id="txtConfirmPassword" promptText="Confirmar" HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ── SECCIÓN DE PERMISOS ── -->
                <VBox spacing="10" style="-fx-padding: 16 0 0 0;">
                    <!-- Cabecera de la sección -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <FontAwesomeIconView glyphName="SHIELD" size="16" styleClass="sidebar-icon"/>
                        <Label text="Zonas de Acceso" styleClass="permission-section-title"/>
                    </HBox>
                    <Label text="Selecciona las secciones a las que tendrá acceso este usuario"
                           styleClass="permission-section-subtitle" wrapText="true"/>

                    <!-- Contenedor donde el controller renderiza los checkboxes dinámicamente -->
                    <VBox fx:id="permissionsContainer" spacing="8" styleClass="permissions-box">
                        <padding>
                            <Insets top="10" right="15" bottom="10" left="15"/>
                        </padding>
                        <!-- Los CheckBox se inyectan dinámicamente desde RegisterUserController -->
                    </VBox>
                </VBox>

                <!-- Error label -->
                <Label fx:id="lblError" text="" styleClass="modern-error-label" wrapText="true"
                       visible="false" managed="false" style="-fx-padding: 8 0 0 0;"/>

                <!-- Spacer -->
                <VBox minHeight="16"/>

                <!-- Actions -->
                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button fx:id="btnCancel" text="Cancelar" onAction="#handleCancel"
                            styleClass="modern-btn-secondary" cancelButton="true"/>
                    <Button fx:id="btnRegister" text="Guardar Usuario" onAction="#handleRegister"
                            styleClass="modern-btn-primary" defaultButton="true"/>
                </HBox>

            </VBox>
        </content>
    </ScrollPane>
</StackPane>
