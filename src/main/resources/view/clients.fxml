<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ClientsController"
      spacing="20" styleClass="main-content-area" style="-fx-padding: 25 25 10 25;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox HBox.hgrow="ALWAYS">
            <Label text="Gestión de Empresas" styleClass="section-title"/>
            <Label text="Selecciona o añade una empresa para la factura" styleClass="section-subtitle"/>
        </VBox>

        <Button fx:id="btnToggleForm" text=" Nueva Empresa" onAction="#handleAddClient"
                styleClass="btn-primary">
            <graphic>
                <FontAwesomeIconView glyphName="PLUS" size="14" fill="WHITE"/>
            </graphic>
        </Button>
    </HBox>

    <HBox VBox.vgrow="ALWAYS" spacing="25">

        <!-- List Section (Left) -->
        <VBox spacing="15" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <!-- Search Bar -->
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="search-bar">
                <FontAwesomeIconView glyphName="SEARCH" size="16" styleClass="sidebar-icon"/>
                <TextField fx:id="searchField" promptText="Buscar por nombre, CIF o teléfono..."
                           HBox.hgrow="ALWAYS" styleClass="search-field"/>
                <Button fx:id="btnClearSearch" visible="false" styleClass="btn-icon">
                    <graphic><FontAwesomeIconView glyphName="CLOSE" size="12" styleClass="sidebar-icon"/></graphic>
                </Button>
            </HBox>

            <!-- Clients List Container -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="detail-scroll" hbarPolicy="NEVER">
                <FlowPane fx:id="clientsListContainer" hgap="20" vgap="20" style="-fx-padding: 10; -fx-background-color: transparent;"/>
            </ScrollPane>

            <!-- Count Section -->
            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 5 10;">
                <children>
                    <Label fx:id="lblCount" text="0 empresas encontradas" styleClass="label-muted" style="-fx-font-weight: bold;"/>
                </children>
            </HBox>
        </VBox>

        <!-- Form Section (Right) - populated dynamically -->
    </HBox>
</VBox>
