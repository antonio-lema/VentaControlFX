<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.layout.StackPane?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ClientsController"
      spacing="0" styleClass="main-content-area" style="-fx-padding: 0;">

    <!-- Header Section -->
    <VBox styleClass="view-header" spacing="0">
        <children>
            <HBox spacing="16" alignment="CENTER_LEFT">
                <children>
                    <StackPane styleClass="view-header-icon-wrap">
                        <children><FontAwesomeIconView glyphName="USERS" size="24" fill="white"/></children>
                    </StackPane>
                    <VBox spacing="2">
                        <children>
                            <Label text="%clients.title" styleClass="view-title"/>
                            <Label text="%clients.subtitle" styleClass="view-subtitle"/>
                        </children>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="btnToggleForm" text="%clients.btn.new" onAction="#handleAddClient"
                            styleClass="btn-primary">
                        <graphic>
                            <FontAwesomeIconView glyphName="PLUS" size="14" fill="WHITE"/>
                        </graphic>
                    </Button>
                </children>
            </HBox>
        </children>
    </VBox>

    <VBox spacing="20.0" VBox.vgrow="ALWAYS" style="-fx-padding: 25 25 10 25;">

    <HBox VBox.vgrow="ALWAYS" spacing="25">

        <!-- List Section (Left) -->
        <VBox spacing="15" HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <!-- Search Bar -->
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="search-bar">
                <FontAwesomeIconView glyphName="SEARCH" size="16" styleClass="sidebar-icon"/>
                <TextField fx:id="searchField" promptText="%clients.search.prompt"
                           HBox.hgrow="ALWAYS" styleClass="search-field"/>
                <Button fx:id="btnClearSearch" visible="false" styleClass="btn-icon">
                    <graphic><FontAwesomeIconView glyphName="CLOSE" size="12" styleClass="sidebar-icon"/></graphic>
                </Button>
            </HBox>

            <!-- Clients Card Container -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="detail-scroll" hbarPolicy="NEVER">
                <FlowPane fx:id="clientsListContainer" hgap="25" vgap="25" style="-fx-padding: 15; -fx-background-color: transparent;"/>
            </ScrollPane>
            
            <!-- Count Section -->
            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 15;">
                <children>
                    <Label fx:id="lblCount" text="%clients.found_count" styleClass="label-muted" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                </children>
            </HBox>
        </VBox>

        <!-- Form Section (Right) - populated dynamically -->
    </HBox>
</VBox>
</VBox>
