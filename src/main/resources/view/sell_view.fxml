<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="sellViewRoot"
            fx:controller="com.mycompany.ventacontrolfx.presentation.controller.SellViewController"
            styleClass="main-content-area">
    <center>
        <VBox spacing="0">
            <HBox alignment="CENTER_LEFT" styleClass="view-header-bar">
                <StackPane styleClass="filter-icon-container">
                     <FontAwesomeIconView glyphName="FILTER" size="18" fill="WHITE"/>
                </StackPane>
                <VBox alignment="CENTER_LEFT" spacing="2">
                     <Label text="Mostrando en este momento:" styleClass="label-muted" style="-fx-font-size: 11px;"/>
                     <Label fx:id="filterLabel" text="Todos los productos" styleClass="section-title" style="-fx-font-size: 18px;"/>
                </VBox>
            </HBox>
            
            <StackPane VBox.vgrow="ALWAYS">
                <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="products-scroll-pane">
                    <TilePane fx:id="productsPane" hgap="20" vgap="20" prefColumns="4">
                        <padding>
                            <Insets top="25" right="25" bottom="25" left="25"/>
                        </padding>
                    </TilePane>
                </ScrollPane>
                <VBox fx:id="loadingOverlay" visible="false" alignment="CENTER" styleClass="loading-overlay">
                    <ProgressIndicator />
                    <Label text="Cargando productos..." styleClass="label-muted"/>
                </VBox>
            </StackPane>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="categories-bar">
            <ScrollPane fx:id="categoriesScrollPane" hbarPolicy="NEVER" vbarPolicy="NEVER" fitToWidth="true" styleClass="categories-scroll-pane" prefHeight="110" maxHeight="110" HBox.hgrow="ALWAYS">
                <FlowPane fx:id="categoriesFlowPane" hgap="15" vgap="15" styleClass="categories-flow-pane">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                </FlowPane>
            </ScrollPane>
            <Button fx:id="btnExpandCategories" onAction="#handleExpandCategories" styleClass="btn-icon">
                <graphic>
                    <FontAwesomeIconView fx:id="expandIcon" glyphName="CHEVRON_UP" size="16" fill="#1e88e5"/>
                </graphic>
            </Button>
        </HBox>
    </bottom>
</BorderPane>
