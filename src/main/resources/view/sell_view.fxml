<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:id="sellViewRoot"
            fx:controller="com.mycompany.ventacontrolfx.presentation.controller.SellViewController"
            styleClass="main-content-area">
    <center>
        <VBox spacing="0">
            <!-- Replaced legacy header with professional view-header -->
            <VBox styleClass="view-header" spacing="0">
                <children>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <children>
                            <StackPane styleClass="view-header-icon-wrap">
                                <children>
                                    <FontAwesomeIconView glyphName="SHOPPING_CART" size="24" fill="white"/>
                                </children>
                            </StackPane>
                            <VBox spacing="2">
                                <children>
                                    <Label text="Realizar Venta" styleClass="view-title"/>
                                    <Label fx:id="filterLabel" text="Catálogo de productos y punto de venta" styleClass="view-subtitle"/>
                                </children>
                            </VBox>
                            
                            <Region HBox.hgrow="ALWAYS" />
                            
                            <!-- Control Section in Header -->
                            <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="filter-card">
                                <children>
                                    <VBox spacing="2">
                                        <children>
                                            <Label text="TARIFA ACTIVA" styleClass="filter-label-cap" />
                                            <ComboBox fx:id="comboPriceList" prefWidth="200" styleClass="price-list-selector" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                        </children>
                    </HBox>
                </children>
            </VBox>
            
            <StackPane VBox.vgrow="ALWAYS">
                <ScrollPane fitToHeight="true" fitToWidth="true" styleClass="products-scroll-pane">
                    <TilePane fx:id="productsPane" hgap="20" vgap="20" styleClass="products-grid">
                        <padding>
                            <Insets top="25" right="25" bottom="25" left="25"/>
                        </padding>
                    </TilePane>
                </ScrollPane>
                <VBox fx:id="loadingOverlay" visible="false" alignment="CENTER" styleClass="loading-overlay">
                    <ProgressIndicator />
                    <Label text="Cargando productos..." styleClass="label-muted"/>
                </VBox>
            </StackPane>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="categories-bar">
            <ScrollPane fx:id="categoriesScrollPane" hbarPolicy="NEVER" vbarPolicy="NEVER" fitToWidth="true" styleClass="categories-scroll-pane" prefHeight="110" maxHeight="110" HBox.hgrow="ALWAYS">
                <FlowPane fx:id="categoriesFlowPane" hgap="15" vgap="15" styleClass="categories-flow-pane">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>
                </FlowPane>
            </ScrollPane>
            <Button fx:id="btnExpandCategories" onAction="#handleExpandCategories" styleClass="btn-icon">
                <graphic>
                    <FontAwesomeIconView fx:id="expandIcon" glyphName="CHEVRON_UP" size="16" styleClass="icon-primary"/>
                </graphic>
            </Button>
        </HBox>
    </bottom>
</BorderPane>
