<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.mycompany.ventacontrolfx.presentation.controller.dialog.SaleConfigController"
      styleClass="main-content-area" spacing="0">
        <VBox styleClass="view-header">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <StackPane styleClass="view-header-icon-wrap">
                    <FontAwesomeIconView glyphName="COG" size="24" fill="white"/>
                </StackPane>
                <VBox spacing="2">
                    <Label text="%config.title" styleClass="view-title"/>
                    <Label text="%config.subtitle" styleClass="view-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Bot&#x00f3;n Guardar (cabecera) -->
                <Button fx:id="btnSaveTop" text="%config.btn.save" onAction="#handleSave" styleClass="btn-primary" defaultButton="true">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER">
                            <FontAwesomeIconView glyphName="SAVE" size="14" fill="white"/>
                        </HBox>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="detail-scroll, edge-to-edge" VBox.vgrow="ALWAYS">
            <VBox spacing="20" style="-fx-padding: 30;">

                <!--  FILA 1: Empresa -->
                <HBox spacing="20">
                    <!-- Tarjeta: Datos de la Empresa -->
                    <VBox styleClass="config-card" HBox.hgrow="ALWAYS">
                        <!-- Cabecera tarjeta -->
                        <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="config-card-icon-wrap config-icon-blue">
                                <FontAwesomeIconView glyphName="BUILDING" size="16" fill="#1e88e5"/>
                            </StackPane>
                            <Label text="%config.section.company" styleClass="config-card-title"/>
                        </HBox>
                        <Separator styleClass="config-card-separator"/>

                        <VBox spacing="14" styleClass="config-card-body">
                            <!-- Nombre empresa -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.company_name" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="BRIEFCASE" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtCompanyName" promptText="%config.field.company_name.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                            <!-- CIF/NIF -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.cif" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="ID_CARD" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtCif" promptText="%config.field.cif.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                            <!-- Direcci&#x00f3;n -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.address" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="MAP_MARKER" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtAddress" promptText="%config.field.address.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                            <!-- Tel&#x00e9f;ono -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.phone" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="PHONE" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtPhone" promptText="%config.field.phone.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                            <!-- Email empresa -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.email" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="ENVELOPE" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtEmail" promptText="%config.field.email.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- Logo de la empresa -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.logo" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container" spacing="10">
                                    <FontAwesomeIconView glyphName="IMAGE" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtLogoPath" promptText="%config.field.logo.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field" editable="false"/>
                                    <Button text="%config.btn.browse" onAction="#handleBrowseLogo" styleClass="btn-secondary"/>
                                </HBox>
                            </VBox>

                            <!-- Icono de la aplicaci&#x00f3;n -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.icon" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container" spacing="10">
                                    <FontAwesomeIconView glyphName="DESKTOP" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtAppIconPath" promptText="%config.field.icon.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field" editable="false"/>
                                    <Button text="%config.btn.browse" onAction="#handleBrowseIcon" styleClass="btn-secondary"/>
                                </HBox>
                            </VBox>

                            <!-- Nombre de la aplicaci&#x00f3;n -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.app_name" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="WINDOW_MAXIMIZE" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtAppName" promptText="%config.field.app_name.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- Nombre de la Terminal / Caja -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.terminal_name" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="DESKTOP" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtTerminalName" promptText="%config.field.terminal_name.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </HBox>

                <!--  FILA 3: Horarios  -->
                <HBox spacing="20">
                    <VBox styleClass="config-card" HBox.hgrow="ALWAYS" maxWidth="450">
                        <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="config-card-icon-wrap config-icon-purple">
                                <FontAwesomeIconView glyphName="CLOCK_ALT" size="16" fill="#7b1fa2"/>
                            </StackPane>
                            <Label text="%config.section.hours" styleClass="config-card-title"/>
                        </HBox>
                        <Separator styleClass="config-card-separator"/>
                        <VBox spacing="14" styleClass="config-card-body">
                            <Label text="%config.hint.hours" 
                                   styleClass="config-field-hint" wrapText="true"/>
                            <Button text="%config.btn.manage_hours" onAction="#handleShowBusinessHours" 
                                    styleClass="btn-secondary-saas" maxWidth="Infinity">
                                <graphic>
                                    <FontAwesomeIconView glyphName="CALENDAR" size="14" />
                                </graphic>
                            </Button>
                        </VBox>
                    </VBox>
                </HBox>

                <!--  FILA 2: Ticket  -->
                <HBox spacing="20">

                    <!-- Tarjeta: Ticket / Recibo -->
                    <VBox styleClass="config-card" HBox.hgrow="ALWAYS">
                        <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="config-card-icon-wrap config-icon-orange">
                                <FontAwesomeIconView glyphName="FILE_TEXT" size="16" fill="#fb8c00"/>
                            </StackPane>
                            <Label text="%config.section.ticket" styleClass="config-card-title"/>
                        </HBox>
                        <Separator styleClass="config-card-separator"/>

                        <VBox spacing="14" styleClass="config-card-body">
                            <!-- Mostrar logo -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="config-check-row">
                                <CheckBox fx:id="chkShowLogo" text="%config.check.show_logo"
                                          styleClass="config-checkbox"/>
                            </HBox>
                            <!-- Mostrar direcci&#x00f3;n -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="config-check-row">
                                <CheckBox fx:id="chkShowAddress" text="%config.check.show_address"
                                          styleClass="config-checkbox"/>
                            </HBox>
                            <!-- Mostrar tel&#x00e9f;ono -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="config-check-row">
                                <CheckBox fx:id="chkShowPhone" text="%config.check.show_phone"
                                          styleClass="config-checkbox"/>
                            </HBox>
                            <!-- Mostrar CIF -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="config-check-row">
                                <CheckBox fx:id="chkShowCif" text="%config.check.show_cif"
                                          styleClass="config-checkbox"/>
                            </HBox>

                            <!-- Mensaje pie de ticket -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.footer" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="COMMENT" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtFooterMessage" promptText="%config.field.footer.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- N&#x00fa;mero de copias -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.copies" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="PRINT" size="14" styleClass="sidebar-icon"/>
                                    <ComboBox fx:id="cmbTicketCopies" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                              styleClass="modern-combo-box">
                                        <items>
                                            <FXCollections fx:factory="observableArrayList" />
                                        </items>
                                    </ComboBox>
                                </HBox>
                            </VBox>

                            <!-- Formato de ticket -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.format" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="ARROWS_H" size="14" styleClass="sidebar-icon"/>
                                    <ComboBox fx:id="cmbTicketFormat" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                              styleClass="modern-combo-box">
                                        <items>
                                            <FXCollections fx:factory="observableArrayList" />
                                        </items>
                                    </ComboBox>
                                </HBox>
                                <Label text="%config.hint.format" styleClass="config-field-hint"/>
                            </VBox>

                            <!-- Imprimir autom&#x00e1;ticamente -->
                            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="config-check-row">
                                <CheckBox fx:id="chkAutoPrint" text="%config.check.auto_print"
                                          styleClass="config-checkbox"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- Tarjeta: Configuraci&#x00f3;n de Correo (SMTP) -->
                    <VBox styleClass="config-card" HBox.hgrow="ALWAYS">
                        <HBox styleClass="config-card-header" alignment="CENTER_LEFT" spacing="10">
                            <StackPane styleClass="config-card-icon-wrap config-icon-blue">
                                <FontAwesomeIconView glyphName="ENVELOPE" size="16" fill="#1e88e5"/>
                            </StackPane>
                            <Label text="%config.section.smtp" styleClass="config-card-title"/>
                        </HBox>
                        <Separator styleClass="config-card-separator"/>

                        <VBox spacing="14" styleClass="config-card-body">
                            <!-- SMTP Host -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.smtp_host" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="SERVER" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtSmtpHost" promptText="%config.field.smtp_host.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- SMTP Port -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.smtp_port" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="PLUG" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtSmtpPort" promptText="%config.field.smtp_port.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- Email From -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.email_user" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="AT" size="14" styleClass="sidebar-icon"/>
                                    <TextField fx:id="txtEmailFrom" promptText="%config.field.email_user.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>

                            <!-- Email Password -->
                            <VBox styleClass="config-field-group">
                                <Label text="%config.field.email_pass" styleClass="config-field-label"/>
                                <HBox styleClass="config-input-container">
                                    <FontAwesomeIconView glyphName="KEY" size="14" styleClass="sidebar-icon"/>
                                    <PasswordField fx:id="txtEmailPassword" promptText="%config.field.email_pass.prompt"
                                               HBox.hgrow="ALWAYS" styleClass="modern-input-field"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>

                </HBox>


                <!--  Botones de Acci&#x00f3;n finales  -->
                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button text="%config.btn.reset" onAction="#handleReset" styleClass="btn-secondary">
                        <graphic>
                            <HBox spacing="8" alignment="CENTER">
                                <FontAwesomeIconView glyphName="UNDO" size="13" fill="#757575"/>
                            </HBox>
                        </graphic>
                    </Button>
                    <Button text="%config.btn.save" onAction="#handleSave" styleClass="btn-primary" defaultButton="true">
                        <graphic>
                            <HBox spacing="8" alignment="CENTER">
                                <FontAwesomeIconView glyphName="CHECK" size="13" fill="white"/>
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>

                <!-- Banner de confirmaci&#x00f3;n -->
                <HBox fx:id="bannerSaved" styleClass="config-banner-success" alignment="CENTER_LEFT" spacing="12"
                      visible="false" managed="false">
                    <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="20" fill="#2e7d32"/>
                    <Label text="%config.banner.success" styleClass="config-banner-text"/>
                </HBox>

            </VBox>
        </ScrollPane>
</VBox>
