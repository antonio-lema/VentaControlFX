<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<BorderPane prefHeight="700.0" prefWidth="500.0" styleClass="payment-root"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.ventacontrolfx.presentation.controller.PaymentController">
   <top>
      <HBox alignment="CENTER_LEFT" styleClass="payment-header">
         <Label text="Forma de pago" styleClass="payment-header-title" />
         <Region HBox.hgrow="ALWAYS" />
         <Button onAction="#handleClose" styleClass="btn-icon" cancelButton="true">
            <graphic>
                <FontAwesomeIconView glyphName="CLOSE" size="20" fill="white" />
            </graphic>
         </Button>
      </HBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true" styleClass="detail-scroll" vbarPolicy="AS_NEEDED">
         <content>
            <VBox alignment="TOP_CENTER" spacing="15.0" styleClass="payment-body">
               <!-- Total Display -->
               <VBox alignment="CENTER" spacing="5.0">
                  <Label fx:id="lblTotalAmount" text="34,99 €" styleClass="payment-total-amount" />
                  <Label text="Total a cobrar" styleClass="label-muted" />
                  <padding><Insets bottom="20.0" top="10.0" /></padding>
               </VBox>

               <!-- Cash Section -->
               <VBox styleClass="payment-method-card payment-method-active">
                  <!-- Header -->
                  <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="payment-method-header">
                     <FontAwesomeIconView glyphName="MONEY" size="16" fill="#1e88e5" />
                     <Label text="Efectivo" styleClass="payment-method-label" />
                     <Region HBox.hgrow="ALWAYS" />
                     <Label fx:id="lblCashAmount" text="34.99 €" styleClass="badge-primary" />
                  </HBox>

                  <!-- Content -->
                  <VBox spacing="15.0" style="-fx-padding: 15;">
                     <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <TextField fx:id="txtGivenAmount" promptText="0.00"
                                   styleClass="modern-input-field payment-amount-field"
                                   HBox.hgrow="ALWAYS" />
                        <Button text="Cobrar" onAction="#handleCashPayment"
                                styleClass="btn-primary btn-lg" defaultButton="true" />
                     </HBox>

                     <!-- Quick Buttons -->
                     <GridPane hgap="10.0" vgap="10.0" styleClass="quick-money-grid">
                       <columnConstraints>
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                       </columnConstraints>
                       <rowConstraints>
                         <RowConstraints minHeight="10.0" prefHeight="40.0" vgrow="SOMETIMES" />
                       </rowConstraints>
                        <Button fx:id="btnQuick1" text="35 €" maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleQuickMoney" styleClass="btn-primary" />
                        <Button fx:id="btnQuick2" text="36 €" maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleQuickMoney" styleClass="btn-primary" GridPane.columnIndex="1" />
                        <Button fx:id="btnQuick3" text="40 €" maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleQuickMoney" styleClass="btn-primary" GridPane.columnIndex="2" />
                        <Button fx:id="btnQuick4" text="50 €" maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleQuickMoney" styleClass="btn-primary" GridPane.columnIndex="3" />
                     </GridPane>
                  </VBox>
               </VBox>

               <!-- Card Payment -->
               <Button onAction="#handleCardPayment" maxWidth="Infinity"
                       alignment="CENTER_LEFT" styleClass="payment-method-card payment-method-btn">
                   <graphic>
                       <HBox alignment="CENTER_LEFT" spacing="15" maxWidth="Infinity">
                           <FontAwesomeIconView glyphName="CREDIT_CARD" size="16" fill="#1e88e5" />
                           <Label text="Tarjeta de Crédito" styleClass="payment-method-label" />
                           <Region HBox.hgrow="ALWAYS" />
                           <FontAwesomeIconView glyphName="ANGLE_RIGHT" size="16" fill="#64748b" />
                       </HBox>
                   </graphic>
               </Button>
            </VBox>
         </content>
      </ScrollPane>
   </center>
   <bottom>
       <HBox alignment="CENTER_RIGHT" styleClass="payment-footer">
           <Button text="Cancelar" onAction="#handleClose"
                   styleClass="btn-secondary" cancelButton="true" />
       </HBox>
   </bottom>
</BorderPane>
