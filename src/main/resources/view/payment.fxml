<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import java.net.URL?>

<BorderPane prefHeight="700.0" prefWidth="500.0" styleClass="payment-root"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.ventacontrolfx.presentation.controller.PaymentController">
   <top>
      <HBox alignment="CENTER_LEFT" styleClass="payment-header">
         <Label text="%payment.title" styleClass="payment-header-title" />
         <Region HBox.hgrow="ALWAYS" />
         <Button onAction="#handleClose" styleClass="btn-icon" cancelButton="true">
            <graphic>
                <FontAwesomeIconView glyphName="CLOSE" size="20" styleClass="icon-white" />
            </graphic>
         </Button>
      </HBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true" styleClass="detail-scroll" vbarPolicy="AS_NEEDED">
         <content>
            <VBox alignment="TOP_CENTER" spacing="15.0" styleClass="payment-body">
               <!-- Total Display -->
               <VBox alignment="CENTER" spacing="5.0">
                  <Label fx:id="lblTotalAmount" text="34,99 €" styleClass="payment-total-amount" />
                  <Label text="%payment.total_to_charge" styleClass="label-muted" />
                  <padding><Insets bottom="20.0" top="10.0" /></padding>
               </VBox>

               <!-- Cash Section -->
               <VBox fx:id="cashSection" styleClass="payment-method-card payment-method-active">
                  <!-- Header -->
                  <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="payment-method-header">
                     <FontAwesomeIconView glyphName="MONEY" size="16" styleClass="icon-primary" />
                     <Label text="%payment.method.cash" styleClass="payment-method-label" />
                     <Region HBox.hgrow="ALWAYS" />
                     <Label fx:id="lblCashAmount" text="34.99 €" styleClass="badge-primary" />
                  </HBox>

                  <!-- Content -->
                  <VBox spacing="15.0" style="-fx-padding: 15;">
                        <VBox spacing="10" HBox.hgrow="ALWAYS">
                           <HBox spacing="10.0" alignment="CENTER_LEFT">
                              <TextField fx:id="txtGivenAmount" promptText="0.00"
                                         styleClass="modern-input-field payment-amount-field"
                                         HBox.hgrow="ALWAYS" />
                              <Button text="%payment.btn.cash" onAction="#handleCashPayment"
                                      styleClass="btn-primary btn-lg" defaultButton="true" graphicTextGap="8">
                                  <graphic>
                                      <FontAwesomeIconView glyphName="CHECK_CIRCLE" size="18" fill="white" />
                                  </graphic>
                              </Button>
                           </HBox>
                           <Button text="%payment.btn.mixed" onAction="#handleMixedPayment"
                                   maxWidth="Infinity" styleClass="btn-secondary" graphicTextGap="8">
                               <graphic>
                                   <FontAwesomeIconView glyphName="CREDIT_CARD" size="16" fill="#64748b" />
                               </graphic>
                           </Button>
                        </VBox>

                     <!-- Quick Buttons -->
                     <GridPane hgap="10.0" vgap="10.0" styleClass="quick-money-grid">
                       <columnConstraints>
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                         <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                       </columnConstraints>
                       <rowConstraints>
                         <RowConstraints minHeight="35.0" vgrow="SOMETIMES" />
                       </rowConstraints>
                        <Button fx:id="btnQuick1" text="35 €" maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleQuickMoney" styleClass="btn-primary" />
                        <Button fx:id="btnQuick2" text="36 €" maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleQuickMoney" styleClass="btn-primary" GridPane.columnIndex="1" />
                        <Button fx:id="btnQuick3" text="40 €" maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleQuickMoney" styleClass="btn-primary" GridPane.columnIndex="2" />
                        <Button fx:id="btnQuick4" text="50 €" maxWidth="Infinity" maxHeight="Infinity"
                                onAction="#handleQuickMoney" styleClass="btn-primary" GridPane.columnIndex="3" />
                     </GridPane>
                  </VBox>
               </VBox>

               <!-- Card Payment -->
               <Button onAction="#handleCardPayment" maxWidth="Infinity"
                       alignment="CENTER_LEFT" styleClass="payment-method-card payment-method-btn">
                   <graphic>
                       <HBox alignment="CENTER_LEFT" spacing="15" maxWidth="Infinity">
                           <FontAwesomeIconView glyphName="CREDIT_CARD" size="16" styleClass="icon-primary" />
                           <Label text="%payment.method.card" styleClass="payment-method-label" />
                           <Region HBox.hgrow="ALWAYS" />
                           <FontAwesomeIconView glyphName="ANGLE_RIGHT" size="16" styleClass="icon-muted" />
                       </HBox>
                   </graphic>
               </Button>

                <!-- Warning Message for Disallowed Cash -->
                <VBox fx:id="vboxCashWarning" managed="false" visible="false" alignment="CENTER" spacing="10" style="-fx-padding: 10 20; -fx-background-color: rgba(239, 68, 68, 0.1); -fx-background-radius: 8; -fx-border-color: #ef4444; -fx-border-width: 1; -fx-border-radius: 8;">
                    <HBox alignment="CENTER" spacing="10">
                        <FontAwesomeIconView glyphName="EXCLAMATION_TRIANGLE" size="18" fill="#ef4444" />
                        <Label fx:id="lblCashWarning" text="%payment.warning.card_only" style="-fx-text-fill: #ef4444; -fx-font-weight: bold;" wrapText="true" />
                    </HBox>
                </VBox>
            </VBox>
         </content>
      </ScrollPane>
   </center>
   <bottom>
       <HBox alignment="CENTER_RIGHT" styleClass="payment-footer">
           <Button text="%payment.btn.cancel" onAction="#handleClose"
                   styleClass="btn-secondary" cancelButton="true" />
       </HBox>
   </bottom>
</BorderPane>
