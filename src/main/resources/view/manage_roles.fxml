<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.scene.layout.StackPane?>

<VBox spacing="0" styleClass="main-content-area" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.ManageRolesController">
    <!-- Header Section -->
    <VBox styleClass="view-header" spacing="0">
        <children>
            <HBox spacing="16" alignment="CENTER_LEFT">
                <children>
                    <StackPane styleClass="view-header-icon-wrap">
                        <children><FontAwesomeIconView glyphName="ID_BADGE" size="22" fill="white"/></children>
                    </StackPane>
                    <VBox spacing="2">
                        <children>
                            <Label text="Gesti\u00f3n de Roles" styleClass="view-title"/>
                            <Label text="Administra los roles del sistema y sus permisos asociados" styleClass="view-subtitle"/>
                        </children>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#handleNewRole" styleClass="btn-primary" text=" Nuevo Rol">
                        <graphic><FontAwesomeIconView glyphName="PLUS" size="14" fill="white" /></graphic>
                    </Button>
                </children>
            </HBox>
        </children>
    </VBox>

    <VBox spacing="20.0" VBox.vgrow="ALWAYS" style="-fx-padding: 30 30 20 30;">

    <!-- Filter Section -->
    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="modern-filter-bar">
        <children>
            <HBox alignment="CENTER_LEFT" styleClass="search-bar" maxWidth="500" HBox.hgrow="ALWAYS">
                <children>
                    <FontAwesomeIconView glyphName="SEARCH" size="16" fill="#adb5bd" />
                    <TextField fx:id="txtSearch" promptText="Nombre del rol o descripci\u00f3n..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                </children>
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
        </children>
    </HBox>

    <!-- Cards Section -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS" hbarPolicy="NEVER">
        <content>
            <FlowPane fx:id="roleCardsPane" hgap="25" vgap="25">
                <padding>
                    <Insets top="10" right="10" bottom="10" left="10"/>
                </padding>
                <!-- Cards will be populated here -->
            </FlowPane>
        </content>
    </ScrollPane>
    
    <!-- Count Section -->
    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10;">
        <children>
            <Label fx:id="lblCount" text="0 roles encontrados" styleClass="label-muted" style="-fx-font-weight: bold;"/>
        </children>
    </HBox>

</VBox>
</VBox>
