<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<StackPane fx:id="rootStackPane" styleClass="register-popup-background" onMousePressed="#handleMousePressed" onMouseDragged="#handleMouseDragged" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.presentation.controller.AddProductController">
    <VBox maxWidth="500" maxHeight="650" spacing="0" alignment="CENTER" styleClass="modern-register-card">
        <padding>
            <Insets top="25" right="40" bottom="25" left="40"/>
        </padding>
        <!-- Header -->
        <VBox styleClass="modern-register-header" alignment="CENTER_LEFT">
            <Label fx:id="lblTitle" text="Producto" styleClass="modern-register-title"/>
            <Label fx:id="lblSubtitle" text="Introduce los datos del producto" styleClass="modern-register-subtitle" style="-fx-text-fill: #64748b;"/>
        </VBox>
        
        <ScrollPane hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 0 10 0 0;">
            <content>
                <VBox spacing="15" style="-fx-background-color: transparent;">
                    
                    <!-- Name -->
                    <VBox styleClass="modern-input-group">
                        <Label text="Nombre del Producto" styleClass="modern-label" style="-fx-text-fill: #1e293b; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;"/>
                        <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                            <FontAwesomeIconView glyphName="TAG" size="18" fill="#64748b">
                                <HBox.margin><Insets right="10"/></HBox.margin>
                            </FontAwesomeIconView> 
                            <TextField fx:id="txtName" promptText="Ej: Coca Cola 33cl" styleClass="modern-input-field" HBox.hgrow="ALWAYS" style="-fx-text-fill: #1e293b;"/>
                        </HBox>
                    </VBox>
                    
                    <!-- Dynamic Prices -->
                    <VBox fx:id="vboxPrices" spacing="15" styleClass="modern-input-group">
                         <!-- Price fields will be injected here dynamically -->
                    </VBox>
                    
                    <!-- Category -->
                     <VBox styleClass="modern-input-group">
                        <Label text="Categoría" styleClass="modern-label" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;"/>
                        <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                            <FontAwesomeIconView glyphName="FOLDER_OPEN" size="18" fill="#64748b">
                                <HBox.margin><Insets right="10"/></HBox.margin>
                            </FontAwesomeIconView> 
                            <ComboBox fx:id="cmbCategory" promptText="Seleccionar..." styleClass="modern-input-field" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-text-fill: #1e293b;"/>
                        </HBox>
                    </VBox>

                    <!-- Tax Group (V2) -->
                    <VBox styleClass="modern-input-group">
                        <Label text="Grupo de Impuestos" styleClass="modern-label" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;"/>
                        <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                            <FontAwesomeIconView glyphName="SHIELD" size="18" fill="#64748b">
                                <HBox.margin><Insets right="10"/></HBox.margin>
                            </FontAwesomeIconView> 
                            <ComboBox fx:id="cmbTaxGroup" promptText="Seleccionar grupo fiscal..." styleClass="modern-input-field" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent; -fx-text-fill: #1e293b;"/>
                        </HBox>
                    </VBox>

                    <!-- IVA Legacy -->
                    <VBox styleClass="modern-input-group">
                        <Label text="IVA Específico (Opcional)" styleClass="modern-label" style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;"/>
                        <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                            <FontAwesomeIconView glyphName="PERCENT" size="18" fill="#64748b">
                                <HBox.margin><Insets right="10"/></HBox.margin>
                            </FontAwesomeIconView> 
                            <TextField fx:id="txtIva" promptText="Ej: 21 (dejar vacío para usar defecto)" styleClass="modern-input-field" HBox.hgrow="ALWAYS" style="-fx-text-fill: #1e293b;"/>
                        </HBox>
                    </VBox>

                    <!-- Stock Management -->
                    <VBox spacing="10" style="-fx-background-color: #f1f5f9; -fx-padding: 15; -fx-background-radius: 8;">
                        <CheckBox fx:id="chkManageStock" text="Gestionar Inventario / Stock" styleClass="modern-checkbox" style="-fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <HBox spacing="15" fx:id="hboxStockDetails">
                            <VBox HBox.hgrow="ALWAYS" spacing="5">
                                <Label text="Stock Actual" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                                    <FontAwesomeIconView glyphName="CUBE" size="16" fill="#64748b">
                                        <HBox.margin><Insets right="5"/></HBox.margin>
                                    </FontAwesomeIconView>
                                    <TextField fx:id="txtStockQuantity" promptText="0" styleClass="modern-input-field" prefWidth="80" style="-fx-text-fill: #1e293b;"/>
                                </HBox>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" spacing="5">
                                <Label text="Aviso Stock Bajo" style="-fx-font-size: 11px; -fx-text-fill: #64748b; -fx-font-weight: bold;"/>
                                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                                    <FontAwesomeIconView glyphName="BELL" size="16" fill="#64748b">
                                        <HBox.margin><Insets right="5"/></HBox.margin>
                                    </FontAwesomeIconView>
                                    <TextField fx:id="txtMinStock" promptText="0" styleClass="modern-input-field" prefWidth="80" style="-fx-text-fill: #1e293b;"/>
                                </HBox>
                            </VBox>
                        </HBox>
                    </VBox>
                    
                    <!-- Image & Favorite Row -->
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <CheckBox fx:id="chkFavorite" text="Favorito" styleClass="modern-checkbox" style="-fx-text-fill: #1e293b;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                         <Button fx:id="btnSelectImage" text="Cambiar Imagen" onAction="#handleSelectImage" styleClass="modern-btn-secondary">
                            <graphic>
                                 <FontAwesomeIconView glyphName="IMAGE" size="14" fill="#64748b"/>
                            </graphic>
                         </Button>
                    </HBox>
                     <!-- Image Preview -->
                    <HBox alignment="CENTER" style="-fx-padding: 10; -fx-background-color: #f8fafc; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-border-width: 1;">
                         <ImageView fx:id="ivProductImage" fitWidth="100" fitHeight="100" preserveRatio="true"/>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
        
        <!-- Actions -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 30 0 0 0;">
            <Button text="Cancelar" onAction="#handleCancel" styleClass="modern-btn-secondary" cancelButton="true"/>
            <Button text="Guardar Producto" onAction="#handleSave" styleClass="modern-btn-primary" defaultButton="true"/>
        </HBox>
    </VBox>
</StackPane>
