<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>

<StackPane fx:id="rootStackPane" styleClass="register-popup-background" onMousePressed="#handleMousePressed" onMouseDragged="#handleMouseDragged" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.ventacontrolfx.controller.AddProductController">
    <VBox maxWidth="500" spacing="0" alignment="CENTER" styleClass="modern-register-card">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>
        <!-- Header -->
        <VBox styleClass="modern-register-header" alignment="CENTER_LEFT">
            <Label fx:id="lblTitle" text="Producto" styleClass="modern-register-title"/>
            <Label fx:id="lblSubtitle" text="Introduce los datos del producto" styleClass="modern-register-subtitle"/>
        </VBox>
        
        <VBox spacing="15">
            <!-- Name -->
            <VBox styleClass="modern-input-group">
                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                    <FontAwesomeIconView glyphName="TAG" size="18" fill="#b0b0b0">
                        <HBox.margin>
                            <Insets right="10"/>
                        </HBox.margin>
                    </FontAwesomeIconView> 
                    <TextField fx:id="txtName" promptText="Nombre del producto" styleClass="modern-input-field" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
            
            <!-- Price -->
             <VBox styleClass="modern-input-group">
                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                    <FontAwesomeIconView glyphName="MONEY" size="18" fill="#b0b0b0">
                         <HBox.margin>
                            <Insets right="10"/>
                        </HBox.margin>
                    </FontAwesomeIconView> 
                    <TextField fx:id="txtPrice" promptText="Precio" styleClass="modern-input-field" HBox.hgrow="ALWAYS"/>
                </HBox>
            </VBox>
            
            <!-- Category -->
             <VBox styleClass="modern-input-group">
                <HBox styleClass="modern-input-container" alignment="CENTER_LEFT">
                    <FontAwesomeIconView glyphName="FOLDER_OPEN" size="18" fill="#b0b0b0">
                        <HBox.margin>
                            <Insets right="10"/>
                        </HBox.margin>
                    </FontAwesomeIconView> 
                    <ComboBox fx:id="cmbCategory" promptText="Categoría" styleClass="modern-input-field" maxWidth="Infinity" HBox.hgrow="ALWAYS" style="-fx-background-color: transparent;"/>
                </HBox>
            </VBox>
            
            <!-- Image & Favorite Row -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <CheckBox fx:id="chkFavorite" text="Favorito" styleClass="modern-checkbox"/>
                <Region HBox.hgrow="ALWAYS"/>
                 <Button fx:id="btnSelectImage" text="Imagen" onAction="#handleSelectImage" styleClass="modern-btn-secondary">
                    <graphic>
                         <FontAwesomeIconView glyphName="IMAGE" size="14" fill="#7f8c8d"/>
                    </graphic>
                 </Button>
            </HBox>
             <!-- Image Preview -->
            <HBox alignment="CENTER" style="-fx-padding: 10; -fx-background-color: #f8fafc; -fx-background-radius: 8;">
                 <ImageView fx:id="ivProductImage" fitWidth="100" fitHeight="100" preserveRatio="true"/>
            </HBox>

        </VBox>
        
        <!-- Actions -->
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 30 0 0 0;">
            <Button text="Cancelar" onAction="#handleCancel" styleClass="modern-btn-secondary" cancelButton="true"/>
            <Button text="Guardar" onAction="#handleSave" styleClass="modern-btn-primary" defaultButton="true"/>
        </HBox>
    </VBox>
</StackPane>
